# Fleexa Manager remote staging environment example.
# Copy these names into the staging host or CI secret store only.
# Do not put real secrets in this file.

RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
FRONTEND_URL=https://<staging-host>
FORCE_SSL=true
SECRET_KEY_BASE=<staging-secret>

POSTGRES_HOST=<staging-postgres-host>
POSTGRES_PORT=5432
POSTGRES_USERNAME=<staging-postgres-user>
POSTGRES_PASSWORD=<staging-postgres-password>
POSTGRES_DB=<staging-db-name>
REDIS_URL=redis://:<staging-redis-password>@<staging-redis-host>:6379/0

FLEEXA_MANAGER_SESSION_COOKIE_SECURE=true
FLEEXA_MANAGER_SESSION_TTL_SECONDS=43200
FLEEXA_MANAGER_LOGIN_RATE_LIMIT=10
FLEEXA_MANAGER_LOGIN_RATE_LIMIT_WINDOW=60
FLEEXA_MANAGER_MESSAGE_SEND_RATE_LIMIT=60
FLEEXA_MANAGER_MESSAGE_SEND_RATE_LIMIT_WINDOW=60
FLEEXA_MANAGER_BOOKING_SYNC_RATE_LIMIT=120
FLEEXA_MANAGER_BOOKING_SYNC_RATE_LIMIT_WINDOW=60
FLEEXA_MANAGER_BOOKING_RELINK_RATE_LIMIT=30
FLEEXA_MANAGER_BOOKING_RELINK_RATE_LIMIT_WINDOW=60

SENTRY_DSN=<backend-staging-dsn>
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_SEND_DEFAULT_PII=false
DISABLE_SENTRY_PII=true
FLEEXA_MANAGER_OBSERVABILITY_SMOKE_ENABLED=false
FLEEXA_MANAGER_OBSERVABILITY_SMOKE_TOKEN=<staging-observability-smoke-token>

EXPO_PUBLIC_FLEEXA_APP_ENV=preview
EXPO_PUBLIC_FLEEXA_API_MODE=live
EXPO_PUBLIC_FLEEXA_API_DRIVER=manager
EXPO_PUBLIC_FLEEXA_API_BASE_URL=https://<staging-host>/api/fleexa-manager/v1
EXPO_PUBLIC_SENTRY_DSN=<manager-web-ios-staging-dsn>
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# Staging acceptance must not use mock or raw Chatwoot modes:
# EXPO_PUBLIC_FLEEXA_API_MODE=mock
# EXPO_PUBLIC_FLEEXA_API_DRIVER=chatwoot
