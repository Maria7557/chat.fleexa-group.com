+class Api::FleexaManager::V1::Accounts::Pipeline::StagesController < Api::FleexaManager::V1::BaseController
+  before_action :set_current_account_from_params
+  before_action :ensure_crm_pipeline_available!
+
+  def index
+    return unless ensure_pipeline_read_permission
+
+    include_counters = ActiveModel::Type::Boolean.new.cast(params.fetch(:includeCounters, true))
+    stages = CrmPipelineStage.for_account(Current.account.id).ordered
+
+    render json: {
+      data: stages.map do |stage|
+        FleexaManager::V1::DtoSerializer.pipeline_stage(
+          stage,
+          include_counters: include_counters
+        )
+      end
+    }
+  end
+
+  private
+
+  def ensure_crm_pipeline_available!
+    return if defined?(CrmPipelineStage) && defined?(CrmDeal)
+
+    render_manager_error('not_found', 'CRM pipeline is not available.', status: :not_found)
+  end
+
+  def ensure_pipeline_read_permission
+    return true if manager_permissions(@current_account_user).include?('pipeline:read')
+
+    render_manager_error('forbidden', 'Pipeline access is not permitted.', status: :forbidden)
+    false
+  end
+end
