diff --git a/app/controllers/api/fleexa_manager/v1/accounts/pipeline/deals_controller.rb b/app/controllers/api/fleexa_manager/v1/accounts/pipeline/deals_controller.rb
new file mode 100644
index 0000000..24cef73
--- /dev/null
+++ b/app/controllers/api/fleexa_manager/v1/accounts/pipeline/deals_controller.rb
@@ -0,0 +1,147 @@
+class Api::FleexaManager::V1::Accounts::Pipeline::DealsController < Api::FleexaManager::V1::BaseController
+  before_action :set_current_account_from_params
+  before_action :ensure_crm_pipeline_available!
+
+  def index
+    return unless ensure_deal_read_permission
+
+    limit = request_limit
+    return if performed?
+
+    scope = apply_deal_filters(deal_scope)
+    return if performed?
+
+    sorted_scope = apply_deal_sort(scope)
+    return if performed?
+
+    deals = sorted_scope.limit(limit + 1).to_a
+    visible_deals = deals.first(limit)
+    has_more = deals.length > limit
+    next_cursor = visible_deals.any? ? deal_cursor_for(visible_deals.last) : nil
+
+    payload = {
+      data: visible_deals.map do |deal|
+        FleexaManager::V1::DtoSerializer.deal(deal, permissions: deal_permissions)
+      end,
+      page: cursor_page(
+        items: visible_deals,
+        has_more: has_more,
+        limit: limit,
+        next_cursor: next_cursor
+      )
+    }
+    payload[:stage] = FleexaManager::V1::DtoSerializer.stage_ref(@filtered_stage) if params[:stage_id].present? && @filtered_stage.present?
+
+    render json: payload
+  end
+
+  private
+
+  def deal_scope
+    CrmDeal.for_account(Current.account.id)
+           .includes(:stage, :contact, :conversation, :assignee)
+           .left_joins(:conversation)
+  end
+
+  def apply_deal_filters(scope)
+    scope = apply_stage_filter(scope)
+    return scope if performed?
+
+    scope = apply_assignment_filter(scope)
+    return scope if performed?
+
+    apply_deal_cursor(scope)
+  end
+
+  def apply_stage_filter(scope)
+    stage_filter = params[:stageId].presence || params[:stage_id].presence || params[:stageKey].presence
+    return scope if stage_filter.blank?
+
+    stage = find_stage(stage_filter)
+    return scope.none if performed?
+
+    @filtered_stage = stage
+    scope.where(stage_id: stage.id)
+  end
+
+  def apply_assignment_filter(scope)
+    assigned_to = params[:assignedTo].presence
+    return scope if assigned_to.blank?
+
+    return scope.where(assigned_to: current_manager_user.id) if assigned_to == 'me'
+
+    user_id = stable_id_value(assigned_to, 'user')
+    return render_manager_error('bad_request', 'Invalid assignedTo.', status: :bad_request) if user_id.blank?
+
+    return scope.where(assigned_to: user_id) if Current.account.account_users.where(user_id: user_id).exists?
+
+    render_manager_error('forbidden', 'Assigned manager is not accessible.', status: :forbidden)
+    scope.none
+  end
+
+  def apply_deal_cursor(scope)
+    cursor = decoded_cursor
+    return scope if cursor.blank? && !performed?
+    return scope.none if performed?
+
+    id = cursor['id'].to_i
+    unless id.positive?
+      render_manager_error('bad_request', 'Invalid cursor.', status: :bad_request)
+      return scope.none
+    end
+
+    scope.where('crm_deals.id < ?', id)
+  end
+
+  def apply_deal_sort(scope)
+    case params[:sort].presence || 'last_activity_desc'
+    when 'last_activity_desc'
+      scope.reorder(Arel.sql('COALESCE(conversations.last_activity_at, crm_deals.updated_at) DESC'), id: :desc)
+    when 'created_desc'
+      scope.reorder(created_at: :desc, id: :desc)
+    when 'amount_desc'
+      scope.reorder(amount: :desc, id: :desc)
+    when 'amount_asc'
+      scope.reorder(amount: :asc, id: :desc)
+    else
+      render_manager_error('bad_request', 'Invalid deal sort.', status: :bad_request)
+      scope.none
+    end
+  end
+
+  def deal_cursor_for(deal)
+    encode_cursor({ id: deal.id })
+  end
+
+  def find_stage(stage_param)
+    stage_id = stable_id_value(stage_param, 'stage')
+    scope = CrmPipelineStage.for_account(Current.account.id)
+    stage = if stage_id.present?
+              scope.find_by(id: stage_id)
+            else
+              scope.find_by(slug: stage_param.to_s)
+            end
+
+    return stage if stage.present?
+
+    render_manager_error('not_found', 'Pipeline stage was not found.', status: :not_found)
+    nil
+  end
+
+  def ensure_crm_pipeline_available!
+    return if defined?(CrmPipelineStage) && defined?(CrmDeal)
+
+    render_manager_error('not_found', 'CRM pipeline is not available.', status: :not_found)
+  end
+
+  def ensure_deal_read_permission
+    return true if manager_permissions(@current_account_user).include?('deals:read')
+
+    render_manager_error('forbidden', 'Deal access is not permitted.', status: :forbidden)
+    false
+  end
+
+  def deal_permissions
+    manager_permissions(@current_account_user) & %w[deals:read deals:update deals:update_stage]
+  end
+end
