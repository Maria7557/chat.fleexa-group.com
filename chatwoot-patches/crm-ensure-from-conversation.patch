+module Crm
+  class EnsureFromConversationJob < ApplicationJob
+    queue_as :low
+
+    def perform(conversation_id, account_id)
+      account = Account.find_by(id: account_id)
+      return if account.blank?
+
+      Crm::EnsureFromConversationService.new(
+        account: account,
+        conversation_id: conversation_id,
+      ).call
+    rescue ActiveRecord::RecordNotFound => e
+      Rails.logger.info("[CRM] conversation not found for auto-deal creation: #{e.message}")
+    rescue Crm::EnsureFromConversationService::InvalidStageError => e
+      Rails.logger.error("[CRM] failed to ensure deal for conversation #{conversation_id}: #{e.message}")
+    rescue StandardError => e
+      Rails.logger.error("[CRM] failed to ensure deal for conversation #{conversation_id}: #{e.class.name}: #{e.message}")
+    end
+  end
+end
