+module Crm
+  class EnsureFromConversationService
+    class InvalidStageError < StandardError; end
+
+    Result = Struct.new(:deal, :created, keyword_init: true)
+
+    CLOSED_STAGE_SLUGS = %w[done cancel closed_won closed_lost].freeze
+
+    def initialize(account:, conversation_id:, stage_slug: nil)
+      @account = account
+      @conversation_id = conversation_id
+      @stage_slug = stage_slug
+    end
+
+    def call
+      stage = resolve_stage!
+      conversation = @account.conversations.find(@conversation_id)
+      title = generated_title(conversation)
+
+      deal, created = find_or_create_deal!(conversation, stage, title)
+
+      Result.new(deal: deal, created: created)
+    end
+
+    private
+
+    def resolve_stage!
+      stage_slug = @stage_slug.presence || 'unassigned'
+      stage = CrmPipelineStage.for_account(@account.id).find_by!(slug: stage_slug)
+
+      stage
+    rescue ActiveRecord::RecordNotFound
+      raise InvalidStageError, "Pipeline stage '#{stage_slug}' was not found for account #{@account.id}"
+    end
+
+    def find_or_create_deal!(conversation, stage, title)
+      if conversation.contact_id.present?
+        active_deal = active_deal_for_contact(conversation)
+        return [active_deal, false] if active_deal.present?
+      end
+
+      deal = CrmDeal.find_or_create_by!(
+        account_id: @account.id,
+        conversation_id: conversation.id
+      ) do |deal|
+        deal.stage_id = stage.id
+        deal.title = title
+        deal.contact_id = conversation.contact_id
+        deal.assigned_to = nil
+      end
+
+      [deal, deal.previously_new_record?]
+    rescue ActiveRecord::RecordNotUnique
+      [CrmDeal.find_by!(account_id: @account.id, conversation_id: conversation.id), false]
+    end
+
+    def active_deal_for_contact(conversation)
+      CrmDeal.joins(:stage)
+        .for_account(@account.id)
+        .where(contact_id: conversation.contact_id)
+        .where.not(crm_pipeline_stages: { slug: CLOSED_STAGE_SLUGS })
+        .order(updated_at: :desc)
+        .first
+        &.tap do |deal|
+          next if deal.conversation_id == conversation.id
+
+          deal.update!(conversation_id: conversation.id)
+        end
+    end
+
+    def generated_title(conversation)
+      contact_name = conversation.contact&.name.to_s.strip
+      return "#{contact_name} - New request" if contact_name.present?
+
+      "Deal ##{Time.current.to_i}"
+    end
+  end
+end
