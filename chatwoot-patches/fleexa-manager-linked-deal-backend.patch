@@ -0,0 +1,80 @@
+class Api::FleexaManager::V1::Accounts::Conversations::DealsController < Api::FleexaManager::V1::BaseController
+  before_action :set_current_account_from_params
+  before_action :ensure_crm_deals_available!
+  before_action :set_conversation
+
+  def show
+    return unless ensure_deal_read_permission
+
+    deal = linked_deal
+    render json: linked_deal_response(deal)
+  end
+
+  def create
+    return unless ensure_deal_write_permission
+
+    result = deal_mutation_service.create_from_conversation(
+      conversation: @conversation,
+      payload: params
+    )
+
+    render json: linked_deal_response(result.deal), status: result.created ? :created : :ok
+  rescue FleexaManager::V1::DealMutationService::InvalidPayload => e
+    render_manager_error('validation_failed', e.message, status: :unprocessable_entity, details: e.details)
+  rescue ActiveRecord::RecordInvalid => e
+    render_manager_error('validation_failed', e.record.errors.full_messages.join(', '), status: :unprocessable_entity)
+  end
+
+  private
+
+  def set_conversation
+    @conversation = find_visible_conversation!(params[:conversation_id])
+  end
+
+  def linked_deal
+    CrmDeal.for_account(Current.account.id)
+           .includes(:stage, :contact, :conversation, :assignee)
+           .where(conversation_id: @conversation.id)
+           .order(updated_at: :desc)
+           .first
+  end
+
+  def linked_deal_response(deal)
+    {
+      conversationId: FleexaManager::V1::DtoSerializer.conversation_id(@conversation),
+      linkState: deal.present? ? 'linked' : 'missing',
+      deal: deal.present? ? FleexaManager::V1::DtoSerializer.deal(deal, permissions: deal_permissions) : nil
+    }
+  end
+
+  def deal_mutation_service
+    FleexaManager::V1::DealMutationService.new(
+      account: Current.account,
+      user: current_manager_user
+    )
+  end
+
+  def ensure_crm_deals_available!
+    return if defined?(CrmDeal) && defined?(CrmPipelineStage)
+
+    render_manager_error('not_found', 'CRM deals are not available.', status: :not_found)
+  end
+
+  def ensure_deal_read_permission
+    return true if manager_permissions(@current_account_user).include?('deals:read')
+
+    render_manager_error('forbidden', 'Deal access is not permitted.', status: :forbidden)
+    false
+  end
+
+  def ensure_deal_write_permission
+    return true if manager_permissions(@current_account_user).include?('deals:update')
+
+    render_manager_error('forbidden', 'Deal updates are not permitted.', status: :forbidden)
+    false
+  end
+
+  def deal_permissions
+    manager_permissions(@current_account_user) & %w[deals:read deals:update deals:update_stage]
+  end
+end
