diff --git a/app/services/fleexa_manager/v1/deal_mutation_service.rb b/app/services/fleexa_manager/v1/deal_mutation_service.rb
new file mode 100644
index 0000000..3d8e6bc
--- /dev/null
+++ b/app/services/fleexa_manager/v1/deal_mutation_service.rb
@@ -0,0 +1,283 @@
+module FleexaManager
+  module V1
+    class DealMutationService
+      DEFAULT_CURRENCY = 'AED'.freeze
+      MARKETING_CONFIG_KEY = 'crm_marketing_dashboard'.freeze
+      QUALIFICATION_STATUSES = %w[pending qualified unqualified].freeze
+
+      class InvalidPayload < StandardError
+        attr_reader :details
+
+        def initialize(message, details = nil)
+          @details = details
+          super(message)
+        end
+      end
+
+      Result = Struct.new(:deal, :created, keyword_init: true)
+
+      def initialize(account:, user:)
+        @account = account
+        @user = user
+      end
+
+      def create_from_conversation(conversation:, payload:)
+        existing_deal = linked_deal_for(conversation)
+        return Result.new(deal: existing_deal, created: false) if existing_deal.present?
+
+        normalized_payload = payload_hash(payload)
+        stage = stage_from_payload(normalized_payload) || default_stage
+        raise InvalidPayload, 'Pipeline stage is required.' if stage.blank?
+
+        deal = nil
+        ActiveRecord::Base.transaction do
+          deal = CrmDeal.create!(
+            account: @account,
+            conversation: conversation,
+            contact: conversation.contact,
+            stage: stage,
+            title: string_value(normalized_payload, 'title', 'clientName', 'client_name').presence || default_title_for(conversation),
+            assigned_to: assigned_manager_id(normalized_payload, fallback_id: conversation.assignee_id || @user.id),
+            amount: amount_value(normalized_payload),
+            custom_attributes: custom_attributes_for({}, normalized_payload, defaults: { 'qualification_status' => 'pending' })
+          )
+          create_activity(deal, 'created', to_stage: stage)
+        end
+
+        Result.new(deal: deal.reload, created: true)
+      end
+
+      def update(deal:, payload:)
+        normalized_payload = payload_hash(payload)
+        attrs = {}
+
+        if key_present?(normalized_payload, 'title', 'clientName', 'client_name')
+          attrs[:title] = string_value(normalized_payload, 'title', 'clientName', 'client_name')
+        end
+
+        stage = stage_from_payload(normalized_payload)
+        attrs[:stage] = stage if stage.present?
+        attrs[:amount] = amount_value(normalized_payload) if key_present?(normalized_payload, 'amount', 'amountValue', 'amount_value', 'currency')
+        attrs[:assigned_to] = assigned_manager_id(normalized_payload) if key_present?(normalized_payload, 'assignedManagerId', 'assigned_manager_id', 'assigned_to')
+
+        if attribution_or_qualification_payload?(normalized_payload)
+          attrs[:custom_attributes] = custom_attributes_for(deal.custom_attributes || {}, normalized_payload)
+        end
+
+        old_stage = deal.stage
+        ActiveRecord::Base.transaction do
+          deal.update!(attrs)
+          create_activity(deal, 'stage_changed', from_stage: old_stage, to_stage: deal.stage) if attrs.key?(:stage) && old_stage.id != deal.stage_id
+          create_activity(deal, 'updated') unless attrs.key?(:stage)
+        end
+
+        Result.new(deal: deal.reload, created: false)
+      end
+
+      private
+
+      def linked_deal_for(conversation)
+        CrmDeal.for_account(@account.id)
+               .includes(:stage, :contact, :conversation, :assignee)
+               .where(conversation_id: conversation.id)
+               .order(updated_at: :desc)
+               .first
+      end
+
+      def payload_hash(payload)
+        raw_payload = if payload.respond_to?(:to_unsafe_h)
+                        payload.to_unsafe_h
+                      elsif payload.respond_to?(:to_h)
+                        payload.to_h
+                      else
+                        {}
+                      end
+        raw_payload = raw_payload['deal'] || raw_payload[:deal] if (raw_payload['deal'] || raw_payload[:deal]).is_a?(Hash)
+
+        raw_payload.deep_stringify_keys
+      end
+
+      def default_stage
+        CrmPipelineStage.for_account(@account.id).ordered.first
+      end
+
+      def stage_from_payload(payload)
+        stage_ref = payload['stage'].is_a?(Hash) ? payload['stage'].deep_stringify_keys : {}
+        stage_id_value = string_value(payload, 'stageId', 'stage_id') || stage_ref['id']
+        stage_key = string_value(payload, 'stageKey', 'stage_key') || stage_ref['key']
+
+        return if stage_id_value.blank? && stage_key.blank?
+
+        stage = if stage_id_value.present?
+                  CrmPipelineStage.for_account(@account.id).find_by(id: stable_id_value(stage_id_value, 'stage') || stage_id_value)
+                else
+                  CrmPipelineStage.for_account(@account.id).find_by(slug: stage_key.to_s)
+                end
+        raise InvalidPayload, 'Pipeline stage is invalid.' if stage.blank?
+
+        stage
+      end
+
+      def amount_value(payload)
+        raw_amount = payload['amount']
+        amount_payload = raw_amount.is_a?(Hash) ? raw_amount.deep_stringify_keys : {}
+        currency = (amount_payload['currency'].presence || string_value(payload, 'currency')).to_s
+        raise InvalidPayload, 'Only AED deal currency is supported.' if currency.present? && currency != DEFAULT_CURRENCY
+
+        value = amount_payload['amount'].presence || string_value(payload, 'amountValue', 'amount_value')
+        value = raw_amount unless raw_amount.is_a?(Hash) || raw_amount.blank? || value.present?
+        return if value.blank?
+
+        BigDecimal(value.to_s)
+      rescue ArgumentError
+        raise InvalidPayload, 'Deal amount is invalid.'
+      end
+
+      def assigned_manager_id(payload, fallback_id: nil)
+        raw_value = string_value(payload, 'assignedManagerId', 'assigned_manager_id', 'assigned_to')
+        raw_value = payload.dig('assignedManager', 'id') if raw_value.blank? && payload['assignedManager'].is_a?(Hash)
+        raw_value = fallback_id if raw_value.blank? && fallback_id.present?
+        return if raw_value.blank?
+
+        user_id = stable_id_value(raw_value, 'user') || raw_value
+        account_user = @account.account_users.find_by(user_id: user_id)
+        raise InvalidPayload, 'Assigned manager is invalid.' if account_user.blank?
+
+        account_user.user_id
+      end
+
+      def custom_attributes_for(existing_attributes, payload, defaults: {})
+        attrs = existing_attributes.to_h.stringify_keys.merge(defaults)
+        apply_qualification(attrs, payload)
+        apply_attribution(attrs, payload, 'traffic_sources', 'trafficSource', 'traffic_source')
+        apply_attribution(attrs, payload, 'lead_origins', 'leadOrigin', 'lead_origin')
+        apply_lost_reason(attrs, payload)
+        attrs
+      end
+
+      def apply_qualification(attrs, payload)
+        status = string_value(payload, 'qualificationStatus', 'qualification_status')
+        status = payload.dig('qualification', 'status') if status.blank? && payload['qualification'].is_a?(Hash)
+        return if status.blank?
+        raise InvalidPayload, 'Qualification status is invalid.' unless QUALIFICATION_STATUSES.include?(status)
+
+        attrs['qualification_status'] = status
+      end
+
+      def apply_attribution(attrs, payload, collection_key, camel_key, snake_key)
+        nested = payload[camel_key].is_a?(Hash) ? payload[camel_key].deep_stringify_keys : {}
+        key = attribution_key(
+          string_value(payload, "#{camel_key}Key", "#{snake_key}_key", snake_key) ||
+          nested['key']
+        )
+        return if key.blank?
+
+        settings = attribution_settings(collection_key)
+        setting = settings.find { |item| item[:key] == key }
+        raise InvalidPayload, "#{camel_key} is invalid." if settings.present? && setting.blank?
+
+        label = setting&.dig(:label).presence ||
+                string_value(payload, "#{camel_key}Label", "#{snake_key}_label") ||
+                nested['label'].presence ||
+                key.humanize
+
+        attrs["#{snake_key}_key"] = key
+        attrs["#{snake_key}_label"] = label
+        attrs['source_detection_method'] = 'manual'
+        attrs['source_confidence'] = 'manual'
+        attrs['needs_source_clarification'] = false
+      end
+
+      def apply_lost_reason(attrs, payload)
+        nested = payload['lostReason'].is_a?(Hash) ? payload['lostReason'].deep_stringify_keys : {}
+        label = string_value(payload, 'lostReasonLabel', 'lost_reason_label') || nested['label']
+        key = attribution_key(string_value(payload, 'lostReasonKey', 'lost_reason_key', 'lost_reason') || nested['key'] || label)
+        return if key.blank? && label.blank?
+
+        attrs['lost_reason_key'] = key.presence || attribution_key(label)
+        attrs['lost_reason_label'] = label.presence || key.humanize
+      end
+
+      def attribution_settings(collection_key)
+        config = (@account.settings || {})[MARKETING_CONFIG_KEY]
+        return [] unless config.is_a?(Hash)
+
+        Array(config[collection_key] || config[collection_key.to_sym]).filter_map do |item|
+          record = item.respond_to?(:to_h) ? item.to_h.with_indifferent_access : {}
+          key = attribution_key(record[:key])
+          label = record[:label].to_s.strip
+          next if key.blank? || label.blank?
+          next if record.key?(:is_active) && ActiveModel::Type::Boolean.new.cast(record[:is_active]) == false
+
+          { key: key, label: label }
+        end
+      end
+
+      def attribution_or_qualification_payload?(payload)
+        key_present?(
+          payload,
+          'qualificationStatus',
+          'qualification_status',
+          'trafficSource',
+          'trafficSourceKey',
+          'traffic_source',
+          'traffic_source_key',
+          'leadOrigin',
+          'leadOriginKey',
+          'lead_origin',
+          'lead_origin_key',
+          'lostReason',
+          'lostReasonKey',
+          'lost_reason',
+          'lost_reason_key'
+        )
+      end
+
+      def create_activity(deal, activity_type, from_stage: nil, to_stage: nil)
+        return unless defined?(CrmDealActivity)
+
+        CrmDealActivity.create!(
+          account: @account,
+          crm_deal: deal,
+          user: @user,
+          activity_type: activity_type,
+          from_stage: from_stage,
+          to_stage: to_stage
+        )
+      end
+
+      def default_title_for(conversation)
+        conversation.contact&.name.presence ||
+          conversation.contact&.phone_number.presence ||
+          conversation.contact&.email.presence ||
+          "Conversation ##{conversation.display_id}"
+      end
+
+      def string_value(payload, *keys)
+        keys.each do |key|
+          value = payload[key.to_s]
+          return value.to_s.strip if value.present?
+        end
+
+        nil
+      end
+
+      def key_present?(payload, *keys)
+        keys.any? { |key| payload.key?(key.to_s) }
+      end
+
+      def stable_id_value(value, prefix)
+        match = value.to_s.match(/\A#{Regexp.escape(prefix)}_(\d+)\z/)
+        match&.[](1)&.to_i
+      end
+
+      def attribution_key(value)
+        value.to_s
+             .strip
+             .downcase
+             .gsub(/[^a-z0-9]+/, '_')
+             .gsub(/\A_+|_+\z/, '')
+      end
+    end
+  end
+end
