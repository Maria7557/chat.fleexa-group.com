+class Api::FleexaManager::V1::Accounts::DealsController < Api::FleexaManager::V1::BaseController
+  before_action :set_current_account_from_params
+  before_action :ensure_crm_deals_available!
+
+  def update
+    return unless ensure_deal_write_permission
+
+    deal = find_deal
+    return if performed?
+
+    result = deal_mutation_service.update(deal: deal, payload: params)
+
+    render json: {
+      data: FleexaManager::V1::DtoSerializer.deal(result.deal, permissions: deal_permissions)
+    }
+  rescue FleexaManager::V1::DealMutationService::InvalidPayload => e
+    render_manager_error('validation_failed', e.message, status: :unprocessable_entity, details: e.details)
+  rescue ActiveRecord::RecordInvalid => e
+    render_manager_error('validation_failed', e.record.errors.full_messages.join(', '), status: :unprocessable_entity)
+  end
+
+  private
+
+  def find_deal
+    deal_id = stable_id_value(params[:id], 'deal')
+    return render_manager_error('bad_request', 'Invalid dealId.', status: :bad_request) if deal_id.blank?
+
+    deal = CrmDeal.for_account(Current.account.id)
+                  .includes(:stage, :contact, :conversation, :assignee)
+                  .find_by(id: deal_id)
+    return render_manager_error('not_found', 'Deal was not found.', status: :not_found) if deal.blank?
+
+    deal
+  end
+
+  def deal_mutation_service
+    FleexaManager::V1::DealMutationService.new(
+      account: Current.account,
+      user: current_manager_user
+    )
+  end
+
+  def ensure_crm_deals_available!
+    return if defined?(CrmDeal) && defined?(CrmPipelineStage)
+
+    render_manager_error('not_found', 'CRM deals are not available.', status: :not_found)
+  end
+
+  def ensure_deal_write_permission
+    return true if manager_permissions(@current_account_user).include?('deals:update')
+
+    render_manager_error('forbidden', 'Deal updates are not permitted.', status: :forbidden)
+    false
+  end
+
+  def deal_permissions
+    manager_permissions(@current_account_user) & %w[deals:read deals:update deals:update_stage]
+  end
+end
