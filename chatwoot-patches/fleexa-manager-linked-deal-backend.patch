+            label: label.presence || normalized_key.humanize
+          }
+        end
+
+        def attribution_settings(account, collection_key)
+          config = (account.settings || {})[MARKETING_CONFIG_KEY]
+          items = config.is_a?(Hash) ? config[collection_key] || config[collection_key.to_sym] : []
+
+          Array(items).filter_map do |item|
+            record = item.respond_to?(:to_h) ? item.to_h.with_indifferent_access : {}
+            key = attribution_key(record[:key])
+            label = record[:label].to_s.strip
+            next if key.blank? || label.blank?
+            next if record.key?(:is_active) && ActiveModel::Type::Boolean.new.cast(record[:is_active]) == false
+
+            { key: key, label: label }
+          end
+        end
+
+        def attribution_key(value)
+          value.to_s
+               .strip
+               .downcase
+               .gsub(/[^a-z0-9]+/, '_')
+               .gsub(/\A_+|_+\z/, '')
+        end
+
         def reply_window(conversation)
           can_reply = conversation.can_reply?
 
