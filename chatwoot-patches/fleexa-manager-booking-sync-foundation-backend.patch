@@ -0,0 +1,251 @@
+require 'rails_helper'
+
+RSpec.describe 'Fleexa Manager Booking sync foundation API', type: :request do
+  let(:account) { create(:account) }
+  let(:other_account) { create(:account) }
+  let(:service_token) { 'booking-service-token-3b' }
+  let(:other_service_token) { 'other-booking-service-token-3b' }
+
+  def booking_headers(token)
+    { 'X-Fleexa-Booking-Token' => token }
+  end
+
+  def json_response
+    JSON.parse(response.body)
+  end
+
+  def create_booking_credential(account:, token:, scopes:)
+    FleexaManagerBookingCredential.create!(
+      account: account,
+      fleexa_company_id: "fleexa_company_#{account.id}",
+      token_digest: FleexaManagerBookingCredential.digest_token(token),
+      scopes: scopes,
+      active: true
+    )
+  end
+
+  def enable_booking_receiver!(account)
+    account.update!(
+      settings: (account.settings || {}).merge(
+        'fleexa_booking_pipeline_sync' => {
+          'receiver_enabled' => true
+        }
+      )
+    )
+  end
+
+  def sync_path(target_account = account)
+    "/api/fleexa-manager/v1/accounts/acc_#{target_account.id}/bookings/sync"
+  end
+
+  def resolve_deal_path(target_account = account)
+    "/api/fleexa-manager/v1/accounts/acc_#{target_account.id}/bookings/resolve-deal"
+  end
+
+  def relink_path(booking_id = 'order_1001', target_account = account)
+    "/api/fleexa-manager/v1/accounts/acc_#{target_account.id}/bookings/#{booking_id}/relink-deal"
+  end
+
+  def sync_payload(overrides = {})
+    {
+      booking_id: 'order_1001',
+      booking_number: 'BK-1001',
+      booking_client_id: 'booking_contact_501',
+      booking_client_name: 'Mina Patel',
+      booking_client_phone: nil,
+      booking_version: 7,
+      source_updated_at: '2026-07-18T10:00:00Z',
+      event_id: SecureRandom.uuid,
+      vehicle: {
+        vehicle_id: 'vehicle_77',
+        vehicle_name: 'Range Rover Sport',
+        vehicle_plate: 'D 83839'
+      },
+      rental_start: '2026-07-20T10:00:00Z',
+      rental_end: '2026-07-22T10:00:00Z',
+      amount: '1800.00',
+      currency: 'AED',
+      booking_status: 'reserved',
+      source: {
+        type: 'Booking'
+      },
+      referral: {
+        communication_phone: '+971501112233',
+        referred_by_contact_id: nil
+      }
+    }.merge(overrides)
+  end
+
+  describe 'service authentication' do
+    it 'rejects missing tokens' do
+      post sync_path, params: sync_payload, as: :json
+
+      expect(response).to have_http_status(:unauthorized)
+      expect(json_response['error']['code']).to eq('service_auth_missing')
+      expect(json_response['error']['details']).to include('retryable' => false)
+    end
+
+    it 'rejects invalid tokens' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:sync'])
+
+      post sync_path, params: sync_payload, headers: booking_headers('wrong-token'), as: :json
+
+      expect(response).to have_http_status(:unauthorized)
+      expect(json_response['error']['code']).to eq('service_auth_invalid')
+    end
+
+    it 'rejects a valid token scoped to another account' do
+      create_booking_credential(account: other_account, token: other_service_token, scopes: ['booking:sync'])
+
+      post sync_path, params: sync_payload, headers: booking_headers(other_service_token), as: :json
+
+      expect(response).to have_http_status(:forbidden)
+      expect(json_response['error']['code']).to eq('service_auth_account_mismatch')
+    end
+
+    it 'rejects a token without the required scope' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:relink'])
+
+      post sync_path, params: sync_payload, headers: booking_headers(service_token), as: :json
+
+      expect(response).to have_http_status(:forbidden)
+      expect(json_response['error']['code']).to eq('service_auth_scope_missing')
+    end
+  end
+
+  describe 'feature flags' do
+    it 'defaults the Chat receiver to SYNC_DISABLED without writing deals' do
+      credential = create_booking_credential(account: account, token: service_token, scopes: ['booking:sync'])
+
+      expect do
+        post sync_path, params: sync_payload, headers: booking_headers(service_token), as: :json
+      end.not_to change { [CrmDeal.count, credential.reload.updated_at] }
+
+      expect(response).to have_http_status(:ok)
+      expect(json_response).to include(
+        'status' => 'SYNC_DISABLED',
+        'code' => 'SYNC_DISABLED',
+        'retryable' => false,
+        'accountId' => "acc_#{account.id}",
+        'fleexaCompanyId' => "fleexa_company_#{account.id}"
+      )
+    end
+  end
+
+  describe 'contract skeleton' do
+    before do
+      enable_booking_receiver!(account)
+    end
+
+    it 'accepts the sync request contract without mutating crm_deals in Prompt 3B' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:sync'])
+
+      expect do
+        post sync_path, params: sync_payload, headers: booking_headers(service_token), as: :json
+      end.not_to change { CrmDeal.count }
+
+      expect(response).to have_http_status(:ok)
+      expect(json_response).to include(
+        'status' => 'ACCEPTED',
+        'bookingId' => 'order_1001',
+        'bookingVersion' => 7,
+        'freshnessBasis' => 'booking_version',
+        'mutated' => false
+      )
+    end
+
+    it 'rejects sync payloads missing required identity fields' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:sync'])
+
+      post sync_path,
+           params: sync_payload(booking_id: nil, booking_version: nil),
+           headers: booking_headers(service_token),
+           as: :json
+
+      expect(response).to have_http_status(:unprocessable_entity)
+      expect(json_response['error']['code']).to eq('validation_failed')
+      expect(json_response['error']['details']['missingFields']).to include('booking_id', 'booking_version')
+      expect(json_response['error']['details']).to include('retryable' => false)
+    end
+
+    it 'exposes the resolve-deal endpoint without treating #344 as an automatic deal id' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:sync'])
+
+      post resolve_deal_path,
+           params: { pipeline_deal_ref_input: '#344' },
+           headers: booking_headers(service_token),
+           as: :json
+
+      expect(response).to have_http_status(:ok)
+      expect(json_response['status']).to eq('ACCEPTED')
+      expect(json_response['resolution']).to include(
+        'status' => 'FOUNDATION_ONLY',
+        'input' => '#344',
+        'pipelineDealId' => nil,
+        'conversationId' => nil,
+        'ambiguous' => false
+      )
+    end
+
+    it 'requires relink scope for relink-deal' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:sync'])
+
+      post relink_path,
+           params: { new_pipeline_deal_id: 'deal_77', reason: 'Wrong link fixed by manager' },
+           headers: booking_headers(service_token),
+           as: :json
+
+      expect(response).to have_http_status(:forbidden)
+      expect(json_response['error']['code']).to eq('service_auth_scope_missing')
+    end
+
+    it 'accepts relink contract with relink scope without mutating deals in Prompt 3B' do
+      create_booking_credential(account: account, token: service_token, scopes: ['booking:relink'])
+
+      expect do
+        post relink_path,
+             params: { new_pipeline_deal_id: 'deal_77', reason: 'Wrong link fixed by manager' },
+             headers: booking_headers(service_token),
+             as: :json
+      end.not_to change { CrmDeal.count }
+
+      expect(response).to have_http_status(:ok)
+      expect(json_response).to include(
+        'status' => 'ACCEPTED',
+        'bookingId' => 'order_1001',
+        'newPipelineDealId' => 'deal_77',
+        'auditRequired' => true,
+        'mutated' => false
+      )
+    end
+  end
+
+  describe 'database protections' do
+    it 'does not expose raw booking service tokens as credential columns' do
+      expect(FleexaManagerBookingCredential.column_names).not_to include('token', 'raw_token', 'plain_token')
+      expect(FleexaManagerBookingCredential.column_names).to include('token_digest', 'scopes', 'account_id')
+    end
+
+    it 'has unique non-empty booking_id protection for account-scoped crm_deals' do
+      index = ActiveRecord::Base.connection.indexes(:crm_deals).find do |candidate|
+        candidate.name == 'uq_crm_deals_account_booking_id_nonempty'
+      end
+
+      expect(index).to be_present
+      expect(index.unique).to be(true)
+      expect(index.columns).to eq(%w[account_id booking_id])
+      expect(index.where).to include("booking_id IS NOT NULL")
+      expect(index.where).to include("booking_id")
+    end
+
+    it 'indexes contacts.custom_attributes booking_client_id for lookup without phone merges' do
+      index = ActiveRecord::Base.connection.indexes(:contacts).find do |candidate|
+        candidate.name == 'idx_contacts_booking_client_id_custom_attributes'
+      end
+
+      expect(index).to be_present
+      expect(index.columns).to include('account_id')
+      expect(index.where).to include("booking_client_id")
+    end
+  end
+end
