@@ -0,0 +1,151 @@
+class Api::FleexaManager::V1::Accounts::BookingsController < Api::FleexaManager::V1::ServiceController
+  NON_BLANK_SYNC_FIELDS = [
+    %w[booking_id bookingId],
+    %w[booking_number bookingNumber],
+    %w[booking_client_id bookingClientId],
+    %w[booking_client_name bookingClientName],
+    %w[booking_version bookingVersion],
+    %w[rental_start rentalStart],
+    %w[rental_end rentalEnd],
+    %w[currency],
+    %w[booking_status bookingStatus]
+  ].freeze
+  PRESENCE_ONLY_SYNC_FIELDS = [
+    %w[booking_client_phone bookingClientPhone],
+    %w[amount]
+  ].freeze
+
+  def resolve_deal
+    ref = payload_value('ref', 'dealRef', 'pipeline_deal_ref_input', 'pipelineDealRefInput')
+    return payload_error('ref is required.', missing_fields: ['ref']) if ref.blank?
+
+    render json: service_status_payload(
+      status: 'ACCEPTED',
+      message: 'Deal reference resolver endpoint is available; resolution logic is implemented in Prompt 4.',
+      extra: {
+        resolution: {
+          status: 'FOUNDATION_ONLY',
+          input: ref.to_s,
+          pipelineDealId: nil,
+          conversationId: nil,
+          ambiguous: false
+        },
+        deal: nil,
+        candidates: []
+      }
+    )
+  end
+
+  def sync
+    missing_fields = missing_sync_fields
+    return payload_error('Required booking sync fields are missing.', missing_fields: missing_fields) if missing_fields.any?
+    return payload_error('booking_version must be a monotonic integer.', missing_fields: ['booking_version']) unless booking_version_valid?
+    return payload_error('idempotency_key or event_id is required.', missing_fields: ['idempotency_key']) if idempotency_key.blank?
+
+    render json: service_status_payload(
+      status: 'ACCEPTED',
+      message: 'Booking sync receiver accepted the contract; deal mutation is implemented in Prompt 4.',
+      extra: {
+        bookingId: payload_value('booking_id', 'bookingId').to_s,
+        bookingVersion: booking_version,
+        idempotencyKey: idempotency_key,
+        freshnessBasis: 'booking_version',
+        mutated: false
+      }
+    )
+  end
+
+  def relink_deal
+    missing_fields = []
+    missing_fields << 'booking_id' if params[:booking_id].blank?
+    missing_fields << 'pipeline_deal_id' if payload_value('new_pipeline_deal_id', 'newPipelineDealId', 'pipeline_deal_id', 'pipelineDealId').blank?
+    missing_fields << 'reason' if payload_value('reason').blank?
+
+    return payload_error('Required relink fields are missing.', missing_fields: missing_fields) if missing_fields.any?
+
+    render json: service_status_payload(
+      status: 'ACCEPTED',
+      message: 'Booking relink endpoint accepted the contract; durable audit and deal mutation are implemented in Prompt 4.',
+      extra: {
+        bookingId: params[:booking_id].to_s,
+        newPipelineDealId: payload_value('new_pipeline_deal_id', 'newPipelineDealId', 'pipeline_deal_id', 'pipelineDealId').to_s,
+        auditRequired: true,
+        mutated: false
+      }
+    )
+  end
+
+  private
+
+  def required_booking_scope
+    action_name == 'relink_deal' ? 'booking:relink' : 'booking:sync'
+  end
+
+  def missing_sync_fields
+    missing = NON_BLANK_SYNC_FIELDS.filter_map do |keys|
+      keys.first unless payload_value(*keys).present?
+    end
+
+    PRESENCE_ONLY_SYNC_FIELDS.each do |keys|
+      missing << keys.first unless payload_key_present?(*keys)
+    end
+
+    missing << 'vehicle.vehicle_id' if vehicle_id.blank?
+    missing
+  end
+
+  def booking_version_valid?
+    booking_version.present?
+  end
+
+  def booking_version
+    raw = payload_value('booking_version', 'bookingVersion')
+    return if raw.blank?
+
+    Integer(raw)
+  rescue ArgumentError, TypeError
+    nil
+  end
+
+  def idempotency_key
+    payload_value('idempotency_key', 'idempotencyKey', 'event_id', 'eventId').presence ||
+      request.headers['Idempotency-Key'].presence
+  end
+
+  def vehicle_id
+    payload_value('vehicle_id', 'vehicleId').presence ||
+      vehicle_payload['vehicle_id'].presence ||
+      vehicle_payload['vehicleId'].presence
+  end
+
+  def vehicle_payload
+    payload_value('vehicle') || {}
+  end
+
+  def payload_value(*keys)
+    keys.each do |key|
+      return raw_payload[key] if raw_payload.key?(key)
+    end
+    nil
+  end
+
+  def payload_key_present?(*keys)
+    keys.any? { |key| raw_payload.key?(key) }
+  end
+
+  def raw_payload
+    @raw_payload ||= params.to_unsafe_h
+  end
+
+  def payload_error(message, missing_fields: [])
+    render_manager_error(
+      'validation_failed',
+      message,
+      status: :unprocessable_entity,
+      details: {
+        missingFields: missing_fields,
+        retryable: false
+      }
+    )
+  end
+end
