+class Api::FleexaManager::V1::ServiceController < Api::FleexaManager::V1::BaseController
+  skip_before_action :normalize_fleexa_bearer_token, raise: false
+  skip_before_action :authenticate_access_token!, raise: false
+  skip_before_action :validate_bot_access_token!, raise: false
+  skip_before_action :authenticate_user!, raise: false
+  skip_before_action :ensure_fleexa_manager_user!, raise: false
+
+  before_action :set_service_account_from_params
+  before_action :authenticate_booking_service!
+  before_action :ensure_booking_receiver_enabled!
+
+  private
+
+  def set_service_account_from_params
+    account_id = account_id_from_param(params[:account_id])
+    return render_manager_error('bad_request', 'Invalid accountId.', status: :bad_request) if account_id.blank?
+
+    account = Account.find_by(id: account_id)
+    return render_manager_error('not_found', 'Account was not found.', status: :not_found) if account.blank?
+    return render_manager_error('forbidden', 'Account is suspended.', status: :forbidden) unless account.active?
+
+    @service_account = account
+    Current.account = account
+  end
+
+  def authenticate_booking_service!
+    provided_token = booking_service_token
+    return render_service_auth_error('service_auth_missing', 'Booking service token is required.', :unauthorized) if provided_token.blank?
+
+    digest = FleexaManagerBookingCredential.digest_token(provided_token)
+    credential = FleexaManagerBookingCredential.active.find_by(token_digest: digest)
+    return render_service_auth_error('service_auth_invalid', 'Booking service token is invalid.', :unauthorized) if credential.blank?
+
+    unless credential.account_id == @service_account.id
+      return render_service_auth_error('service_auth_account_mismatch', 'Booking service token is not scoped to this account.', :forbidden)
+    end
+
+    unless credential.allows_scope?(required_booking_scope)
+      return render_service_auth_error('service_auth_scope_missing', "Booking service token is missing #{required_booking_scope}.", :forbidden)
+    end
+
+    @booking_service_credential = credential
+  end
+
+  def ensure_booking_receiver_enabled!
+    return if booking_receiver_enabled?
+
+    render json: service_status_payload(
+      status: 'SYNC_DISABLED',
+      message: 'Booking sync receiver is disabled for this account.'
+    )
+  end
+
+  def booking_receiver_enabled?
+    settings = @service_account.settings || {}
+    config = settings['fleexa_booking_pipeline_sync'] || settings[:fleexa_booking_pipeline_sync] || {}
+    ActiveModel::Type::Boolean.new.cast(config['receiver_enabled'] || config[:receiver_enabled])
+  end
+
+  def booking_service_token
+    header_token = request.headers['X-Fleexa-Booking-Token'].presence ||
+                   request.headers['X-Booking-Service-Token'].presence
+    bearer_token = request.headers['Authorization'].to_s.match(/\ABearer\s+(.+)\z/i)&.[](1)&.strip
+
+    header_token || bearer_token
+  end
+
+  def required_booking_scope
+    raise NotImplementedError, 'Service controller must define required_booking_scope.'
+  end
+
+  def account_id_from_param(value)
+    stable = stable_id_value(value, 'acc')
+    return stable if stable.present?
+
+    raw = value.to_s
+    return raw.to_i if raw.match?(/\A\d+\z/)
+  end
+
+  def render_service_auth_error(code, message, status)
+    render_manager_error(code, message, status: status, details: { retryable: false })
+  end
+
+  def service_status_payload(status:, message:, extra: {})
+    {
+      status: status,
+      code: status,
+      retryable: false,
+      accountId: "acc_#{@service_account.id}",
+      fleexaCompanyId: @booking_service_credential&.fleexa_company_id,
+      message: message
+    }.merge(extra)
+  end
+end
diff --git a/app/models/fleexa_manager_booking_credential.rb b/app/models/fleexa_manager_booking_credential.rb
