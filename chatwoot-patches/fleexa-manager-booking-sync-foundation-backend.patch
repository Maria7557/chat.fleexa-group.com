@@ -0,0 +1,45 @@
+require 'digest'
+
+class FleexaManagerBookingCredential < ApplicationRecord
+  ALLOWED_SCOPES = %w[booking:sync booking:relink].freeze
+  TOKEN_DIGEST_PATTERN = /\A[0-9a-f]{64}\z/.freeze
+
+  belongs_to :account
+  belongs_to :created_by, class_name: 'User', optional: true
+
+  scope :active, -> { where(active: true) }
+
+  before_validation :normalize_scopes
+  before_validation :normalize_metadata
+
+  validates :account_id, presence: true
+  validates :fleexa_company_id, presence: true
+  validates :token_digest, presence: true, format: { with: TOKEN_DIGEST_PATTERN }
+  validates :token_digest, uniqueness: { conditions: -> { where(active: true) } }, if: :active?
+  validate :allowed_scope_values
+
+  def self.digest_token(raw_token)
+    Digest::SHA256.hexdigest(raw_token.to_s)
+  end
+
+  def allows_scope?(scope)
+    scopes.include?(scope.to_s)
+  end
+
+  private
+
+  def normalize_scopes
+    self.scopes = Array(scopes).map(&:to_s).uniq
+  end
+
+  def normalize_metadata
+    self.metadata = {} unless metadata.is_a?(Hash)
+  end
+
+  def allowed_scope_values
+    invalid_scopes = scopes - ALLOWED_SCOPES
+    return if invalid_scopes.blank?
+
+    errors.add(:scopes, "include unsupported values: #{invalid_scopes.join(', ')}")
+  end
+end
