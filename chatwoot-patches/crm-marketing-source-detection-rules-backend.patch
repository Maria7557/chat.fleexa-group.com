+  def normalized_detection_rules(raw_rules)
+    Array(raw_rules).each_with_index.filter_map do |rule, index|
+      field = value_for(rule, :field).to_s
+      operator = value_for(rule, :operator).to_s
+      next unless DETECTION_RULE_FIELDS.include?(field) && DETECTION_RULE_OPERATORS.include?(operator)
+
+      traffic_source_key = attribution_key(value_for(rule, :result_traffic_source_key))
+      traffic_source_label = value_for(rule, :result_traffic_source_label).to_s.strip
+      lead_origin_key = attribution_key(value_for(rule, :result_lead_origin_key))
+      lead_origin_label = value_for(rule, :result_lead_origin_label).to_s.strip
+      next if traffic_source_key.blank? && lead_origin_key.blank?
+
+      priority = value_for(rule, :priority).to_i
+      {
+        id: value_for(rule, :id).presence || SecureRandom.uuid,
+        active: value_for(rule, :active).nil? ? true : boolean_value(value_for(rule, :active)),
+        priority: priority.positive? ? priority : index + 1,
+        field: field,
+        operator: operator,
+        value: value_for(rule, :value).to_s,
+        result_traffic_source_key: traffic_source_key,
+        result_traffic_source_label: traffic_source_label,
+        result_lead_origin_key: lead_origin_key,
+        result_lead_origin_label: lead_origin_label
+      }
+    end.sort_by { |rule| rule[:priority] }
+       .map.with_index { |rule, index| rule.merge(priority: index + 1) }
+  end
+
   def default_position(key)
     ALLOWED_WIDGET_KEYS.index(key) || ALLOWED_WIDGET_KEYS.length
   end
