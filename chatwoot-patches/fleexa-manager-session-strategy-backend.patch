diff --git a/app/models/fleexa_manager_session.rb b/app/models/fleexa_manager_session.rb
new file mode 100644
index 0000000..b8ae5e7
--- /dev/null
+++ b/app/models/fleexa_manager_session.rb
@@ -0,0 +1,89 @@
+require 'digest'
+require 'openssl'
+
+class FleexaManagerSession < ApplicationRecord
+  TOKEN_BYTES = 48
+  DEFAULT_TTL_SECONDS = 12.hours.to_i
+  MAX_TTL_SECONDS = 30.days.to_i
+  CLIENT_PLATFORMS = %w[web ios native].freeze
+
+  belongs_to :user
+  belongs_to :account, optional: true
+
+  validates :token_digest, presence: true, uniqueness: true
+  validates :client_platform, presence: true, inclusion: { in: CLIENT_PLATFORMS }
+  validates :expires_at, presence: true
+
+  scope :active, -> { where(revoked_at: nil).where('expires_at > ?', Time.current) }
+
+  class << self
+    def issue!(user:, account:, client_platform:, user_agent:, remote_ip:)
+      raw_token = SecureRandom.urlsafe_base64(TOKEN_BYTES)
+      session = create!(
+        user: user,
+        account: account,
+        client_platform: normalize_client_platform(client_platform),
+        token_digest: digest_token(raw_token),
+        user_agent_hash: digest_metadata(user_agent),
+        ip_hash: digest_metadata(remote_ip),
+        expires_at: session_ttl.seconds.from_now,
+        last_used_at: Time.current
+      )
+
+      [session, raw_token]
+    end
+
+    def authenticate(raw_token)
+      return if raw_token.blank?
+
+      session = active.includes(:user, :account).find_by(token_digest: digest_token(raw_token))
+      return if session.blank?
+      return unless session.user.respond_to?(:active_for_authentication?)
+      return unless session.user.active_for_authentication?
+
+      session.touch_usage!
+      session
+    end
+
+    def digest_token(raw_token)
+      OpenSSL::HMAC.hexdigest('SHA256', digest_secret, raw_token.to_s)
+    end
+
+    def normalize_client_platform(value)
+      platform = value.to_s.downcase
+      return platform if CLIENT_PLATFORMS.include?(platform)
+
+      'web'
+    end
+
+    def session_ttl
+      Integer(ENV.fetch('FLEEXA_MANAGER_SESSION_TTL_SECONDS', DEFAULT_TTL_SECONDS)).clamp(300, MAX_TTL_SECONDS)
+    rescue ArgumentError, TypeError
+      DEFAULT_TTL_SECONDS
+    end
+
+    private
+
+    def digest_metadata(value)
+      return if value.blank?
+
+      Digest::SHA256.hexdigest(value.to_s)
+    end
+
+    def digest_secret
+      Rails.application.secret_key_base.presence || ENV.fetch('SECRET_KEY_BASE')
+    end
+  end
+
+  def active?
+    revoked_at.blank? && expires_at.future?
+  end
+
+  def revoke!
+    update!(revoked_at: Time.current)
+  end
+
+  def touch_usage!
+    update_columns(last_used_at: Time.current, updated_at: Time.current)
+  end
+end
