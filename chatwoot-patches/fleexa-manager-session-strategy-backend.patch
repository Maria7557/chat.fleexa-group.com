diff --git a/spec/requests/api/fleexa_manager/v1/session_strategy_spec.rb b/spec/requests/api/fleexa_manager/v1/session_strategy_spec.rb
new file mode 100644
index 0000000..b5910ab
--- /dev/null
+++ b/spec/requests/api/fleexa_manager/v1/session_strategy_spec.rb
@@ -0,0 +1,127 @@
+require 'rails_helper'
+
+RSpec.describe 'Fleexa Manager session strategy', type: :request do
+  let(:account) { create(:account) }
+  let(:user) { create(:user) }
+  let!(:account_user) { create(:account_user, account: account, user: user, role: :administrator) }
+  let(:password) { 'FleexaSessionStrategy!2026' }
+
+  before do
+    user.update!(password: password, password_confirmation: password)
+    FleexaManager::V1::RateLimiter.reset_local! if defined?(FleexaManager::V1::RateLimiter)
+  end
+
+  def login_web
+    post '/api/fleexa-manager/v1/session',
+         params: { email: user.email, password: password, accountHint: "acc_#{account.id}", clientPlatform: 'web' },
+         as: :json
+  end
+
+  def login_ios
+    post '/api/fleexa-manager/v1/session',
+         params: { email: user.email, password: password, accountHint: "acc_#{account.id}", clientPlatform: 'ios' },
+         as: :json
+  end
+
+  it 'creates a web session using an HttpOnly SameSite cookie without returning a bearer token' do
+    login_web
+
+    expect(response).to have_http_status(:created)
+    expect(json_response).not_to include('accessToken')
+    expect(json_response['auth']).to include('transport' => 'http_only_cookie', 'refresh' => 'none')
+    expect(json_response['auth']['expiresAt']).to be_present
+    expect(response.headers['Set-Cookie']).to include('fleexa_manager_session')
+    expect(response.headers['Set-Cookie'].downcase).to include('httponly')
+    expect(response.headers['Set-Cookie'].downcase).to include('samesite=lax')
+    expect(FleexaManagerSession.count).to eq(1)
+    expect(FleexaManagerSession.first.token_digest).to be_present
+  end
+
+  it 'creates an iOS session using a bearer token for SecureStore storage' do
+    login_ios
+
+    expect(response).to have_http_status(:created)
+    token = json_response['accessToken']
+    expect(token).to be_present
+    expect(json_response['tokenType']).to eq('Bearer')
+    expect(json_response['auth']).to include('transport' => 'bearer_token', 'refresh' => 'none')
+    expect(FleexaManagerSession.find_by(token_digest: FleexaManagerSession.digest_token(token))).to be_present
+
+    get '/api/fleexa-manager/v1/session/current', headers: { 'Authorization' => "Bearer #{token}" }
+
+    expect(response).to have_http_status(:ok)
+    expect(json_response['activeAccountId']).to eq("acc_#{account.id}")
+  end
+
+  it 'denies wrong passwords without creating a session' do
+    post '/api/fleexa-manager/v1/session',
+         params: { email: user.email, password: 'wrong-password', clientPlatform: 'web' },
+         as: :json
+
+    expect(response).to have_http_status(:unauthorized)
+    expect(json_response['error']['code']).to eq('invalid_credentials')
+    expect(json_response).not_to include('accessToken')
+    expect(FleexaManagerSession.count).to eq(0)
+  end
+
+  it 'restores the current session from the web cookie' do
+    login_web
+
+    get '/api/fleexa-manager/v1/session/current'
+
+    expect(response).to have_http_status(:ok)
+    expect(json_response['user']['id']).to eq("user_#{user.id}")
+  end
+
+  it 'logs out by revoking the server session and clearing the web cookie' do
+    login_web
+    manager_session = FleexaManagerSession.first
+
+    delete '/api/fleexa-manager/v1/session'
+
+    expect(response).to have_http_status(:no_content)
+    expect(manager_session.reload.revoked_at).to be_present
+    expect(response.headers['Set-Cookie']).to include('fleexa_manager_session')
+    expect(response.headers['Set-Cookie']).to include('max-age=0')
+
+    get '/api/fleexa-manager/v1/session/current'
+
+    expect(response).to have_http_status(:unauthorized)
+    expect(json_response['error']['code']).to eq('unauthenticated')
+  end
+
+  it 'denies expired or invalid sessions' do
+    login_ios
+    token = json_response['accessToken']
+    FleexaManagerSession.first.update!(expires_at: 1.minute.ago)
+
+    get '/api/fleexa-manager/v1/session/current', headers: { 'Authorization' => "Bearer #{token}" }
+
+    expect(response).to have_http_status(:unauthorized)
+    expect(json_response['error']['code']).to eq('unauthenticated')
+
+    get '/api/fleexa-manager/v1/session/current', headers: { 'Authorization' => 'Bearer invalid-manager-session' }
+
+    expect(response).to have_http_status(:unauthorized)
+    expect(json_response['error']['code']).to eq('unauthenticated')
+  end
+
+  it 'denies revoked or disabled users' do
+    login_ios
+    token = json_response['accessToken']
+    FleexaManagerSession.first.revoke!
+
+    get '/api/fleexa-manager/v1/session/current', headers: { 'Authorization' => "Bearer #{token}" }
+
+    expect(response).to have_http_status(:unauthorized)
+
+    login_ios
+    fresh_token = json_response['accessToken']
+    user.update_column(:confirmed_at, nil)
+
+    get '/api/fleexa-manager/v1/session/current', headers: { 'Authorization' => "Bearer #{fresh_token}" }
+
+    expect(response).to have_http_status(:unauthorized)
+    expect(json_response['error']['code']).to eq('unauthenticated')
+  end
+end
