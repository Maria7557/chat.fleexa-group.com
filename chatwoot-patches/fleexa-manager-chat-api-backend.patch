diff --git a/spec/requests/api/fleexa_manager/v1/chat_api_spec.rb b/spec/requests/api/fleexa_manager/v1/chat_api_spec.rb
new file mode 100644
index 0000000..a013597
--- /dev/null
+++ b/spec/requests/api/fleexa_manager/v1/chat_api_spec.rb
@@ -0,0 +1,239 @@
+require 'rails_helper'
+
+RSpec.describe 'Fleexa Manager chat API', type: :request do
+  let(:account) { create(:account) }
+  let(:other_account) { create(:account) }
+  let(:user) { create(:user) }
+  let!(:account_user) { create(:account_user, account: account, user: user, role: :administrator) }
+  let(:access_token) { create(:access_token, owner: user) }
+  let(:headers) { { 'api_access_token' => access_token.token } }
+  let(:inbox) { create(:inbox, account: account) }
+  let(:contact) { create(:contact, account: account) }
+  let(:contact_inbox) { create(:contact_inbox, contact: contact, inbox: inbox) }
+  let!(:conversation) do
+    create(:conversation, account: account, inbox: inbox, contact: contact, contact_inbox: contact_inbox, display_id: 42)
+  end
+
+  before do
+    allow_any_instance_of(Conversation).to receive(:can_reply?).and_return(true)
+  end
+
+  describe 'OPTIONS /api/fleexa-manager/v1/*path' do
+    it 'allows local Expo web preflight without authentication' do
+      options '/api/fleexa-manager/v1/session/current',
+              headers: {
+                'Origin' => 'http://127.0.0.1:8082',
+                'Access-Control-Request-Method' => 'GET',
+                'Access-Control-Request-Headers' => 'authorization'
+              }
+
+      expect(response).to have_http_status(:no_content)
+      expect(response.headers['Access-Control-Allow-Origin']).to eq(
+        'http://127.0.0.1:8082'
+      )
+      expect(response.headers['Access-Control-Allow-Methods']).to include('OPTIONS')
+    end
+  end
+
+  describe 'GET /api/fleexa-manager/v1/session/current' do
+    it 'returns the current Manager session DTO' do
+      get '/api/fleexa-manager/v1/session/current', headers: headers
+
+      expect(response).to have_http_status(:ok)
+      expect(json_response['user']['id']).to eq("user_#{user.id}")
+      expect(json_response['memberships'].first['accountId']).to eq("acc_#{account.id}")
+      expect(json_response['permissions']).to include('session:read', 'conversations:read', 'messages:send')
+      expect(json_response).not_to include('tokens')
+    end
+
+    it 'denies unauthenticated requests' do
+      get '/api/fleexa-manager/v1/session/current'
+
+      expect(response).to have_http_status(:unauthorized)
+      expect(json_response['error']['code']).to eq('unauthenticated')
+    end
+
