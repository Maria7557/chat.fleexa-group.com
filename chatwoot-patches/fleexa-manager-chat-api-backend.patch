diff --git a/app/controllers/api/fleexa_manager/v1/accounts/conversations/messages_controller.rb b/app/controllers/api/fleexa_manager/v1/accounts/conversations/messages_controller.rb
new file mode 100644
index 0000000..d353b9a
--- /dev/null
+++ b/app/controllers/api/fleexa_manager/v1/accounts/conversations/messages_controller.rb
@@ -0,0 +1,136 @@
+class Api::FleexaManager::V1::Accounts::Conversations::MessagesController < Api::FleexaManager::V1::BaseController
+  UUID_PATTERN = /\A[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}\z/i
+
+  before_action :set_current_account_from_params
+  before_action :set_conversation
+
+  def index
+    limit = request_limit
+    return if performed?
+
+    order = message_order
+    return if performed?
+
+    scope = apply_message_cursor(@conversation.messages.includes(:attachments, :sender), order)
+    return if performed?
+
+    messages = scope.reorder(id: order).limit(limit + 1).to_a
+    visible_messages = messages.first(limit)
+    has_more = messages.length > limit
+    next_cursor = visible_messages.any? ? message_cursor_for(visible_messages.last) : nil
+
+    render json: {
+      data: visible_messages.map { |message| FleexaManager::V1::DtoSerializer.message(message) },
+      page: cursor_page(
+        items: visible_messages,
+        has_more: has_more,
+        limit: limit,
+        next_cursor: next_cursor
+      )
+    }
+  end
+
+  def create_text
+    payload = text_message_payload
+    return if performed?
+
+    result = FleexaManager::V1::MessageIdempotencyService.new(
+      account: Current.account,
+      conversation: @conversation,
+      user: current_manager_user,
+      text: payload[:text],
+      client_message_id: payload[:client_message_id],
+      idempotency_key: payload[:idempotency_key],
+      quoted_message_id: payload[:quoted_message_id],
+      quoted_message_database_id: payload[:quoted_message_database_id]
+    ).call
+
+    render json: {
+      data: FleexaManager::V1::DtoSerializer.message(result.message),
+      idempotency: {
+        key: result.key,
+        duplicate: result.duplicate,
+        originalMessageId: result.duplicate ? FleexaManager::V1::DtoSerializer.message_id(result.message) : nil
+      }
+    }, status: :created
+  rescue FleexaManager::V1::MessageIdempotencyService::PayloadConflict
+    render_manager_error('conflict', 'Idempotency key was already used with a different payload.', status: :conflict)
+  rescue ActiveRecord::RecordInvalid => e
+    render_manager_error('validation_failed', e.record.errors.full_messages.join(', '), status: :unprocessable_entity)
+  rescue StandardError => e
+    Rails.logger.warn("Fleexa Manager message send failed request_id=#{request.request_id} error_class=#{e.class.name}")
+    render_manager_error('validation_failed', 'Message could not be sent.', status: :unprocessable_entity)
+  end
+
+  private
+
+  def set_conversation
+    @conversation = find_visible_conversation!(params[:conversation_id])
+  end
+
+  def message_order
+    order = params[:order].presence || 'desc'
+    return order.to_sym if %w[asc desc].include?(order)
+
+    render_manager_error('bad_request', 'Invalid message order.', status: :bad_request)
+    nil
+  end
+
+  def apply_message_cursor(scope, order)
+    cursor = decoded_cursor
+    return scope if cursor.blank? && !performed?
+    return scope.none if performed?
+
+    id = cursor['id'].to_i
+    unless id.positive?
+      render_manager_error('bad_request', 'Invalid cursor.', status: :bad_request)
+      return scope.none
+    end
+
+    order == :asc ? scope.where('messages.id > ?', id) : scope.where('messages.id < ?', id)
+  end
+
+  def message_cursor_for(message)
+    encode_cursor({ id: message.id })
+  end
+
+  def text_message_payload
+    text = params[:text]
+    client_message_id = params[:clientMessageId].presence
+    idempotency_key = request.headers['Idempotency-Key'].presence || client_message_id
+    quoted_message_id = params[:quotedMessageId].presence
+
+    return payload_error('text must be a non-empty string.') unless text.is_a?(String) && text.strip.present?
+    return payload_error('text is too long.') if text.length > 4000
+    return payload_error('clientMessageId or Idempotency-Key is required.') if idempotency_key.blank?
+    return payload_error('clientMessageId must be a UUID.') if client_message_id.present? && !client_message_id.match?(UUID_PATTERN)
+    return payload_error('Idempotency-Key must be between 16 and 120 characters.') unless idempotency_key.length.between?(16, 120)
+
+    quoted_message_database_id = quoted_message_database_id_for(quoted_message_id)
+    return if performed?
+
+    {
+      text: text,
+      client_message_id: client_message_id,
+      idempotency_key: idempotency_key,
+      quoted_message_id: quoted_message_id,
+      quoted_message_database_id: quoted_message_database_id
+    }
+  end
+
+  def quoted_message_database_id_for(quoted_message_id)
+    return if quoted_message_id.blank?
+
+    message_id = stable_id_value(quoted_message_id, 'msg')
+    return payload_error('quotedMessageId is invalid.') if message_id.blank?
+
+    return message_id if @conversation.messages.where(id: message_id, account_id: Current.account.id).exists?
+
+    payload_error('quotedMessageId is not accessible.')
+  end
+
+  def payload_error(message)
+    render_manager_error('validation_failed', message, status: :unprocessable_entity)
+    nil
+  end
+end
diff --git a/app/controllers/api/fleexa_manager/v1/accounts/conversations_controller.rb b/app/controllers/api/fleexa_manager/v1/accounts/conversations_controller.rb
new file mode 100644
index 0000000..bb2b0a0
--- /dev/null
+++ b/app/controllers/api/fleexa_manager/v1/accounts/conversations_controller.rb
@@ -0,0 +1,148 @@
+class Api::FleexaManager::V1::Accounts::ConversationsController < Api::FleexaManager::V1::BaseController
+  before_action :set_current_account_from_params
+
+  def index
+    limit = request_limit
+    return if performed?
+
+    scope = apply_conversation_filters(account_conversations_scope.includes(:inbox, :contact, :assignee))
+    return if performed?
+
+    conversations = scope.reorder(last_activity_at: :desc, id: :desc).limit(limit + 1).to_a
+    visible_conversations = conversations.first(limit)
+    has_more = conversations.length > limit
+    next_cursor = visible_conversations.any? ? conversation_cursor_for(visible_conversations.last) : nil
+
+    render json: {
+      data: visible_conversations.map do |conversation|
+        FleexaManager::V1::DtoSerializer.conversation_summary(
+          conversation,
+          permissions: conversation_permissions
+        )
+      end,
+      page: cursor_page(
+        items: visible_conversations,
+        has_more: has_more,
+        limit: limit,
+        next_cursor: next_cursor
+      )
+    }
+  end
+
+  def show
+    conversation = find_visible_conversation!(params[:id])
+    return if performed?
+
+    render json: {
+      data: FleexaManager::V1::DtoSerializer.conversation_detail(
+        conversation,
+        permissions: conversation_permissions
+      )
+    }
+  end
+
+  private
+
+  def apply_conversation_filters(scope)
+    scope = apply_status_filter(scope)
+    return scope if performed?
+
+    scope = apply_assignment_filter(scope)
+    scope = apply_channel_filter(scope)
+    return scope if performed?
+
+    scope = apply_updated_after_filter(scope)
+    scope = apply_conversation_cursor(scope)
+    scope
+  end
+
+  def apply_status_filter(scope)
+    return scope if params[:status].blank?
+
+    status = params[:status].to_s
+    return scope.where(status: status) if Conversation.statuses.key?(status)
+
+    render_manager_error('bad_request', 'Invalid conversation status.', status: :bad_request)
+    scope.none
+  end
+
+  def apply_assignment_filter(scope)
+    case params[:assignment].presence || 'all'
+    when 'mine'
+      scope.where(assignee_id: current_manager_user.id)
+    when 'unassigned'
+      scope.where(assignee_id: nil)
+    when 'all'
+      scope
+    else
+      render_manager_error('bad_request', 'Invalid assignment filter.', status: :bad_request)
+      scope.none
+    end
+  end
+
+  def apply_channel_filter(scope)
+    return scope if params[:channel].blank?
+
+    channel_types = channel_types_for(params[:channel].to_s)
+    return scope.joins(:inbox).where(inboxes: { channel_type: channel_types }) if channel_types.present?
+
+    render_manager_error('bad_request', 'Invalid channel filter.', status: :bad_request)
+    scope.none
+  end
+
+  def apply_updated_after_filter(scope)
+    return scope if params[:updatedAfter].blank?
+
+    updated_after = Time.zone.parse(params[:updatedAfter].to_s)
+    return scope.where('conversations.last_activity_at >= ?', updated_after) if updated_after.present?
+
+    render_manager_error('bad_request', 'Invalid updatedAfter.', status: :bad_request)
+    scope.none
+  rescue ArgumentError
+    render_manager_error('bad_request', 'Invalid updatedAfter.', status: :bad_request)
+    scope.none
+  end
+
+  def apply_conversation_cursor(scope)
+    cursor = decoded_cursor
+    return scope if cursor.blank? && !performed?
+    return scope.none if performed?
+
+    last_activity_at = Time.zone.parse(cursor['lastActivityAt'].to_s)
+    id = cursor['id'].to_i
+    unless last_activity_at.present? && id.positive?
+      render_manager_error('bad_request', 'Invalid cursor.', status: :bad_request)
+      return scope.none
+    end
+
+    scope.where(
+      'conversations.last_activity_at < :last_activity_at OR ' \
+      '(conversations.last_activity_at = :last_activity_at AND conversations.id < :id)',
+      last_activity_at: last_activity_at,
+      id: id
+    )
+  rescue ArgumentError
+    render_manager_error('bad_request', 'Invalid cursor.', status: :bad_request)
+    scope.none
+  end
+
+  def conversation_cursor_for(conversation)
+    encode_cursor(
+      {
+        id: conversation.id,
+        lastActivityAt: conversation.last_activity_at.utc.iso8601
+      }
+    )
+  end
+
+  def channel_types_for(channel)
+    {
+      'whatsapp' => ['Channel::Whatsapp', 'Channel::TwilioSms'],
+      'instagram' => ['Channel::Instagram', 'Channel::FacebookPage'],
+      'web_widget' => ['Channel::WebWidget'],
+      'email' => ['Channel::Email'],
+      'phone' => ['Channel::Sms', 'Channel::TwilioSms'],
+      'telegram' => ['Channel::Telegram']
+    }[channel]
+  end
+end
diff --git a/app/controllers/api/fleexa_manager/v1/accounts/manager/counters_controller.rb b/app/controllers/api/fleexa_manager/v1/accounts/manager/counters_controller.rb
