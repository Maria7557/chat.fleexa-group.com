+  describe 'POST /api/fleexa-manager/v1/accounts/:account_id/conversations/:id/messages/text' do
+    let(:message_path) do
+      "/api/fleexa-manager/v1/accounts/acc_#{account.id}/conversations/conv_#{conversation.display_id}/messages/text"
+    end
+    let(:client_message_id) { SecureRandom.uuid }
+    let(:payload) { { text: 'Manager reply', clientMessageId: client_message_id } }
+    let(:idempotent_headers) { headers.merge('Idempotency-Key' => client_message_id) }
+
+    it 'denies invalid payloads' do
+      post message_path, params: { text: '' }, headers: idempotent_headers
+
+      expect(response).to have_http_status(:unprocessable_entity)
+      expect(json_response['error']['code']).to eq('validation_failed')
+    end
+
+    it 'rejects oversized text payloads' do
+      post message_path, params: payload.merge(text: 'x' * 4001), headers: idempotent_headers
+
+      expect(response).to have_http_status(:unprocessable_entity)
+      expect(json_response['error']['code']).to eq('validation_failed')
+    end
+
+    it 'does not send through an inaccessible account id' do
+      wrong_account_path = "/api/fleexa-manager/v1/accounts/acc_#{other_account.id}/conversations/conv_#{conversation.display_id}/messages/text"
+
+      expect do
+        post wrong_account_path, params: payload, headers: idempotent_headers
+      end.not_to change { conversation.messages.count }
+
+      expect(response).to have_http_status(:forbidden)
+      expect(json_response['error']['code']).to eq('forbidden')
+    end
+
+    it 'does not send when the conversation belongs to another account' do
+      other_inbox = create(:inbox, account: other_account)
+      other_contact = create(:contact, account: other_account)
+      other_contact_inbox = create(:contact_inbox, contact: other_contact, inbox: other_inbox)
+      other_conversation = create(
+        :conversation,
+        account: other_account,
+        inbox: other_inbox,
+        contact: other_contact,
+        contact_inbox: other_contact_inbox,
+        display_id: 88
+      )
+      wrong_account_path = "/api/fleexa-manager/v1/accounts/acc_#{account.id}/conversations/conv_#{other_conversation.display_id}/messages/text"
+
+      expect do
+        post wrong_account_path, params: payload, headers: idempotent_headers
+      end.not_to change { other_conversation.messages.count }
+
+      expect(response).to have_http_status(:not_found)
+      expect(json_response['error']['code']).to eq('not_found')
+    end
+
+    it 'creates one Chatwoot message and returns a Manager DTO' do
+      expect do
+        post message_path, params: payload, headers: idempotent_headers
+      end.to change { conversation.messages.count }.by(1)
+
+      expect(response).to have_http_status(:created)
+      expect(json_response['data']).to include(
+        'conversationId' => "conv_#{conversation.display_id}",
+        'clientMessageId' => client_message_id,
+        'direction' => 'outgoing'
+      )
+      expect(json_response['idempotency']).to include('key' => client_message_id, 'duplicate' => false)
+    end
+
+    it 'does not duplicate a repeated request with the same idempotency key' do
+      post message_path, params: payload, headers: idempotent_headers
+      first_message_id = json_response['data']['id']
+
+      expect do
+        post message_path, params: payload, headers: idempotent_headers
+      end.not_to change { conversation.messages.count }
+
+      expect(response).to have_http_status(:created)
+      expect(json_response['data']['id']).to eq(first_message_id)
+      expect(json_response['idempotency']).to include('duplicate' => true, 'originalMessageId' => first_message_id)
+    end
+
+    it 'rejects key reuse with a different payload' do
