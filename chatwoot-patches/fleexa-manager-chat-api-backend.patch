--- /dev/null
+++ b/app/controllers/api/fleexa_manager/v1/accounts/manager/counters_controller.rb
@@ -0,0 +1,27 @@
+class Api::FleexaManager::V1::Accounts::Manager::CountersController < Api::FleexaManager::V1::BaseController
+  before_action :set_current_account_from_params
+
+  def show
+    scope = account_conversations_scope
+
+    render json: {
+      accountId: FleexaManager::V1::DtoSerializer.account_id(Current.account),
+      generatedAt: Time.current.utc.iso8601,
+      counters: {
+        unread: unread_count(scope),
+        assigned: scope.where.not(assignee_id: nil).count,
+        unassigned: scope.where(assignee_id: nil).count
+      }
+    }
+  end
+
+  private
+
+  def unread_count(scope)
+    scope.joins(:messages)
+         .where(messages: { account_id: Current.account.id, message_type: Message.message_types[:incoming] })
+         .where('conversations.agent_last_seen_at IS NULL OR messages.created_at > conversations.agent_last_seen_at')
+         .distinct
+         .count
+  end
+end
diff --git a/app/controllers/api/fleexa_manager/v1/base_controller.rb b/app/controllers/api/fleexa_manager/v1/base_controller.rb
new file mode 100644
index 0000000..bca41a5
--- /dev/null
+++ b/app/controllers/api/fleexa_manager/v1/base_controller.rb
@@ -0,0 +1,206 @@
+require 'base64'
+require 'json'
+
+class Api::FleexaManager::V1::BaseController < Api::BaseController
+  MANAGER_API_VERSION = '2026-07-18.stage2'.freeze
+  READ_PERMISSIONS = %w[session:read conversations:read counters:read].freeze
+  WRITE_PERMISSIONS = %w[messages:send].freeze
+  OWNER_EXTRA_PERMISSIONS = %w[deals:read pipeline:read bookings:read settings:read settings:write].freeze
+  MAX_LIMIT = 100
+  DEFAULT_LIMIT = 30
+  FLEEXA_MANAGER_CORS_ALLOWED_ORIGINS = %w[
+    http://localhost:8082
+    http://127.0.0.1:8082
+  ].freeze
+  FLEEXA_MANAGER_CORS_ALLOWED_HEADERS = 'Authorization, Content-Type, Accept, Idempotency-Key, api_access_token'.freeze
+  FLEEXA_MANAGER_CORS_ALLOWED_METHODS = 'GET, POST, PATCH, DELETE, OPTIONS'.freeze
+
+  prepend_before_action :handle_fleexa_manager_preflight
+  prepend_before_action :normalize_fleexa_bearer_token
+  before_action :ensure_fleexa_manager_user!
+  after_action :set_fleexa_manager_cors_headers
+
+  def preflight
+    set_fleexa_manager_cors_headers
+    head :no_content
+  end
+
+  private
+
+  def handle_fleexa_manager_preflight
+    return unless request.options?
+
+    set_fleexa_manager_cors_headers
+    head :no_content
+  end
+
+  def set_fleexa_manager_cors_headers
+    origin = request.headers['Origin'].to_s
+    return if origin.blank?
+    return unless fleexa_manager_allowed_cors_origin?(origin)
+
+    response.headers['Access-Control-Allow-Origin'] = origin
+    response.headers['Access-Control-Allow-Credentials'] = 'true'
+    response.headers['Access-Control-Allow-Headers'] = FLEEXA_MANAGER_CORS_ALLOWED_HEADERS
+    response.headers['Access-Control-Allow-Methods'] = FLEEXA_MANAGER_CORS_ALLOWED_METHODS
+    response.headers['Access-Control-Max-Age'] = '600'
+
+    existing_vary = response.headers['Vary'].to_s
+    vary_values = existing_vary.split(',').map(&:strip).reject(&:blank?)
+    response.headers['Vary'] = (vary_values + ['Origin']).uniq.join(', ')
+  end
+
+  def fleexa_manager_allowed_cors_origin?(origin)
+    configured_origins = ENV.fetch('FLEEXA_MANAGER_CORS_ORIGINS', '').split(',').map(&:strip).reject(&:blank?)
+    allowed_origins = configured_origins.presence || FLEEXA_MANAGER_CORS_ALLOWED_ORIGINS
+
+    allowed_origins.include?(origin)
+  end
+
+  def normalize_fleexa_bearer_token
+    return if request.headers[:api_access_token].present? || request.headers[:HTTP_API_ACCESS_TOKEN].present?
+
+    authorization = request.headers['Authorization'].to_s
+    token = authorization.match(/\ABearer\s+(.+)\z/i)&.[](1)&.strip
+    return if token.blank?
+
+    request.headers['api_access_token'] = token
+    request.headers['HTTP_API_ACCESS_TOKEN'] = token
+  end
+
+  def authenticate_user!(*)
+    return if current_user.present?
+
+    render_manager_error('unauthenticated', 'Authentication required.', status: :unauthorized)
+  end
+
+  def render_unauthorized(message)
+    render_manager_error('unauthenticated', message, status: :unauthorized)
+  end
+
+  def render_not_found_error(message)
+    render_manager_error('not_found', message, status: :not_found)
+  end
+
+  def render_could_not_create_error(message)
+    render_manager_error('validation_failed', message, status: :unprocessable_entity)
+  end
+
+  def ensure_fleexa_manager_user!
+    return if performed?
+
+    unless current_manager_user.is_a?(User)
+      return render_manager_error('unauthenticated', 'A manager user is required.', status: :unauthorized)
+    end
+
+    return unless current_manager_user.respond_to?(:active_for_authentication?)
+    return if current_manager_user.active_for_authentication?
+
+    render_manager_error('unauthenticated', 'The manager user is inactive.', status: :unauthorized)
+  end
+
+  def current_manager_user
+    Current.user || current_user
+  end
+
+  def set_current_account_from_params
+    return if performed?
+
+    account_id = stable_id_value(params[:account_id], 'acc')
+    return render_manager_error('bad_request', 'Invalid accountId.', status: :bad_request) if account_id.blank?
+
+    account = Account.find_by(id: account_id)
+    return render_manager_error('not_found', 'Account was not found.', status: :not_found) if account.blank?
+    return render_manager_error('forbidden', 'Account is suspended.', status: :forbidden) unless account.active?
+
+    account_user = account.account_users.find_by(user_id: current_manager_user.id)
+    return render_manager_error('forbidden', 'Account is not accessible.', status: :forbidden) if account_user.blank?
+
+    @current_account = account
+    @current_account_user = account_user
+    Current.account = account
+    Current.account_user = account_user
+  end
+
+  def account_conversations_scope
+    Conversations::PermissionFilterService.new(
+      Current.account.conversations,
+      current_manager_user,
+      Current.account
+    ).perform
+  end
+
+  def find_visible_conversation!(conversation_id_param)
+    display_id = stable_id_value(conversation_id_param, 'conv')
+    return render_manager_error('bad_request', 'Invalid conversationId.', status: :bad_request) if display_id.blank?
+
+    conversation = account_conversations_scope
+                   .includes(:inbox, :contact, :assignee, :messages)
+                   .find_by(display_id: display_id)
+    return render_manager_error('not_found', 'Conversation was not found.', status: :not_found) if conversation.blank?
+
+    conversation
+  end
+
+  def stable_id_value(value, prefix)
+    value = value.to_s
+    match = value.match(/\A#{Regexp.escape(prefix)}_(\d+)\z/)
+    match&.[](1)&.to_i
+  end
+
+  def manager_role(account_user)
+    account_user.administrator? ? 'owner' : 'operator'
+  end
+
+  def manager_permissions(account_user)
+    permissions = READ_PERMISSIONS + WRITE_PERMISSIONS
+    permissions += OWNER_EXTRA_PERMISSIONS if account_user.administrator?
+    permissions.uniq
+  end
+
+  def conversation_permissions
+    %w[conversations:read messages:send]
+  end
+
+  def request_limit
+    raw_limit = params[:limit].presence || DEFAULT_LIMIT
+    limit = Integer(raw_limit)
+    [[limit, 1].max, MAX_LIMIT].min
+  rescue ArgumentError, TypeError
+    render_manager_error('bad_request', 'Invalid limit.', status: :bad_request)
+    nil
+  end
+
+  def decoded_cursor
+    return if params[:cursor].blank?
+
+    JSON.parse(Base64.urlsafe_decode64(params[:cursor].to_s))
+  rescue ArgumentError, JSON::ParserError
+    render_manager_error('bad_request', 'Invalid cursor.', status: :bad_request)
+    nil
+  end
+
+  def encode_cursor(payload)
+    Base64.urlsafe_encode64(payload.to_json)
+  end
+
+  def cursor_page(items:, has_more:, limit:, next_cursor:)
+    {
+      limit: limit,
+      nextCursor: has_more ? next_cursor : nil,
+      previousCursor: nil,
+      hasMore: has_more
+    }
+  end
+
+  def render_manager_error(code, message, status:, details: nil)
+    error = {
+      code: code,
+      message: message
+    }
+    error[:requestId] = request.request_id if request.respond_to?(:request_id)
+    error[:details] = details if details.present?
+
+    render json: { error: error }, status: status
+  end
+end
diff --git a/config/initializers/fleexa_manager_cors.rb b/config/initializers/fleexa_manager_cors.rb
new file mode 100644
index 0000000..5c10e61
--- /dev/null
+++ b/config/initializers/fleexa_manager_cors.rb
@@ -0,0 +1,85 @@
+module FleexaManager
+  module V1
+    class CorsMiddleware
+      DEFAULT_ALLOWED_ORIGINS = %w[
+        http://localhost:8082
+        http://127.0.0.1:8082
+      ].freeze
+      ALLOWED_HEADERS = [
+        'Authorization',
+        'Content-Type',
+        'Accept',
+        'Idempotency-Key',
+        'api_access_token'
+      ].join(', ').freeze
+      ALLOWED_METHODS = 'GET, POST, PATCH, DELETE, OPTIONS'.freeze
+
+      def initialize(app)
+        @app = app
+      end
+
+      def call(env)
+        return @app.call(env) unless manager_api_path?(env['PATH_INFO'])
+
+        if env['REQUEST_METHOD'] == 'OPTIONS'
+          headers = apply_cors_headers({}, origin_for(env), env)
+          return [204, headers, []]
+        end
+
+        status, headers, response = @app.call(env)
+        apply_cors_headers(headers, origin_for(env), env)
+
+        [status, headers, response]
+      end
+
+      private
+
+      def manager_api_path?(path)
+        path.to_s.start_with?('/api/fleexa-manager/v1/')
+      end
+
+      def origin_for(env)
+        env['HTTP_ORIGIN'].to_s
+      end
+
+      def apply_cors_headers(headers, origin, env)
+        return headers if origin.empty?
+        return headers unless allowed_origin?(origin)
+
+        headers['Access-Control-Allow-Origin'] = origin
+        headers['Access-Control-Allow-Credentials'] = 'true'
+        headers['Access-Control-Allow-Headers'] = ALLOWED_HEADERS
+        headers['Access-Control-Allow-Methods'] = ALLOWED_METHODS
+        headers['Access-Control-Max-Age'] = '600'
+        headers['Access-Control-Allow-Private-Network'] = 'true' if private_network_preflight?(env)
+        append_vary_origin(headers)
+        headers
+      end
+
+      def private_network_preflight?(env)
+        env['HTTP_ACCESS_CONTROL_REQUEST_PRIVATE_NETWORK'] == 'true'
+      end
+
+      def append_vary_origin(headers)
+        vary_values = headers['Vary'].to_s.split(',').map(&:strip).reject(&:empty?)
+        headers['Vary'] = (vary_values + ['Origin']).uniq.join(', ')
+      end
+
+      def allowed_origin?(origin)
+        configured_origins = ENV.fetch('FLEEXA_MANAGER_CORS_ORIGINS', '')
+                                .split(',')
+                                .map(&:strip)
+                                .reject(&:empty?)
+        allowed_origins = if configured_origins.empty?
+                            DEFAULT_ALLOWED_ORIGINS
+                          else
+                            configured_origins
+                          end
+
+        allowed_origins.include?(origin)
+      end
+    end
+  end
+end
+
+Rails.application.config.middleware.insert_before Rack::Cors, FleexaManager::V1::CorsMiddleware
diff --git a/app/controllers/api/fleexa_manager/v1/session_controller.rb b/app/controllers/api/fleexa_manager/v1/session_controller.rb
new file mode 100644
