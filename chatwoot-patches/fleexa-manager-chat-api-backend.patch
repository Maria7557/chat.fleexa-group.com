--- /dev/null
+++ b/app/controllers/api/fleexa_manager/v1/session_controller.rb
@@ -0,0 +1,31 @@
+class Api::FleexaManager::V1::SessionController < Api::FleexaManager::V1::BaseController
+  def current
+    memberships = current_manager_user.account_users.includes(:account).select { |membership| membership.account&.active? }
+    active_membership = active_membership_for(memberships)
+    return if performed?
+
+    render json: FleexaManager::V1::DtoSerializer.current_session(
+      user: current_manager_user,
+      memberships: memberships,
+      active_membership: active_membership,
+      permissions_for: method(:manager_permissions),
+      role_for: method(:manager_role),
+      api_version: MANAGER_API_VERSION
+    )
+  end
+
+  private
+
+  def active_membership_for(memberships)
+    return memberships.first if params[:activeAccountId].blank?
+
+    account_id = stable_id_value(params[:activeAccountId], 'acc')
+    return render_manager_error('bad_request', 'Invalid activeAccountId.', status: :bad_request) if account_id.blank?
+
+    membership = memberships.find { |candidate| candidate.account_id == account_id }
+    return membership if membership.present?
+
+    render_manager_error('forbidden', 'Active account is not accessible.', status: :forbidden)
+    nil
+  end
+end
diff --git a/app/services/fleexa_manager/v1/dto_serializer.rb b/app/services/fleexa_manager/v1/dto_serializer.rb
new file mode 100644
index 0000000..0b6da2c
--- /dev/null
+++ b/app/services/fleexa_manager/v1/dto_serializer.rb
@@ -0,0 +1,373 @@
+module FleexaManager
+  module V1
+    class DtoSerializer
+      class << self
+        def current_session(user:, memberships:, active_membership:, permissions_for:, role_for:, api_version:)
+          {
+            user: manager_user(user),
+            activeAccountId: active_membership.present? ? account_id(active_membership.account) : nil,
+            memberships: memberships.map do |membership|
+              {
+                accountId: account_id(membership.account),
+                accountName: membership.account.name,
+                role: role_for.call(membership),
+                permissions: permissions_for.call(membership),
+                features: []
+              }
+            end,
+            permissions: active_membership.present? ? permissions_for.call(active_membership) : [],
+            realtime: realtime_bootstrap(user),
+            serverTime: Time.current.utc.iso8601,
+            apiVersion: api_version
+          }
+        end
+
+        def manager_user(user)
+          {
+            id: user_id(user),
+            name: user.name.to_s,
+            email: user.email.to_s,
+            avatarUrl: user.avatar_url.presence,
+            locale: user.ui_settings&.dig('locale').presence || I18n.locale.to_s,
+            timeZone: user.ui_settings&.dig('timezone').presence || Time.zone.name
+          }
+        end
+
+        def conversation_summary(conversation, permissions:)
+          last_message = conversation.messages.chat.includes(:attachments, :sender).reorder(created_at: :desc, id: :desc).first
+
+          {
+            id: conversation_id(conversation),
+            accountId: account_id(conversation.account),
+            title: conversation_title(conversation),
+            status: conversation.status,
+            priority: conversation_priority(conversation),
+            channel: channel_summary(conversation.inbox),
+            contact: contact_summary(conversation.contact),
+            assignee: actor(conversation.assignee),
+            lastMessage: message_preview(last_message),
+            linkedDeal: linked_deal_summary(conversation),
+            unreadCount: conversation.unread_incoming_messages.count,
+            canReply: conversation.can_reply?,
+            replyWindow: reply_window(conversation),
+            lastActivityAt: iso8601(conversation.last_activity_at),
+            permissions: permissions
+          }
+        end
+
+        def conversation_detail(conversation, permissions:)
+          conversation_summary(conversation, permissions: permissions).merge(
+            participants: participants(conversation),
+            tags: conversation.cached_label_list_array,
+            createdAt: iso8601(conversation.created_at),
+            updatedAt: iso8601(conversation.updated_at)
+          )
+        end
+
+        def message(message)
+          {
+            id: message_id(message),
+            conversationId: conversation_id(message.conversation),
+            clientMessageId: message.content_attributes&.dig('clientMessageId'),
+            direction: message.incoming? ? 'incoming' : 'outgoing',
+            visibility: message_visibility(message),
+            type: message_kind(message),
+            text: message.content,
+            sender: actor(message.sender),
+            deliveryStatus: delivery_status(message),
+            failureReason: message.content_attributes&.dig('external_error'),
+            attachments: message.attachments.map { |attachment| attachment_summary(attachment) }.compact,
+            createdAt: iso8601(message.created_at),
+            updatedAt: iso8601(message.updated_at)
+          }
+        end
+
+        def message_id(message)
+          "msg_#{message.id}"
+        end
+
+        def conversation_id(conversation)
+          "conv_#{conversation.display_id}"
+        end
+
+        def account_id(account)
+          "acc_#{account.id}"
+        end
+
+        private
+
+        def user_id(user)
+          "user_#{user.id}"
+        end
+
+        def contact_id(contact)
+          "contact_#{contact.id}"
+        end
+
+        def deal_id(deal)
+          "deal_#{deal.id}"
+        end
+
+        def stage_id(stage)
+          "stage_#{stage.id}"
+        end
+
+        def realtime_bootstrap(user)
+          frontend_url = ENV.fetch('FRONTEND_URL', 'http://localhost:3000').to_s.chomp('/')
+
+          {
+            url: "#{frontend_url}/cable",
+            token: user.pubsub_token.to_s,
+            tokenExpiresAt: 1.hour.from_now.utc.iso8601,
+            lastEventCursor: nil
+          }
+        end
+
+        def conversation_title(conversation)
+          conversation.contact&.name.presence ||
+            conversation.contact&.phone_number.presence ||
+            conversation.contact&.email.presence ||
+            "Conversation ##{conversation.display_id}"
+        end
+
+        def conversation_priority(conversation)
+          return 'normal' if conversation.priority.blank? || conversation.priority == 'medium'
+
+          conversation.priority
+        end
+
+        def channel_summary(inbox)
+          {
+            type: channel_type(inbox),
+            displayName: inbox.name.to_s
+          }
+        end
+
+        def channel_type(inbox)
+          return 'whatsapp' if inbox.whatsapp? || inbox.twilio_whatsapp?
+          return 'instagram' if inbox.instagram? || inbox.instagram_direct?
+          return 'web_widget' if inbox.web_widget?
+          return 'email' if inbox.email?
+          return 'phone' if inbox.sms? || inbox.twilio?
+          return 'telegram' if inbox.telegram?
+
+          'other'
+        end
+
+        def contact_summary(contact)
+          {
+            id: contact_id(contact),
+            displayName: contact.name.presence || contact.phone_number.presence || contact.email.presence || "Contact ##{contact.id}",
+            phone: contact.phone_number.presence,
+            email: contact.email.presence
+          }
+        end
+
+        def actor(record)
+          return if record.blank?
+
+          {
+            id: actor_id(record),
+            displayName: actor_name(record),
+            type: actor_type(record),
+            avatarUrl: actor_avatar_url(record)
+          }
+        end
+
+        def actor_id(record)
+          return user_id(record) if record.is_a?(User)
+          return contact_id(record) if record.is_a?(Contact)
+          return "bot_#{record.id}" if record.is_a?(AgentBot)
+
+          "system_#{record.id}"
+        end
+
+        def actor_name(record)
+          record.try(:name).presence || record.try(:display_name).presence || record.class.name
+        end
+
+        def actor_type(record)
+          return 'user' if record.is_a?(User)
+          return 'contact' if record.is_a?(Contact)
+          return 'bot' if record.is_a?(AgentBot)
+
+          'system'
+        end
+
+        def actor_avatar_url(record)
+          return unless record.respond_to?(:avatar_url)
+
+          record.avatar_url.presence
+        end
+
+        def message_preview(message)
+          return if message.blank?
+
+          {
+            id: message_id(message),
+            text: message.content.to_s,
+            direction: message.incoming? ? 'incoming' : 'outgoing',
+            createdAt: iso8601(message.created_at)
+          }
+        end
+
+        def linked_deal_summary(conversation)
+          return unless defined?(CrmDeal)
+
+          deal = CrmDeal.for_account(conversation.account_id)
+                        .includes(:stage, :contact, :assignee)
+                        .where(conversation_id: conversation.id)
+                        .order(updated_at: :desc)
+                        .first
+          return if deal.blank?
+
+          {
+            id: deal_id(deal),
+            accountId: account_id(conversation.account),
+            title: deal.title.to_s,
+            stage: stage_summary(deal.stage),
+            amount: money(deal.amount),
+            bookingRef: booking_ref(deal),
+            contact: deal.contact.present? ? contact_summary(deal.contact) : nil,
+            assignee: actor(deal.assignee),
+            sourceAttribution: source_attribution(deal),
+            qualification: lead_qualification(deal),
+            lastActivityAt: iso8601(deal.updated_at),
+            createdAt: iso8601(deal.created_at),
+            updatedAt: iso8601(deal.updated_at),
+            permissions: %w[deals:read]
+          }
+        end
+
+        def stage_summary(stage)
+          return { id: 'stage_unknown', key: 'unknown', name: 'Unknown' } if stage.blank?
+
+          {
+            id: stage_id(stage),
+            key: stage.slug.to_s,
+            name: stage.name.to_s
+          }
+        end
+
+        def money(value)
+          return if value.blank?
+
+          {
+            amount: format('%.2f', value.to_d),
+            currency: 'AED'
+          }
+        end
+
+        def booking_ref(deal)
+          return if deal.booking_id.blank?
+
+          {
+            bookingId: "booking_#{deal.booking_id}",
+            status: 'pending',
+            externalBookingId: deal.booking_id.to_s
+          }
+        end
+
+        def source_attribution(deal)
+          attrs = deal.custom_attributes || {}
+          return if attrs.blank?
+
+          {
+            trafficSourceKey: attrs['traffic_source_key'].presence,
+            trafficSourceLabel: attrs['traffic_source_label'].presence,
+            leadOriginKey: attrs['lead_origin_key'].presence,
+            leadOriginLabel: attrs['lead_origin_label'].presence,
+            sourceDetectionMethod: safe_source_detection_method(attrs['source_detection_method']),
+            sourceConfidence: safe_source_confidence(attrs['source_confidence']),
+            needsSourceClarification: ActiveModel::Type::Boolean.new.cast(attrs['needs_source_clarification'])
+          }
+        end
+
+        def safe_source_detection_method(value)
+          %w[click_id utm first_message_rule manual unknown].include?(value) ? value : 'unknown'
+        end
+
+        def safe_source_confidence(value)
+          %w[auto manual unknown].include?(value) ? value : 'unknown'
+        end
+
+        def lead_qualification(deal)
+          attrs = deal.custom_attributes || {}
+          status = attrs['qualification_status'].presence || attrs['lead_qualification_status'].presence
+          return if status.blank?
+
+          {
+            status: %w[pending unqualified qualified].include?(status) ? status : 'pending',
+            reason: attrs['qualification_reason'].presence,
+            lostReasonKey: attrs['lost_reason_key'].presence,
+            lostReasonLabel: attrs['lost_reason_label'].presence
+          }
+        end
+
+        def reply_window(conversation)
+          can_reply = conversation.can_reply?
+
+          {
+            canReply: can_reply,
+            reason: can_reply ? 'open' : 'expired',
+            closesAt: nil
+          }
+        end
+
+        def participants(conversation)
+          actors = [conversation.assignee]
+          actors += conversation.conversation_participants.includes(:user).map(&:user) if conversation.respond_to?(:conversation_participants)
+          actors.compact.uniq.map { |participant| actor(participant) }
+        end
+
+        def message_visibility(message)
+          return 'system' if message.activity?
+          return 'private_note' if message.private?
+
+          'customer'
+        end
+
+        def message_kind(message)
+          return 'system' if message.activity?
+          return 'template' if message.template?
+          return 'attachment' if message.attachments.any?
+
+          'text'
+        end
+
+        def delivery_status(message)
+          return 'sent' if message.status.blank?
+
+          message.status
+        end
+
+        def attachment_summary(attachment)
+          {
+            id: "att_#{attachment.id}",
+            kind: attachment_kind(attachment),
+            fileName: attachment.file.attached? ? attachment.file.filename.to_s : attachment.fallback_title.presence,
+            url: attachment_url(attachment),
+            contentType: attachment.file.attached? ? attachment.file.content_type : nil
+          }
+        end
+
+        def attachment_kind(attachment)
+          return 'document' if attachment.file?
+          return attachment.file_type if %w[image video audio].include?(attachment.file_type)
+
+          'other'
+        end
+
+        def attachment_url(attachment)
+          attachment.download_url.presence || attachment.external_url.presence || attachment.file_url.presence || ''
+        rescue StandardError
+          ''
+        end
+
+        def iso8601(value)
+          value&.utc&.iso8601
+        end
+      end
+    end
+  end
+end
diff --git a/app/services/fleexa_manager/v1/message_idempotency_service.rb b/app/services/fleexa_manager/v1/message_idempotency_service.rb
new file mode 100644
index 0000000..921e9b7
--- /dev/null
+++ b/app/services/fleexa_manager/v1/message_idempotency_service.rb
@@ -0,0 +1,162 @@
+require 'digest'
+require 'json'
+require 'zlib'
+
+module FleexaManager
+  module V1
+    class MessageIdempotencyService
+      Result = Struct.new(:message, :duplicate, :key, keyword_init: true)
+      class PayloadConflict < StandardError; end
+
+      LOCK_NAMESPACE = 'fleexa_manager_message_send'.freeze
+
+      def initialize(account:, conversation:, user:, text:, client_message_id:, idempotency_key:, quoted_message_id:, quoted_message_database_id:)
+        @account = account
+        @conversation = conversation
+        @user = user
+        @text = text
+        @client_message_id = client_message_id
+        @idempotency_key = idempotency_key
+        @quoted_message_id = quoted_message_id
+        @quoted_message_database_id = quoted_message_database_id
+      end
+
+      def call
+        result = nil
+
+        ActiveRecord::Base.transaction do
+          advisory_lock!
+          existing_message = find_existing_message
+
+          if existing_message.present?
+            raise PayloadConflict unless same_payload?(existing_message)
+
+            result = Result.new(message: existing_message, duplicate: true, key: idempotency_key)
+            next
+          end
+
+          result = Result.new(message: create_message!, duplicate: false, key: idempotency_key)
+        end
+
+        result
+      end
+
+      private
+
+      attr_reader :account, :conversation, :user, :text, :client_message_id, :idempotency_key,
+                  :quoted_message_id, :quoted_message_database_id
+
+      def advisory_lock!
+        first_key = signed_crc32(LOCK_NAMESPACE)
+        second_key = signed_crc32("#{account.id}:#{conversation.id}:#{idempotency_key}")
+
+        ActiveRecord::Base.connection.execute("SELECT pg_advisory_xact_lock(#{first_key}, #{second_key})")
+      end
+
+      def signed_crc32(value)
+        crc = Zlib.crc32(value.to_s)
+        crc > 2_147_483_647 ? crc - 4_294_967_296 : crc
+      end
+
+      def find_existing_message
+        conditions = [
+          "additional_attributes -> 'fleexa_manager' ->> 'idempotencyKey' = :idempotency_key",
+          'content_attributes::text LIKE :idempotency_like'
+        ]
+        binds = {
+          idempotency_key: idempotency_key,
+          idempotency_like: "%#{ActiveRecord::Base.sanitize_sql_like(idempotency_key)}%"
+        }
+
+        if client_message_id.present?
+          conditions << "additional_attributes -> 'fleexa_manager' ->> 'clientMessageId' = :client_message_id"
+          conditions << 'content_attributes::text LIKE :client_message_like'
+          binds[:client_message_id] = client_message_id
+          binds[:client_message_like] = "%#{ActiveRecord::Base.sanitize_sql_like(client_message_id)}%"
+        end
+
+        conversation.messages
+                    .where(account_id: account.id)
+                    .where(conditions.join(' OR '), binds)
+                    .reorder(id: :asc)
+                    .detect { |message| idempotency_match?(message) }
+      end
+
+      def same_payload?(message)
+        existing_hash = idempotency_attributes(message)['requestHash'] ||
+                        content_attributes_for(message)['fleexaManagerRequestHash']
+        existing_hash.blank? || existing_hash == request_hash
+      end
+
+      def create_message!
+        message = Messages::MessageBuilder.new(user, conversation, builder_params).perform
+        persist_idempotency_attributes!(message)
+        message
+      end
+
+      def builder_params
+        ActionController::Parameters.new(
+          content: text,
+          private: false,
+          message_type: 'outgoing',
+          content_type: 'text',
+          content_attributes: content_attributes
+        )
+      end
+
+      def content_attributes
+        attrs = {
+          clientMessageId: client_message_id,
+          fleexaManagerIdempotencyKey: idempotency_key,
+          fleexaManagerRequestHash: request_hash
+        }
+        attrs[:quotedMessageId] = quoted_message_id if quoted_message_id.present?
+        attrs[:in_reply_to] = quoted_message_database_id if quoted_message_database_id.present?
+        attrs
+      end
+
+      def persist_idempotency_attributes!(message)
+        attrs = (message.additional_attributes || {}).deep_dup
+        attrs['fleexa_manager'] = {
+          'idempotencyKey' => idempotency_key,
+          'clientMessageId' => client_message_id,
+          'requestHash' => request_hash
+        }
+        attrs['fleexa_manager']['quotedMessageId'] = quoted_message_id if quoted_message_id.present?
+
+        message.update_column(:additional_attributes, attrs)
+      end
+
+      def idempotency_match?(message)
+        attrs = idempotency_attributes(message)
+        content_attrs = content_attributes_for(message)
+
+        return true if attrs['idempotencyKey'] == idempotency_key
+        return true if content_attrs['fleexaManagerIdempotencyKey'] == idempotency_key
+
+        client_message_id.present? &&
+          (attrs['clientMessageId'] == client_message_id || content_attrs['clientMessageId'] == client_message_id)
+      end
+
+      def idempotency_attributes(message)
+        (message.additional_attributes || {}).fetch('fleexa_manager', {})
+      end
+
+      def content_attributes_for(message)
+        message.content_attributes || {}
+      end
+
+      def request_hash
+        @request_hash ||= Digest::SHA256.hexdigest(
+          JSON.generate(
+            {
+              text: text,
+              clientMessageId: client_message_id,
+              quotedMessageId: quoted_message_id
+            }
+          )
+        )
+      end
+    end
+  end
+end
