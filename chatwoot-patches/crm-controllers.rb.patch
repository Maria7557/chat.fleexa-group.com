+++ b/app/controllers/api/v1/accounts/crm/pipeline_stages_controller.rb
@@ -0,0 +1,119 @@
+class Api::V1::Accounts::Crm::PipelineStagesController < Api::V1::Accounts::BaseController
+  before_action :check_authorization
+  before_action :set_pipeline_stage, only: [:update, :destroy, :reorder]
+
+  def index
+    render json: stage_scope.ordered
+  end
+
+  def create
+    position = stage_params[:position].to_i
+    return render_position_error unless valid_custom_position?(position)
+
+    @pipeline_stage = CrmPipelineStage.new(stage_params.merge(account: Current.account))
+    @pipeline_stage.save!
+
+    render json: @pipeline_stage
+  end
+
+  def update
+    return render_immutable_field_error if immutable_stage_params_present?
+    return render_system_stage_error if @pipeline_stage.is_system? && pipeline_stage_payload.key?(:name)
+
+    @pipeline_stage.update!(stage_update_params)
+
+    render json: @pipeline_stage
+  end
+
+  def destroy
+    return render_system_stage_error if @pipeline_stage.is_system?
+
+    fallback_stage = stage_scope.find(params.require(:fallback_stage_id))
+    return render_validation_error('fallback_stage_id must point to a different stage') if fallback_stage.id == @pipeline_stage.id
+
+    ActiveRecord::Base.transaction do
+      CrmDeal.for_account(Current.account.id).where(stage_id: @pipeline_stage.id).update_all(
+        stage_id: fallback_stage.id,
+        updated_at: Time.current
+      )
+      @pipeline_stage.destroy!
+    end
+
+    head :ok
+  end
+
+  def reorder
+    return render_system_stage_error if @pipeline_stage.is_system?
+
+    position = params[:position].to_i
+    return render_position_error unless valid_custom_position?(position)
+
+    @pipeline_stage.update!(position: position)
+
+    render json: @pipeline_stage
+  end
+
+  private
+
+  def stage_scope
+    CrmPipelineStage.for_account(Current.account.id)
+  end
+
+  def set_pipeline_stage
+    @pipeline_stage = stage_scope.find(params[:id])
+  end
+
+  def pipeline_stage_payload
+    params.require(:pipeline_stage)
+  end
+
+  def stage_params
+    pipeline_stage_payload.permit(
+      :slug,
+      :name,
+      :color,
+      :position,
+      :rotting_enabled,
+      :rotting_after_minutes,
+      :fleet_status_trigger
+    )
+  end
+
+  def stage_update_params
+    pipeline_stage_payload.permit(
+      :name,
+      :color,
+      :rotting_enabled,
+      :rotting_after_minutes,
+      :fleet_status_trigger
+    )
+  end
+
+  def immutable_stage_params_present?
+    %i[slug position is_system].any? { |key| pipeline_stage_payload.key?(key) }
+  end
+
+  def valid_custom_position?(position)
+    position > 1 && position < 999
+  end
+
+  def render_position_error
+    render_validation_error('position must be between 2 and 998')
+  end
+
+  def render_immutable_field_error
+    render_validation_error('slug, position, and is_system cannot be updated')
+  end
+
+  def render_system_stage_error
+    render_validation_error('system stages cannot be modified this way')
+  end
+
+  def render_validation_error(message)
+    render json: { error: message }, status: :unprocessable_entity
+  end
+
+  def check_authorization
+    raise Pundit::NotAuthorizedError unless Current.account_user.administrator?
+  end
+end
diff --git a/app/controllers/api/v1/accounts/crm/deals_controller.rb b/app/controllers/api/v1/accounts/crm/deals_controller.rb
