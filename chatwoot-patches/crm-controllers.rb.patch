+class Api::V1::Accounts::Crm::LossReasonsController < Api::V1::Accounts::BaseController
+  before_action :check_authorization
+  before_action :set_loss_reason, only: [:update]
+
+  def index
+    render json: loss_reason_scope.active
+  end
+
+  def create
+    @loss_reason = CrmLossReasonOption.new(loss_reason_params.merge(account: Current.account))
+    @loss_reason.save!
+
+    render json: @loss_reason
+  end
+
+  def update
+    @loss_reason.update!(loss_reason_params)
+
+    render json: @loss_reason
+  end
+
+  private
+
+  def loss_reason_scope
+    CrmLossReasonOption.for_account(Current.account.id)
+  end
+
+  def set_loss_reason
+    @loss_reason = loss_reason_scope.find(params[:id])
+  end
+
+  def loss_reason_params
+    params.require(:loss_reason).permit(
+      :label,
+      :position,
+      :is_active
+    )
+  end
+
+  def check_authorization
+    raise Pundit::NotAuthorizedError unless Current.account_user.administrator?
+  end
+end
