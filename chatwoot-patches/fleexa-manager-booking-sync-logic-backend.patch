diff --git a/app/services/fleexa_manager/v1/booking_deal_reference_resolver.rb b/app/services/fleexa_manager/v1/booking_deal_reference_resolver.rb
new file mode 100644
index 0000000..4b2aac7
--- /dev/null
+++ b/app/services/fleexa_manager/v1/booking_deal_reference_resolver.rb
@@ -0,0 +1,187 @@
+require 'uri'
+
+module FleexaManager
+  module V1
+    class BookingDealReferenceResolver
+      class WrongAccountError < StandardError; end
+
+      def initialize(account:, credential:)
+        @account = account
+        @credential = credential
+      end
+
+      def call(ref)
+        @input = ref.to_s.strip
+        parsed = parsed_reference(@input)
+        raise WrongAccountError, 'Reference points to another account.' if parsed[:account_id].present? && parsed[:account_id] != account.id
+
+        deal_candidates = resolve_deal_candidates(parsed)
+        conversation_candidates = resolve_conversation_deal_candidates(parsed)
+        candidates = (deal_candidates + conversation_candidates).uniq(&:id)
+
+        return not_found_response if candidates.blank?
+        return resolved_response(candidates.first) if candidates.one?
+
+        ambiguous_response(candidates)
+      end
+
+      private
+
+      attr_reader :account, :credential, :input
+
+      def parsed_reference(value)
+        explicit_deal_ids = value.scan(%r{(?:\bdeal[_/-]?|/deals/)(\d+)\b}i).flatten.map(&:to_i)
+        explicit_conversation_ids = value.scan(%r{(?:\bconv[_/-]?|/conversations/)(\d+)\b}i).flatten.map(&:to_i)
+        explicit_conversation_ids += query_values(value, %w[conversation_id conversationId]).map(&:to_i)
+        explicit_deal_ids += query_values(value, %w[deal_id dealId pipeline_deal_id pipelineDealId]).map(&:to_i)
+
+        numeric_id = value.match(/\A#?(\d+)\z/)&.[](1)&.to_i
+        deal_display_id = value.match(/\AD-(\d+)\z/i)&.[](1)&.to_i
+        account_id = value.match(%r{/accounts/(?:acc_)?(\d+)}i)&.[](1)&.to_i
+
+        {
+          account_id: account_id,
+          deal_ids: (explicit_deal_ids + [deal_display_id].compact + [numeric_id].compact).uniq,
+          conversation_ids: (explicit_conversation_ids + [numeric_id].compact).uniq,
+          explicit_deal_ids: (explicit_deal_ids + [deal_display_id].compact).uniq,
+          explicit_conversation_ids: explicit_conversation_ids.uniq
+        }
+      end
+
+      def query_values(value, keys)
+        uri = URI.parse(value)
+        return [] if uri.query.blank?
+
+        Rack::Utils.parse_nested_query(uri.query).values_at(*keys).compact
+      rescue URI::InvalidURIError
+        []
+      end
+
+      def resolve_deal_candidates(parsed)
+        return [] if parsed[:deal_ids].blank?
+
+        direct_deals = CrmDeal.where(id: parsed[:deal_ids])
+        account_deals = direct_deals.for_account(account.id).includes(:stage, :contact, :conversation).to_a
+        raise WrongAccountError, 'Deal belongs to another account.' if account_deals.blank? && direct_deals.exists?
+
+        account_deals
+      end
+
+      def resolve_conversation_deal_candidates(parsed)
+        return [] if parsed[:conversation_ids].blank?
+
+        conversation_ids = parsed[:conversation_ids]
+        conversations = Conversation.where(account_id: account.id, display_id: conversation_ids).to_a
+        conversation_record_ids = conversations.map(&:id) + conversation_ids
+
+        CrmDeal
+          .for_account(account.id)
+          .where(conversation_id: conversation_record_ids.uniq)
+          .includes(:stage, :contact, :conversation)
+          .to_a
+      end
+
+      def resolved_response(deal)
+        base_response('RESOLVED').merge(
+          pipeline_deal_id: deal.id.to_s,
+          deal_display_number: deal_display_number(deal),
+          conversation_id: conversation_display_id(deal),
+          company_id: credential&.fleexa_company_id,
+          client_preview: contact_preview(deal.contact),
+          preview: deal_preview(deal),
+          candidates: []
+        )
+      end
+
+      def not_found_response
+        base_response('NOT_FOUND').merge(
+          pipeline_deal_id: nil,
+          deal_display_number: nil,
+          conversation_id: nil,
+          company_id: credential&.fleexa_company_id,
+          client_preview: nil,
+          preview: nil,
+          candidates: []
+        )
+      end
+
+      def ambiguous_response(deals)
+        base_response('AMBIGUOUS_REFERENCE').merge(
+          pipeline_deal_id: nil,
+          deal_display_number: nil,
+          conversation_id: nil,
+          company_id: credential&.fleexa_company_id,
+          client_preview: nil,
+          preview: nil,
+          candidates: deals.map { |deal| deal_candidate(deal, 'deal_ref_and_conversation_ref_disagree') }
+        )
+      end
+
+      def base_response(status)
+        {
+          status: status,
+          code: status,
+          retryable: false,
+          accountId: "acc_#{account.id}",
+          fleexaCompanyId: credential&.fleexa_company_id,
+          input: input
+        }
+      end
+
+      def deal_candidate(deal, reason)
+        deal_preview(deal).merge(reason: reason, active: active_deal?(deal))
+      end
+
+      def deal_preview(deal)
+        {
+          pipeline_deal_id: deal.id.to_s,
+          deal_display_number: deal_display_number(deal),
+          title: deal.title.to_s,
+          stage: stage_preview(deal.stage),
+          client_preview: contact_preview(deal.contact),
+          conversation_id: conversation_display_id(deal),
+          existing_booking_id: deal.booking_id.presence
+        }
+      end
+
+      def stage_preview(stage)
+        return if stage.blank?
+
+        {
+          id: stage.id.to_s,
+          key: stage.slug.to_s,
+          name: stage.name.to_s,
+          fleet_status_trigger: stage.fleet_status_trigger.presence
+        }
+      end
+
+      def contact_preview(contact)
+        return if contact.blank?
+
+        {
+          id: contact.id.to_s,
+          displayName: contact.name.presence || contact.phone_number.presence || contact.email.presence || "Contact ##{contact.id}",
+          phone: contact.phone_number.presence,
+          phoneNumber: contact.phone_number.presence,
+          email: contact.email.presence
+        }
+      end
+
+      def deal_display_number(deal)
+        "D-#{deal.id}"
+      end
+
+      def conversation_display_id(deal)
+        deal.conversation&.display_id&.to_s
+      end
+
+      def active_deal?(deal)
+        trigger = deal.stage&.fleet_status_trigger.to_s
+        return false if %w[done cancel].include?(trigger)
+
+        label = [deal.stage&.slug, deal.stage&.name].compact.join(' ').downcase
+        !label.match?(/\b(done|complete|completed|won|cancel|cancelled|canceled|lost)\b/)
+      end
+    end
+  end
+end
diff --git a/app/services/fleexa_manager/v1/booking_pipeline_relink_service.rb b/app/services/fleexa_manager/v1/booking_pipeline_relink_service.rb
new file mode 100644
index 0000000..647cd77
--- /dev/null
+++ b/app/services/fleexa_manager/v1/booking_pipeline_relink_service.rb
@@ -0,0 +1,121 @@
+require 'json'
+require 'zlib'
+
+module FleexaManager
+  module V1
+    class BookingPipelineRelinkService
+      class WrongAccountError < StandardError; end
+      class InvalidRequestError < StandardError; end
+
+      def initialize(account:, credential:, booking_id:, new_pipeline_deal_id:, reason:)
+        @account = account
+        @credential = credential
+        @booking_id = booking_id.to_s
+        @new_pipeline_deal_id = new_pipeline_deal_id.to_s
+        @reason = reason.to_s
+      end
+
+      def call
+        ActiveRecord::Base.transaction do
+          advisory_lock!
+
+          new_deal = target_deal
+          old_deal = CrmDeal.for_account(account.id).lock.where(booking_id: booking_id).where.not(id: new_deal.id).first
+          raise InvalidRequestError, 'Target deal is already linked to another booking.' if new_deal.booking_id.present? && new_deal.booking_id != booking_id
+
+          audit = audit_payload(old_deal, new_deal)
+          clear_old_deal!(old_deal, audit) if old_deal.present?
+          link_new_deal!(new_deal, audit)
+
+          relink_response(old_deal, new_deal, audit)
+        end
+      end
+
+      private
+
+      attr_reader :account, :credential, :booking_id, :new_pipeline_deal_id, :reason
+
+      def target_deal
+        id = stable_numeric_id(new_pipeline_deal_id, 'deal')
+        raise InvalidRequestError, 'new_pipeline_deal_id must be a real crm_deals.id.' if id.blank?
+
+        deal = CrmDeal.where(id: id).lock.first
+        raise InvalidRequestError, 'new_pipeline_deal_id was not found.' if deal.blank?
+        raise WrongAccountError, 'Deal belongs to another account.' if deal.account_id != account.id
+
+        deal
+      end
+
+      def clear_old_deal!(deal, audit)
+        attrs = custom_attributes(deal)
+        attrs['booking_relink_audit'] = relink_audit_entries(attrs).push(audit)
+        attrs['booking_relinked_to_deal_id'] = audit['new_deal_id']
+        deal.update!(booking_id: nil, custom_attributes: attrs)
+        create_activity!(deal, audit, "Booking #{booking_id} relinked to deal #{audit['new_deal_id']}.")
+      end
+
+      def link_new_deal!(deal, audit)
+        attrs = custom_attributes(deal)
+        attrs['booking_relink_audit'] = relink_audit_entries(attrs).push(audit)
+        attrs.delete('booking_relinked_to_deal_id')
+        deal.update!(booking_id: booking_id, custom_attributes: attrs)
+        create_activity!(deal, audit, "Booking #{booking_id} linked from deal #{audit['old_deal_id'] || 'none'}.")
+      end
+
+      def create_activity!(deal, audit, message)
+        CrmDealActivity.create!(
+          account: account,
+          crm_deal: deal,
+          activity_type: 'booking_relinked',
+          note: "#{message}\n#{JSON.generate(audit)}"
+        )
+      end
+
+      def audit_payload(old_deal, new_deal)
+        {
+          'old_deal_id' => old_deal&.id&.to_s,
+          'new_deal_id' => new_deal.id.to_s,
+          'booking_id' => booking_id,
+          'user_id' => nil,
+          'service_actor' => 'fleexa_booking_service',
+          'changed_at' => Time.current.utc.iso8601,
+          'reason' => reason
+        }
+      end
+
+      def custom_attributes(deal)
+        deal.custom_attributes.is_a?(Hash) ? deal.custom_attributes.deep_dup : {}
+      end
+
+      def relink_audit_entries(attrs)
+        Array(attrs['booking_relink_audit']).select { |entry| entry.is_a?(Hash) }
+      end
+
+      def relink_response(old_deal, new_deal, audit)
+        {
+          status: 'RELINKED',
+          code: 'RELINKED',
+          retryable: false,
+          accountId: "acc_#{account.id}",
+          fleexaCompanyId: credential&.fleexa_company_id,
+          bookingId: booking_id,
+          oldPipelineDealId: old_deal&.id&.to_s,
+          newPipelineDealId: new_deal.id.to_s,
+          auditRequired: true,
+          audit: audit,
+          mutated: true
+        }
+      end
+
+      def stable_numeric_id(value, prefix)
+        raw = value.to_s.strip
+        raw.match(/\A#{Regexp.escape(prefix)}_(\d+)\z/)&.[](1)&.to_i || raw.match(/\A\d+\z/)&.[](0)&.to_i
+      end
+
+      def advisory_lock!
+        lock_key = Zlib.crc32("fleexa-booking-relink:#{account.id}:#{booking_id}")
+        ActiveRecord::Base.connection.execute("SELECT pg_advisory_xact_lock(#{lock_key}::bigint)")
+      end
+    end
+  end
+end
diff --git a/app/services/fleexa_manager/v1/booking_pipeline_sync_service.rb b/app/services/fleexa_manager/v1/booking_pipeline_sync_service.rb
new file mode 100644
index 0000000..79f779b
--- /dev/null
+++ b/app/services/fleexa_manager/v1/booking_pipeline_sync_service.rb
@@ -0,0 +1,471 @@
+require 'bigdecimal'
+require 'zlib'
+
+module FleexaManager
+  module V1
+    class BookingPipelineSyncService
+      class WrongAccountError < StandardError; end
+      class InvalidRequestError < StandardError; end
+
+      STATUS_TO_STAGE_TRIGGER = {
+        'booking' => 'reserved',
+        'reserved' => 'reserved',
+        'rental' => 'rental',
+        'done' => 'done',
+        'cancel' => 'cancel'
+      }.freeze
+
+      FALLBACK_STAGE_TERMS = {
+        'reserved' => %w[reserved booking booked],
+        'rental' => %w[rental active],
+        'done' => %w[done completed complete won],
+        'cancel' => %w[cancel cancelled canceled follow]
+      }.freeze
+
+      def initialize(account:, credential:, payload:, idempotency_key:)
+        @account = account
+        @credential = credential
+        @payload = payload.to_h.deep_stringify_keys
+        @idempotency_key = idempotency_key.to_s
+      end
+
+      def call
+        ActiveRecord::Base.transaction do
+          advisory_lock!
+
+          target_deal = explicit_pipeline_deal
+          if target_deal.present?
+            sync_existing_deal(target_deal, explicit: true)
+          else
+            existing_deal = CrmDeal.for_account(account.id).lock.where(booking_id: booking_id).includes(:stage, :contact, :conversation).first
+            if existing_deal.present?
+              sync_existing_deal(existing_deal, explicit: false)
+            else
+              contact = confirmed_contact
+              active_deals = contact.present? ? active_deals_for(contact) : []
+              active_deals.any? ? pending_user_action(active_deals) : sync_new_deal(contact || create_booking_contact!)
+            end
+          end
+        end
+      rescue ActiveRecord::RecordNotUnique
+        ActiveRecord::Base.transaction do
+          advisory_lock!
+          deal = CrmDeal.for_account(account.id).lock.find_by!(booking_id: booking_id)
+          sync_existing_deal(deal, explicit: false)
+        end
+      end
+
+      private
+
+      attr_reader :account, :credential, :payload, :idempotency_key
+
+      def explicit_pipeline_deal
+        raw = payload_value('pipeline_deal_id', 'pipelineDealId')
+        return if raw.blank?
+
+        id = stable_numeric_id(raw, 'deal')
+        raise InvalidRequestError, 'pipeline_deal_id must be a real crm_deals.id.' if id.blank?
+
+        deal = CrmDeal.where(id: id).includes(:stage, :contact, :conversation).first
+        raise WrongAccountError, 'Deal belongs to another account.' if deal.present? && deal.account_id != account.id
+
+        deal || raise(InvalidRequestError, 'pipeline_deal_id was not found.')
+      end
+
+      def sync_existing_deal(deal, explicit:)
+        deal.lock!
+        if explicit && deal.booking_id.present? && deal.booking_id != booking_id
+          raise InvalidRequestError, 'pipeline_deal_id is already linked to another booking.'
+        end
+
+        return stale_response(deal) if stale_event?(deal)
+
+        contact = confirmed_contact
+        assign_contact = contact.present? && explicit_contact_override?
+        update_deal!(deal, contact: contact, assign_contact: assign_contact, new_deal: false, explicit_deal: explicit)
+
+        synced_response(deal, mutated: true)
+      end
+
+      def sync_new_deal(contact)
+        stage = mapped_stage
+        deal = CrmDeal.create!(
+          account: account,
+          stage: stage,
+          contact: contact,
+          title: generated_title,
+          booking_id: booking_id,
+          car_model: vehicle_name,
+          rental_start: parse_time(payload_value('rental_start', 'rentalStart')),
+          rental_end: parse_time(payload_value('rental_end', 'rentalEnd')),
+          amount: decimal_value(payload_value('amount')),
+          client_phone: safe_client_phone_for_new_deal(contact),
+          custom_attributes: booking_snapshot.merge('stage_mapping' => stage_mapping_snapshot(stage))
+        )
+
+        synced_response(deal, mutated: true)
+      end
+
+      def update_deal!(deal, contact:, assign_contact:, new_deal:, explicit_deal:)
+        stage = mapped_stage
+        attrs = {
+          booking_id: booking_id,
+          stage: stage,
+          car_model: vehicle_name,
+          rental_start: parse_time(payload_value('rental_start', 'rentalStart')),
+          rental_end: parse_time(payload_value('rental_end', 'rentalEnd')),
+          amount: decimal_value(payload_value('amount')),
+          custom_attributes: deal_custom_attributes(deal, stage)
+        }
+
+        attrs[:contact] = contact if assign_contact || new_deal
+        attrs[:client_phone] = safe_client_phone_for_existing_deal(deal, contact, assign_contact, explicit_deal)
+
+        deal.update!(attrs)
+      end
+
+      def stale_event?(deal)
+        stored = deal.custom_attributes.is_a?(Hash) ? deal.custom_attributes['booking_version'] : nil
+        stored.present? && booking_version < stored.to_i
+      end
+
+      def stale_response(deal)
+        {
+          status: 'STALE_BOOKING_EVENT',
+          code: 'STALE_BOOKING_EVENT',
+          retryable: false,
+          accountId: "acc_#{account.id}",
+          fleexaCompanyId: credential&.fleexa_company_id,
+          bookingId: booking_id,
+          acceptedBookingVersion: deal.custom_attributes['booking_version'].to_i,
+          receivedBookingVersion: booking_version,
+          freshnessBasis: 'booking_version',
+          pipelineDealId: deal.id.to_s,
+          mutated: false
+        }
+      end
+
+      def pending_user_action(deals)
+        {
+          status: 'PENDING_USER_ACTION',
+          code: 'PENDING_USER_ACTION',
+          retryable: false,
+          accountId: "acc_#{account.id}",
+          fleexaCompanyId: credential&.fleexa_company_id,
+          bookingId: booking_id,
+          bookingVersion: booking_version,
+          freshnessBasis: 'booking_version',
+          pipelineDealId: nil,
+          mutated: false,
+          candidates: deals.map { |deal| deal_candidate(deal, 'multiple_active_deals') }
+        }
+      end
+
+      def synced_response(deal, mutated:)
+        {
+          status: 'SYNCED',
+          code: 'SYNCED',
+          retryable: false,
+          accountId: "acc_#{account.id}",
+          fleexaCompanyId: credential&.fleexa_company_id,
+          bookingId: booking_id,
+          bookingVersion: booking_version,
+          freshnessBasis: 'booking_version',
+          pipelineDealId: deal.id.to_s,
+          dealDisplayNumber: "D-#{deal.id}",
+          mutated: mutated,
+          candidates: []
+        }
+      end
+
+      def confirmed_contact
+        return @confirmed_contact if defined?(@confirmed_contact)
+
+        @confirmed_contact = Contact.where(account_id: account.id)
+                                    .where("custom_attributes ->> 'booking_client_id' = ?", booking_client_id)
+                                    .first
+      end
+
+      def phone_candidate_contacts
+        return Contact.none if booking_client_phone.blank?
+
+        Contact.where(account_id: account.id, phone_number: booking_client_phone)
+      end
+
+      def create_booking_contact!
+        Contact.create!(
+          account: account,
+          name: booking_client_name,
+          phone_number: safe_phone_for_new_contact,
+          custom_attributes: {
+            'booking_client_id' => booking_client_id,
+            'booking_client_name' => booking_client_name,
+            'booking_client_phone' => booking_client_phone
+          }.compact
+        )
+      end
+
+      def active_deals_for(contact)
+        CrmDeal
+          .for_account(account.id)
+          .where(contact_id: contact.id)
+          .includes(:stage, :contact, :conversation)
+          .select { |deal| active_deal?(deal) }
+      end
+
+      def active_deal?(deal)
+        trigger = deal.stage&.fleet_status_trigger.to_s
+        return false if %w[done cancel].include?(trigger)
+
+        label = [deal.stage&.slug, deal.stage&.name].compact.join(' ').downcase
+        !label.match?(/\b(done|complete|completed|won|cancel|cancelled|canceled|lost)\b/)
+      end
+
+      def mapped_stage
+        @mapped_stage ||= begin
+          trigger = STATUS_TO_STAGE_TRIGGER.fetch(booking_status) { 'reserved' }
+          exact = CrmPipelineStage.for_account(account.id).ordered.find_by(fleet_status_trigger: trigger)
+          exact || fallback_stage_for(trigger) || first_stage!
+        end
+      end
+
+      def fallback_stage_for(trigger)
+        terms = FALLBACK_STAGE_TERMS.fetch(trigger, [])
+        CrmPipelineStage.for_account(account.id).ordered.detect do |stage|
+          label = [stage.slug, stage.name].compact.join(' ').downcase
+          terms.any? { |term| label.include?(term) }
+        end
+      end
+
+      def first_stage!
+        CrmPipelineStage.for_account(account.id).ordered.first ||
+          raise(InvalidRequestError, 'No CRM pipeline stages are configured for this account.')
+      end
+
+      def stage_mapping_snapshot(stage)
+        trigger = STATUS_TO_STAGE_TRIGGER.fetch(booking_status) { 'reserved' }
+        {
+          'booking_status' => booking_status,
+          'target_trigger' => trigger,
+          'stage_id' => stage.id.to_s,
+          'stage_slug' => stage.slug.to_s,
+          'stage_trigger' => stage.fleet_status_trigger.presence,
+          'fallback' => stage.fleet_status_trigger.to_s != trigger
+        }
+      end
+
+      def deal_custom_attributes(deal, stage)
+        attrs = deal.custom_attributes.is_a?(Hash) ? deal.custom_attributes.deep_dup : {}
+        attrs.merge(booking_snapshot).merge('stage_mapping' => stage_mapping_snapshot(stage))
+      end
+
+      def booking_snapshot
+        {
+          'booking_number' => payload_value('booking_number', 'bookingNumber').to_s,
+          'booking_client_id' => booking_client_id,
+          'booking_client_name' => booking_client_name,
+          'booking_client_phone' => booking_client_phone,
+          'vehicle_id' => vehicle_value('vehicle_id', 'vehicleId'),
+          'vehicle_name' => vehicle_name,
+          'vehicle_plate' => vehicle_value('vehicle_plate', 'vehiclePlate'),
+          'rental_days' => integer_value(payload_value('rental_days', 'rentalDays')),
+          'currency' => payload_value('currency').to_s,
+          'booking_status' => booking_status,
+          'source' => source_type,
+          'referred_by_contact_id' => referred_by_contact_id,
+          'communication_phone' => communication_phone,
+          'booking_version' => booking_version,
+          'source_updated_at' => payload_value('source_updated_at', 'sourceUpdatedAt'),
+          'last_booking_event_id' => payload_value('event_id', 'eventId').presence || idempotency_key
+        }
+      end
+
+      def deal_candidate(deal, reason)
+        {
+          pipeline_deal_id: deal.id.to_s,
+          deal_display_number: "D-#{deal.id}",
+          title: deal.title.to_s,
+          stage: stage_preview(deal.stage),
+          client_preview: contact_preview(deal.contact),
+          conversation_id: deal.conversation&.display_id&.to_s,
+          existing_booking_id: deal.booking_id.presence,
+          reason: reason,
+          active: active_deal?(deal)
+        }
+      end
+
+      def stage_preview(stage)
+        return if stage.blank?
+
+        {
+          id: stage.id.to_s,
+          key: stage.slug.to_s,
+          name: stage.name.to_s,
+          fleet_status_trigger: stage.fleet_status_trigger.presence
+        }
+      end
+
+      def contact_preview(contact)
+        return if contact.blank?
+
+        {
+          id: contact.id.to_s,
+          displayName: contact.name.presence || contact.phone_number.presence || contact.email.presence || "Contact ##{contact.id}",
+          phone: contact.phone_number.presence,
+          phoneNumber: contact.phone_number.presence,
+          email: contact.email.presence
+        }
+      end
+
+      def explicit_contact_override?
+        ActiveModel::Type::Boolean.new.cast(
+          payload_value(
+            'confirmed_contact_override',
+            'confirmedContactOverride',
+            'manager_contact_override',
+            'managerContactOverride'
+          )
+        )
+      end
+
+      def safe_client_phone_for_existing_deal(deal, contact, assign_contact, explicit_deal)
+        return deal.client_phone unless assign_contact
+        return deal.client_phone if explicit_deal
+
+        safe_client_phone_for_new_deal(contact)
+      end
+
+      def safe_client_phone_for_new_deal(contact)
+        phone = booking_client_phone
+        return if phone.blank?
+        return phone if contact.present? && contact.phone_number == phone
+        return phone if phone_candidate_contacts.blank?
+      end
+
+      def safe_phone_for_new_contact
+        phone = booking_client_phone
+        return if phone.blank?
+        return unless phone.match?(/\A\+[1-9]\d{1,14}\z/)
+        return if phone_candidate_contacts.exists?
+
+        phone
+      end
+
+      def generated_title
+        [booking_client_name, vehicle_name.presence || payload_value('booking_number', 'bookingNumber')]
+          .compact
+          .join(' - ')
+          .presence
+          .to_s
+          .truncate(255)
+      end
+
+      def booking_id
+        payload_value('booking_id', 'bookingId').to_s
+      end
+
+      def booking_client_id
+        payload_value('booking_client_id', 'bookingClientId').to_s
+      end
+
+      def booking_client_name
+        payload_value('booking_client_name', 'bookingClientName').to_s
+      end
+
+      def booking_client_phone
+        payload_value('booking_client_phone', 'bookingClientPhone').presence
+      end
+
+      def booking_version
+        @booking_version ||= Integer(payload_value('booking_version', 'bookingVersion'))
+      end
+
+      def booking_status
+        payload_value('booking_status', 'bookingStatus').to_s
+      end
+
+      def source_type
+        source = payload_value('source')
+        return source.to_s if source.is_a?(String)
+
+        hash_value(source)['type'].presence || payload_value('source_type', 'sourceType').presence || 'Booking'
+      end
+
+      def communication_phone
+        source = hash_value(payload_value('source'))
+        referral = hash_value(payload_value('referral'))
+        payload_value('communication_phone', 'communicationPhone').presence ||
+          source['communication_phone'].presence ||
+          source['communicationPhone'].presence ||
+          referral['communication_phone'].presence ||
+          referral['communicationPhone'].presence
+      end
+
+      def referred_by_contact_id
+        referral = hash_value(payload_value('referral'))
+        payload_value('referred_by_contact_id', 'referredByContactId').presence ||
+          referral['referred_by_contact_id'].presence ||
+          referral['referredByContactId'].presence
+      end
+
+      def vehicle_name
+        vehicle_value('vehicle_name', 'vehicleName', 'brand_model', 'brandModel').presence ||
+          [vehicle_value('brand'), vehicle_value('model')].compact.join(' ').presence
+      end
+
+      def vehicle_value(*keys)
+        vehicle = hash_value(payload_value('vehicle'))
+        keys.each do |key|
+          return vehicle[key] if vehicle.key?(key)
+          return payload[key] if payload.key?(key)
+        end
+        nil
+      end
+
+      def payload_value(*keys)
+        keys.each do |key|
+          return payload[key] if payload.key?(key)
+        end
+        nil
+      end
+
+      def hash_value(value)
+        value.is_a?(Hash) ? value.deep_stringify_keys : {}
+      end
+
+      def stable_numeric_id(value, prefix)
+        raw = value.to_s.strip
+        raw.match(/\A#{Regexp.escape(prefix)}_(\d+)\z/)&.[](1)&.to_i || raw.match(/\A\d+\z/)&.[](0)&.to_i
+      end
+
+      def parse_time(value)
+        return if value.blank?
+
+        Time.zone.parse(value.to_s)
+      rescue ArgumentError, TypeError
+        nil
+      end
+
+      def decimal_value(value)
+        return if value.blank?
+
+        BigDecimal(value.to_s)
+      rescue ArgumentError
+        nil
+      end
+
+      def integer_value(value)
+        return if value.blank?
+
+        Integer(value)
+      rescue ArgumentError, TypeError
+        nil
+      end
+
+      def advisory_lock!
+        lock_key = Zlib.crc32("fleexa-booking-sync:#{account.id}:#{booking_id}")
+        ActiveRecord::Base.connection.execute("SELECT pg_advisory_xact_lock(#{lock_key}::bigint)")
+      end
+    end
+  end
+end
