diff --git a/spec/requests/api/fleexa_manager/v1/booking_sync_logic_spec.rb b/spec/requests/api/fleexa_manager/v1/booking_sync_logic_spec.rb
new file mode 100644
index 0000000..46e8741
--- /dev/null
+++ b/spec/requests/api/fleexa_manager/v1/booking_sync_logic_spec.rb
@@ -0,0 +1,365 @@
+require 'rails_helper'
+
+RSpec.describe 'Fleexa Manager Booking sync logic API', type: :request do
+  let(:account) { create(:account) }
+  let(:other_account) { create(:account) }
+  let(:service_token) { 'booking-service-token-prompt-4' }
+
+  def booking_headers(token = service_token)
+    { 'X-Fleexa-Booking-Token' => token }
+  end
+
+  def create_booking_credential(account:, token: service_token, scopes: ['booking:sync'])
+    FleexaManagerBookingCredential.create!(
+      account: account,
+      fleexa_company_id: "fleexa_company_#{account.id}",
+      token_digest: FleexaManagerBookingCredential.digest_token(token),
+      scopes: scopes,
+      active: true
+    )
+  end
+
+  def enable_booking_receiver!(target_account = account)
+    target_account.update!(
+      settings: (target_account.settings || {}).merge(
+        'fleexa_booking_pipeline_sync' => {
+          'receiver_enabled' => true
+        }
+      )
+    )
+  end
+
+  def stage(slug:, name:, position:, trigger:, target_account: account)
+    CrmPipelineStage.create!(
+      account: target_account,
+      slug: slug,
+      name: name,
+      color: '#0EA5A0',
+      position: position,
+      fleet_status_trigger: trigger
+    )
+  end
+
+  def build_pipeline!
+    @reserved_stage = stage(slug: 'reserved', name: 'Booking', position: 1, trigger: 'reserved')
+    @rental_stage = stage(slug: 'active_rental', name: 'Active rental', position: 2, trigger: 'rental')
+    @done_stage = stage(slug: 'completed', name: 'Completed', position: 3, trigger: 'done')
+    @cancel_stage = stage(slug: 'follow_up_cancel', name: 'Cancel follow-up', position: 4, trigger: 'cancel')
+  end
+
+  def sync_path(target_account = account)
+    "/api/fleexa-manager/v1/accounts/acc_#{target_account.id}/bookings/sync"
+  end
+
+  def resolve_deal_path(target_account = account)
+    "/api/fleexa-manager/v1/accounts/acc_#{target_account.id}/bookings/resolve-deal"
+  end
+
+  def relink_path(booking_id = 'order_1001', target_account = account)
+    "/api/fleexa-manager/v1/accounts/acc_#{target_account.id}/bookings/#{booking_id}/relink-deal"
+  end
+
+  def sync_payload(overrides = {})
+    {
+      booking_id: 'order_1001',
+      booking_number: 'BK-1001',
+      booking_client_id: 'booking_contact_501',
+      booking_client_name: 'Mina Patel',
+      booking_client_phone: '+971501112233',
+      booking_version: 7,
+      source_updated_at: '2026-07-18T10:00:00Z',
+      event_id: SecureRandom.uuid,
+      pipeline_deal_id: nil,
+      vehicle: {
+        vehicle_id: 'vehicle_77',
+        vehicle_name: 'Range Rover Sport',
+        vehicle_plate: 'D 83839'
+      },
+      rental_start: '2026-07-20T10:00:00Z',
+      rental_end: '2026-07-22T10:00:00Z',
+      rental_days: 2,
+      amount: '1800.00',
+      currency: 'AED',
+      booking_status: 'reserved',
+      source: {
+        type: 'Booking'
+      },
+      referral: {
+        communication_phone: nil,
+        referred_by_contact_id: nil
+      }
+    }.deep_merge(overrides)
+  end
+
+  def booking_contact(booking_client_id:, phone: nil, name: 'Mina Patel')
+    Contact.create!(
+      account: account,
+      name: name,
+      phone_number: phone,
+      custom_attributes: { 'booking_client_id' => booking_client_id }
+    )
+  end
+
+  before do
+    enable_booking_receiver!
+    create_booking_credential(account: account)
+    build_pipeline!
+  end
+
+  it 'returns AMBIGUOUS_REFERENCE when #344 matches a deal and a different conversation-linked deal' do
+    direct_contact = create(:contact, account: account, name: 'Direct Client')
+    conversation_contact = create(:contact, account: account, name: 'Conversation Client')
+    inbox = create(:inbox, account: account)
+    contact_inbox = create(:contact_inbox, contact: conversation_contact, inbox: inbox)
+    conversation = create(:conversation, account: account, inbox: inbox, contact: conversation_contact, contact_inbox: contact_inbox, display_id: 344)
+
+    direct_deal = CrmDeal.create!(id: 344, account: account, stage: @reserved_stage, contact: direct_contact, title: 'Deal id 344')
+    conversation_deal = CrmDeal.create!(account: account, stage: @reserved_stage, contact: conversation_contact, conversation: conversation, title: 'Conversation 344 deal')
+
+    post resolve_deal_path,
+         params: { pipeline_deal_ref_input: '#344' },
+         headers: booking_headers,
+         as: :json
+
+    expect(response).to have_http_status(:ok)
+    expect(json_response['status']).to eq('AMBIGUOUS_REFERENCE')
+    expect(json_response['candidates'].map { |candidate| candidate['pipeline_deal_id'] }).to match_array(
+      [direct_deal.id.to_s, conversation_deal.id.to_s]
+    )
+  end
+
+  it 'rejects resolving a deal that belongs to another account' do
+    other_stage = stage(slug: 'reserved', name: 'Other booking', position: 1, trigger: 'reserved', target_account: other_account)
+    other_deal = CrmDeal.create!(account: other_account, stage: other_stage, title: 'Other account deal')
+
+    post resolve_deal_path,
+         params: { pipeline_deal_ref_input: "deal_#{other_deal.id}" },
+         headers: booking_headers,
+         as: :json
+
+    expect(response).to have_http_status(:forbidden)
+    expect(json_response['error']['code']).to eq('forbidden')
+  end
+
+  it 'updates an explicit existing deal without overwriting contact_id or client_phone' do
+    existing_contact = create(:contact, account: account, name: 'Existing Client', phone_number: '+971501110000')
+    confirmed_contact = booking_contact(booking_client_id: 'booking_contact_501', phone: '+971501112233', name: 'Booking Client')
+    deal = CrmDeal.create!(
+      account: account,
+      stage: @reserved_stage,
+      contact: existing_contact,
+      title: 'Existing linked deal',
+      client_phone: '+971501110000',
+      amount: 500,
+      custom_attributes: { 'booking_version' => 1 }
+    )
+
+    post sync_path,
+         params: sync_payload(pipeline_deal_id: deal.id.to_s, booking_status: 'rental', amount: '2400.00'),
+         headers: booking_headers,
+         as: :json
+
+    expect(response).to have_http_status(:ok)
+    expect(json_response['status']).to eq('SYNCED')
+    expect(json_response['pipelineDealId']).to eq(deal.id.to_s)
+    deal.reload
+    expect(deal.contact_id).to eq(existing_contact.id)
+    expect(deal.contact_id).not_to eq(confirmed_contact.id)
+    expect(deal.client_phone).to eq('+971501110000')
+    expect(deal.booking_id).to eq('order_1001')
+    expect(deal.stage_id).to eq(@rental_stage.id)
+    expect(deal.car_model).to eq('Range Rover Sport')
+    expect(deal.amount).to eq(BigDecimal('2400.0'))
+    expect(deal.custom_attributes).to include(
+      'booking_client_phone' => '+971501112233',
+      'vehicle_id' => 'vehicle_77',
+      'booking_version' => 7
+    )
+    expect(deal.custom_attributes['last_booking_event_id']).to be_present
+  end
+
+  it 'changes contact_id only when explicit contact override is present' do
+    existing_contact = create(:contact, account: account, name: 'Existing Client', phone_number: '+971501110001')
+    confirmed_contact = booking_contact(booking_client_id: 'booking_contact_501', phone: '+971501112234', name: 'Booking Client')
+    deal = CrmDeal.create!(account: account, stage: @reserved_stage, contact: existing_contact, title: 'Existing linked deal')
+
+    post sync_path,
+         params: sync_payload(
+           pipeline_deal_id: deal.id.to_s,
+           booking_client_phone: '+971501112234',
+           confirmed_contact_override: true
+         ),
+         headers: booking_headers,
+         as: :json
+
+    expect(response).to have_http_status(:ok)
+    expect(deal.reload.contact_id).to eq(confirmed_contact.id)
+  end
+
+  it 'returns PENDING_USER_ACTION without creating a duplicate when the confirmed contact has active deals' do
+    contact = booking_contact(booking_client_id: 'booking_contact_501', phone: '+971501112233')
+    active_deal = CrmDeal.create!(account: account, stage: @reserved_stage, contact: contact, title: 'Active candidate')
+
+    expect do
+      post sync_path, params: sync_payload, headers: booking_headers, as: :json
+    end.not_to change { CrmDeal.for_account(account.id).count }
+
+    expect(response).to have_http_status(:ok)
+    expect(json_response['status']).to eq('PENDING_USER_ACTION')
+    expect(json_response['retryable']).to be(false)
