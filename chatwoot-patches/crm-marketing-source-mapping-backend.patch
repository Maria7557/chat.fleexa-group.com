diff --git a/app/models/marketing_source_mapping.rb b/app/models/marketing_source_mapping.rb
new file mode 100644
index 0000000..2a302d1
--- /dev/null
+++ b/app/models/marketing_source_mapping.rb
@@ -0,0 +1,26 @@
+class MarketingSourceMapping < ApplicationRecord
+  self.table_name = 'marketing_source_mappings'
+
+  belongs_to :account
+
+  scope :active, -> { where(is_active: true) }
+  scope :for_account, ->(account_id) { where(account_id: account_id) }
+  scope :for_platform, ->(platform) { where(platform: platform) }
+
+  before_validation :normalize_fields
+
+  validates :platform, :source_key, :source_label, presence: true
+  validates :is_active, inclusion: { in: [true, false] }
+
+  private
+
+  def normalize_fields
+    self.platform = platform.to_s.strip.presence
+    self.ad_account_id = ad_account_id.to_s.strip.presence
+    self.campaign_id = campaign_id.to_s.strip.presence
+    self.source_key = source_key.to_s.strip.presence
+    self.source_label = source_label.to_s.strip.presence
+    self.entry_point_key = entry_point_key.to_s.strip.presence
+    self.is_active = true if is_active.nil?
+  end
+end
