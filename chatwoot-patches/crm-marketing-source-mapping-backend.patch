+          campaign_id: 'ga-campaign-search',
+          source_key: 'google_search_leads',
+          source_label: 'Google Search Leads',
+          entry_point_key: 'search'
+        },
+        {
+          platform: MarketingSpendDaily::SOURCE_SYSTEM_META_ADS,
+          ad_account_id: 'meta-act-1',
+          campaign_id: nil,
+          source_key: 'meta_paid_social',
+          source_label: 'Meta Paid Social',
+          entry_point_key: 'lead_forms'
+        }
+      ]
+
+      rows.each do |attributes|
+        mapping = MarketingSourceMapping.where(
+          account_id: account_id,
+          platform: attributes[:platform],
+          ad_account_id: attributes[:ad_account_id],
+          campaign_id: attributes[:campaign_id]
+        ).first_or_initialize
+        mapping.assign_attributes(attributes.merge(account_id: account_id, is_active: true))
+        mapping.save!
+      end
+
+      scope = MarketingSourceMapping.active.for_account(account_id)
+      puts "active_mappings=#{scope.count}"
+      puts "google_mappings=#{scope.for_platform(MarketingSpendDaily::SOURCE_SYSTEM_GOOGLE_ADS).count}"
+      puts "meta_mappings=#{scope.for_platform(MarketingSpendDaily::SOURCE_SYSTEM_META_ADS).count}"
+    end
