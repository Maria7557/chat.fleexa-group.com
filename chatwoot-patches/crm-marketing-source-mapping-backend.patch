diff --git a/app/services/crm/marketing_spend/source_mapping_resolver.rb b/app/services/crm/marketing_spend/source_mapping_resolver.rb
new file mode 100644
index 0000000..2961cf4
--- /dev/null
+++ b/app/services/crm/marketing_spend/source_mapping_resolver.rb
@@ -0,0 +1,92 @@
+module Crm
+  module MarketingSpend
+    class SourceMappingResolver
+      DEFAULTS = {
+        MarketingSpendDaily::SOURCE_SYSTEM_GOOGLE_ADS => {
+          source_key: MarketingSpendDaily::SOURCE_SYSTEM_GOOGLE_ADS,
+          source_label: 'Google Ads'
+        },
+        MarketingSpendDaily::SOURCE_SYSTEM_META_ADS => {
+          source_key: MarketingSpendDaily::SOURCE_SYSTEM_META_ADS,
+          source_label: 'Meta Ads'
+        }
+      }.freeze
+
+      Result = Struct.new(:source_key, :source_label, :entry_point_key, keyword_init: true)
+
+      def self.resolve(account_id:, platform:, ad_account_id:, campaign_id:)
+        new(
+          account_id: account_id,
+          platform: platform,
+          ad_account_id: ad_account_id,
+          campaign_id: campaign_id
+        ).resolve
+      end
+
+      def initialize(account_id:, platform:, ad_account_id:, campaign_id:)
+        @account_id = account_id
+        @platform = platform.to_s
+        @ad_account_id = ad_account_id.to_s.presence
+        @campaign_id = campaign_id.to_s.presence
+      end
+
+      def resolve
+        mapping = campaign_mapping || ad_account_mapping || platform_mapping
+        return result_for_mapping(mapping) if mapping.present?
+
+        default_result
+      end
+
+      private
+
+      attr_reader :account_id, :platform, :ad_account_id, :campaign_id
+
+      def mapping_scope
+        return MarketingSourceMapping.none unless MarketingSourceMapping.table_exists?
+
+        MarketingSourceMapping.active
+                              .for_account(account_id)
+                              .for_platform(platform)
+                              .order(id: :desc)
+      end
+
+      def campaign_mapping
+        return if campaign_id.blank?
+
+        if ad_account_id.present?
+          exact_mapping = mapping_scope.where(ad_account_id: ad_account_id, campaign_id: campaign_id).first
+          return exact_mapping if exact_mapping.present?
+        end
+
+        mapping_scope.where(ad_account_id: nil, campaign_id: campaign_id).first
+      end
+
+      def ad_account_mapping
+        return if ad_account_id.blank?
+
+        mapping_scope.where(ad_account_id: ad_account_id, campaign_id: nil).first
+      end
+
+      def platform_mapping
+        mapping_scope.where(ad_account_id: nil, campaign_id: nil).first
+      end
+
+      def result_for_mapping(mapping)
+        Result.new(
+          source_key: mapping.source_key,
+          source_label: mapping.source_label,
+          entry_point_key: mapping.entry_point_key
+        )
+      end
+
+      def default_result
+        default = DEFAULTS.fetch(platform, { source_key: platform, source_label: platform.presence || 'Unknown' })
+        Result.new(
+          source_key: default[:source_key],
+          source_label: default[:source_label],
+          entry_point_key: nil
+        )
+      end
+    end
+  end
+end
