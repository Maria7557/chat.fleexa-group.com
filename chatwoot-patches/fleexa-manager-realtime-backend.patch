diff --git a/app/services/fleexa_manager/v1/realtime_broadcaster.rb b/app/services/fleexa_manager/v1/realtime_broadcaster.rb
new file mode 100644
index 0000000..dd44314
--- /dev/null
+++ b/app/services/fleexa_manager/v1/realtime_broadcaster.rb
@@ -0,0 +1,169 @@
+module FleexaManager
+  module V1
+    class RealtimeBroadcaster
+      MESSAGE_CHANGED_FIELDS = %w[unreadCount replyState lastCustomerMessageAt lastAgentReplyAt].freeze
+      ASSIGNMENT_CHANGED_FIELDS = %w[assignedManager assignee].freeze
+      CONVERSATION_PERMISSIONS = %w[conversations:read messages:send].freeze
+
+      class << self
+        def stream_name(account, user)
+          "fleexa_manager:v1:account:#{account.id}:user:#{user.id}"
+        end
+
+        def message_created(message, actor: nil)
+          return if message.blank? || !visible_customer_message?(message)
+
+          conversation = message.conversation
+          users = visible_users(conversation)
+          broadcast_to_users(conversation.account, users) do |user|
+            realtime_event(
+              event_id: "evt_msg_#{message.id}_created",
+              event_type: 'message.created',
+              account: conversation.account,
+              actor: actor,
+              payload: {
+                conversationId: DtoSerializer.conversation_id(conversation),
+                message: DtoSerializer.message(message),
+                conversation: conversation_payload(conversation),
+                counters: counters_payload(conversation.account, user)
+              }
+            )
+          end
+          counters_updated(conversation.account, users: users, source_key: "msg_#{message.id}_created")
+        end
+
+        def conversation_updated(conversation, changed_attributes:, event_type: 'conversation.updated', actor: nil)
+          return if conversation.blank?
+
+          changed_fields = changed_fields_for(changed_attributes)
+          changed_fields = ASSIGNMENT_CHANGED_FIELDS if event_type == 'conversation.assigned' && changed_fields.blank?
+          changed_fields = MESSAGE_CHANGED_FIELDS if changed_fields.blank?
+
+          users = visible_users(conversation)
+          broadcast_to_users(conversation.account, users) do |user|
+            realtime_event(
+              event_id: "evt_conv_#{conversation.id}_#{event_type.tr('.', '_')}_#{conversation.updated_at.to_i}",
+              event_type: event_type,
+              account: conversation.account,
+              actor: actor,
+              payload: {
+                conversation: conversation_payload(conversation),
+                changedFields: changed_fields,
+                counters: counters_payload(conversation.account, user)
+              }
+            )
+          end
+          counters_updated(conversation.account, users: users, source_key: "conv_#{conversation.id}_#{event_type.tr('.', '_')}")
+        end
+
+        def counters_updated(account, users:, source_key:)
+          Array(users).compact.uniq.each do |user|
+            next unless user_visible_account?(account, user)
+
+            payload = counters_payload(account, user)
+            broadcast(
+              account,
+              user,
+              realtime_event(
+                event_id: "evt_counters_#{account.id}_#{user.id}_#{source_key}",
+                event_type: 'manager.counters.updated',
+                account: account,
+                actor: nil,
+                payload: { counters: payload }
+              )
+            )
+          end
+        end
+
+        private
+
+        def broadcast_to_users(account, users)
+          users.each do |user|
+            broadcast(account, user, yield(user))
+          end
+        end
+
+        def broadcast(account, user, event)
+          ActionCable.server.broadcast(stream_name(account, user), event)
+        end
+
+        def realtime_event(event_id:, event_type:, account:, actor:, payload:)
+          {
+            eventId: event_id,
+            eventType: event_type,
+            accountId: DtoSerializer.account_id(account),
+            occurredAt: Time.current.utc.iso8601,
+            cursor: nil,
+            sequence: nil,
+            actor: DtoSerializer.actor_ref(actor || Current.user),
+            payload: payload
+          }
+        end
+
+        def conversation_payload(conversation)
+          DtoSerializer.conversation_summary(conversation, permissions: CONVERSATION_PERMISSIONS)
+        end
+
+        def counters_payload(account, user)
+          scope = visible_conversation_scope(account, user)
+
+          {
+            accountId: DtoSerializer.account_id(account),
+            generatedAt: Time.current.utc.iso8601,
+            counters: {
+              unread: unread_count(scope, account),
+              assigned: scope.where.not(assignee_id: nil).count,
+              unassigned: scope.where(assignee_id: nil).count
+            }
+          }
+        end
+
+        def unread_count(scope, account)
+          scope.joins(:messages)
+               .where(messages: { account_id: account.id, message_type: Message.message_types[:incoming] })
+               .where('conversations.agent_last_seen_at IS NULL OR messages.created_at > conversations.agent_last_seen_at')
+               .distinct
+               .count
+        end
+
+        def visible_users(conversation)
+          account = conversation.account
+          users = conversation.inbox.members.to_a + account.administrators.to_a
+          users.uniq.select { |user| visible_conversation_scope(account, user).where(id: conversation.id).exists? }
+        end
+
+        def user_visible_account?(account, user)
+          return false unless user.is_a?(User)
+          return false if user.respond_to?(:active_for_authentication?) && !user.active_for_authentication?
+
+          account.account_users.exists?(user_id: user.id)
+        end
+
+        def visible_conversation_scope(account, user)
+          Conversations::PermissionFilterService.new(account.conversations, user, account).perform
+        end
+
+        def visible_customer_message?(message)
+          return false if message.private?
+          return false if message.activity?
+
+          message.incoming? || message.outgoing?
+        end
+
+        def changed_fields_for(changed_attributes)
+          keys = if changed_attributes.respond_to?(:keys)
+                   changed_attributes.keys.map(&:to_s)
+                 else
+                   []
+                 end
+          fields = []
+          fields.concat(ASSIGNMENT_CHANGED_FIELDS) if keys.intersect?(%w[assignee_id assignee_agent_bot_id])
+          fields << 'status' if keys.include?('status')
+          fields << 'unreadCount' if keys.intersect?(%w[agent_last_seen_at assignee_last_seen_at])
+          fields.concat(%w[replyState lastCustomerMessageAt lastAgentReplyAt]) if keys.intersect?(%w[waiting_since first_reply_created_at last_activity_at])
+          fields.uniq
+        end
+      end
+    end
+  end
+end
diff --git a/spec/channels/fleexa_manager/v1/realtime_channel_spec.rb b/spec/channels/fleexa_manager/v1/realtime_channel_spec.rb
new file mode 100644
index 0000000..ac76eea
--- /dev/null
+++ b/spec/channels/fleexa_manager/v1/realtime_channel_spec.rb
@@ -0,0 +1,32 @@
+require 'rails_helper'
+
+RSpec.describe FleexaManager::V1::RealtimeChannel do
+  let(:account) { create(:account) }
+  let(:other_account) { create(:account) }
+  let(:user) { create(:user, account: account, role: :administrator) }
+
+  before do
+    stub_connection
+  end
+
+  it 'subscribes an authenticated manager to their account/user stream' do
+    subscribe(accountId: "acc_#{account.id}", token: user.pubsub_token)
+
+    expect(subscription).to be_confirmed
+    expect(subscription).to have_stream_from(
+      FleexaManager::V1::RealtimeBroadcaster.stream_name(account, user)
+    )
+  end
+
+  it 'rejects a subscription for an account the manager cannot access' do
+    subscribe(accountId: "acc_#{other_account.id}", token: user.pubsub_token)
+
+    expect(subscription).to be_rejected
+  end
+
+  it 'rejects missing authentication' do
+    subscribe(accountId: "acc_#{account.id}")
+
+    expect(subscription).to be_rejected
+  end
+end
diff --git a/spec/services/fleexa_manager/v1/realtime_broadcaster_spec.rb b/spec/services/fleexa_manager/v1/realtime_broadcaster_spec.rb
new file mode 100644
index 0000000..b2c7f3b
--- /dev/null
+++ b/spec/services/fleexa_manager/v1/realtime_broadcaster_spec.rb
@@ -0,0 +1,105 @@
+require 'rails_helper'
+
+RSpec.describe FleexaManager::V1::RealtimeBroadcaster do
+  let(:account) { create(:account) }
+  let(:other_account) { create(:account) }
+  let(:user) { create(:user, account: account, role: :administrator) }
+  let(:other_user) { create(:user, account: other_account, role: :administrator) }
+  let(:inbox) { create(:inbox, account: account) }
+  let(:contact) { create(:contact, account: account) }
+  let(:contact_inbox) { create(:contact_inbox, contact: contact, inbox: inbox) }
+  let(:conversation) do
+    create(:conversation, account: account, inbox: inbox, contact: contact, contact_inbox: contact_inbox, assignee: user)
+  end
+  let(:message) do
+    create(
+      :message,
+      account: account,
+      inbox: inbox,
+      conversation: conversation,
+      sender: contact,
+      message_type: :incoming,
+      content: 'New customer message'
+    )
+  end
+
+  before do
+    user
+    other_user
+    allow_any_instance_of(Conversation).to receive(:can_reply?).and_return(true)
+  end
+
+  it 'broadcasts Manager message DTOs only to visible same-account manager streams' do
+    created_message = message
+    allow(ActionCable.server).to receive(:broadcast)
+
+    described_class.message_created(created_message)
+
+    expect(ActionCable.server).to have_received(:broadcast).with(
+      described_class.stream_name(account, user),
+      hash_including(
+          eventType: 'message.created',
+          accountId: "acc_#{account.id}",
+          payload: hash_including(
+            conversationId: "conv_#{conversation.id}",
+            message: hash_including(id: "msg_#{created_message.id}", text: 'New customer message'),
+            conversation: hash_including(id: "conv_#{conversation.id}", accountId: "acc_#{account.id}"),
+            counters: hash_including(accountId: "acc_#{account.id}")
+          )
+      )
+    )
+    expect(ActionCable.server).not_to have_received(:broadcast).with(
+      described_class.stream_name(other_account, other_user),
+      anything
+    )
+  end
+
+  it 'broadcasts Manager counters updates without exposing another account' do
+    allow(ActionCable.server).to receive(:broadcast)
+
+    described_class.counters_updated(account, users: [user, other_user], source_key: 'spec')
+
+    expect(ActionCable.server).to have_received(:broadcast).with(
+      described_class.stream_name(account, user),
+      hash_including(
+        eventType: 'manager.counters.updated',
+        accountId: "acc_#{account.id}",
+        payload: hash_including(
+          counters: hash_including(
+            accountId: "acc_#{account.id}",
+            counters: include(:unread, :assigned, :unassigned)
+          )
+        )
+      )
+    )
+    expect(ActionCable.server).not_to have_received(:broadcast).with(
+      described_class.stream_name(other_account, other_user),
+      anything
+    )
+  end
+
+  it 'broadcasts assignment/reply-state changes as Manager conversation DTOs' do
+    conversation.update!(waiting_since: Time.current)
+    allow(ActionCable.server).to receive(:broadcast)
+
+    described_class.conversation_updated(
+      conversation,
+      changed_attributes: { 'assignee_id' => [nil, user.id], 'waiting_since' => [nil, Time.current] },
+      event_type: 'conversation.assigned'
+    )
+
+    expect(ActionCable.server).to have_received(:broadcast).with(
+      described_class.stream_name(account, user),
+      hash_including(
+        eventType: 'conversation.assigned',
+        payload: hash_including(
+          conversation: hash_including(
+            id: "conv_#{conversation.id}",
+            assignedManager: hash_including(id: "user_#{user.id}")
+          ),
+          changedFields: include('assignedManager', 'assignee', 'replyState')
+        )
+      )
+    )
+  end
+end
