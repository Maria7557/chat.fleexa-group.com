diff --git a/app/channels/fleexa_manager/v1/realtime_channel.rb b/app/channels/fleexa_manager/v1/realtime_channel.rb
new file mode 100644
index 0000000..0e61bca
--- /dev/null
+++ b/app/channels/fleexa_manager/v1/realtime_channel.rb
@@ -0,0 +1,59 @@
+class FleexaManager::V1::RealtimeChannel < ApplicationCable::Channel
+  MANAGER_SESSION_COOKIE = 'fleexa_manager_session'.freeze
+
+  def subscribed
+    user = current_manager_user
+    account = current_manager_account(user)
+
+    return reject if user.blank? || account.blank?
+    return reject if user.respond_to?(:active_for_authentication?) && !user.active_for_authentication?
+
+    stream_from FleexaManager::V1::RealtimeBroadcaster.stream_name(account, user)
+  rescue ActiveRecord::RecordNotFound
+    reject
+  end
+
+  private
+
+  def current_manager_user
+    @current_manager_user ||= begin
+      session = current_manager_session
+      if session.present?
+        session.user
+      else
+        token = params[:token].presence || params[:pubsub_token].presence
+        token.present? ? User.find_by(pubsub_token: token) : nil
+      end
+    end
+  end
+
+  def current_manager_session
+    @current_manager_session ||= begin
+      if connection.respond_to?(:cookies)
+        raw_token = connection.cookies.encrypted[MANAGER_SESSION_COOKIE].presence
+        session = raw_token.present? ? FleexaManagerSession.authenticate(raw_token) : nil
+        session if session&.user&.active_for_authentication? && session.account&.active?
+      end
+    end
+  rescue ActiveSupport::MessageVerifier::InvalidSignature
+    nil
+  end
+
+  def current_manager_account(user)
+    return if user.blank?
+
+    account_id = stable_account_id(params[:accountId] || params[:account_id])
+    return if account_id.blank?
+
+    account = Account.find_by(id: account_id)
+    return if account.blank? || !account.active?
+    return if current_manager_session.present? && current_manager_session.account_id != account.id
+    return if account.account_users.find_by(user_id: user.id).blank?
+
+    account
+  end
+
+  def stable_account_id(value)
+    value.to_s.match(/\Aacc_(\d+)\z/)&.[](1)&.to_i
+  end
+end
