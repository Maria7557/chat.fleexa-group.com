+  def range_values_for(*keys)
+    raw_value = filter_value(*keys)
+    return range_values_from_hash(raw_value) if raw_value.is_a?(Hash)
+
+    from_keys = keys.flat_map { |key| ["#{key}_from", "#{key}_min", "min_#{key}"] }
+    to_keys = keys.flat_map { |key| ["#{key}_to", "#{key}_max", "max_#{key}"] }
+
+    [
+      filter_value(*from_keys),
+      filter_value(*to_keys)
+    ]
+  end
+
+  def range_values_from_hash(value)
+    value = value.deep_stringify_keys
+    [
+      value['from'] || value['min'] || value['start'],
+      value['to'] || value['max'] || value['end']
+    ]
+  end
+
+  def date_range_for(key)
+    raw_value = filter_value(key)
+    raw_hash = raw_value.is_a?(Hash) ? raw_value.deep_stringify_keys : {}
+    preset = raw_hash['preset'] || filter_value("#{key}_preset")
+    preset = raw_value if raw_value.is_a?(String) && raw_value.match?(/\A[a-z_]+\z/)
+
+    preset_from, preset_to = date_preset_range(preset)
+    from_value = raw_hash['from'] || raw_hash['start'] || filter_value("#{key}_from", "#{key}_start")
+    to_value = raw_hash['to'] || raw_hash['end'] || filter_value("#{key}_to", "#{key}_end")
+
+    [
+      parse_time_filter(from_value) || preset_from,
+      parse_time_filter(to_value, end_of_day: true) || preset_to
+    ]
+  end
+
+  def date_preset_range(preset)
+    today = Time.zone.today
+
+    case preset.to_s
+    when 'today'
+      [today.beginning_of_day, today.end_of_day]
+    when 'yesterday'
+      [1.day.ago.beginning_of_day, 1.day.ago.end_of_day]
+    when 'last_7_days'
+      [6.days.ago.beginning_of_day, today.end_of_day]
+    when 'last_30_days'
+      [29.days.ago.beginning_of_day, today.end_of_day]
+    when 'this_week'
+      [today.beginning_of_week, today.end_of_week]
+    when 'last_week'
+      [1.week.ago.beginning_of_week, 1.week.ago.end_of_week]
+    when 'this_month'
+      [today.beginning_of_month, today.end_of_month]
+    when 'last_month'
+      [1.month.ago.beginning_of_month, 1.month.ago.end_of_month]
+    when 'this_quarter'
+      [today.beginning_of_quarter, today.end_of_quarter]
+    when 'this_year'
+      [today.beginning_of_year, today.end_of_year]
+    else
+      [nil, nil]
+    end
+  end
+
+  def parse_time_filter(value, end_of_day: false)
+    return if value.blank?
+
+    parsed_time = Time.zone.parse(value.to_s)
+    return parsed_time.end_of_day if end_of_day && value.to_s.match?(/\A\d{4}-\d{2}-\d{2}\z/)
+
+    parsed_time
+  rescue ArgumentError, TypeError
+    nil
+  end
+
+  def sort_key
+    requested_key = filter_value('sort', 'sort_by').to_s
+    return requested_key if %w[
+      created_at updated_at title amount rental_start rental_end
+      client_name conversation_display_id
+    ].include?(requested_key)
+
+    'created_at'
+  end
+
+  def sort_direction
+    requested_direction = filter_value('direction', 'sort_direction').to_s.downcase
+    requested_direction == 'asc' ? 'ASC' : 'DESC'
+  end
+
+  def pagination_requested?
+    present_filter_value?(params[:page]) || present_filter_value?(params[:per_page])
+  end
+
+  def page_number
+    [params[:page].to_i, 1].max
+  end
+
+  def per_page
+    requested_per_page = params[:per_page].to_i
+    requested_per_page = DEFAULT_PER_PAGE if requested_per_page <= 0
+    [requested_per_page, MAX_PER_PAGE].min
+  end
+
+  def include_meta?
+    truthy_param?(params[:include_meta]) || truthy_param?(params[:pipeline])
+  end
+
+  def truthy_param?(value)
+    %w[1 true yes on].include?(value.to_s.downcase)
+  end
+
+  def present_filter_value?(value)
+    return false if value.nil?
+    return false if value.respond_to?(:empty?) && value.empty?
+
+    true
+  end
+
+  def array_param(value)
+    case value
+    when Array
+      value
+    when String
+      value.split(',')
+    else
+      [value]
+    end.filter_map do |item|
+      next if item.nil?
