+++ b/app/models/crm_pipeline_stage_required_field.rb
@@ -0,0 +1,25 @@
+class CrmPipelineStageRequiredField < ApplicationRecord
+  belongs_to :account
+  belongs_to :stage, class_name: 'CrmPipelineStage'
+  belongs_to :field_definition, class_name: 'CrmDealFieldDefinition'
+
+  scope :for_account, ->(account_id) { where(account_id: account_id) }
+
+  validates :field_definition_id, uniqueness: { scope: :stage_id }
+  validate :stage_belongs_to_account
+  validate :field_definition_belongs_to_account
+
+  private
+
+  def stage_belongs_to_account
+    return if stage.blank? || account_id.blank? || stage.account_id == account_id
+
+    errors.add(:stage, 'must belong to the same account')
+  end
+
+  def field_definition_belongs_to_account
+    return if field_definition.blank? || account_id.blank? || field_definition.account_id == account_id
+
+    errors.add(:field_definition, 'must belong to the same account')
+  end
+end
