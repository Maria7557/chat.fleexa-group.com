+class Api::V1::Accounts::Crm::DealFieldsController < Api::V1::Accounts::BaseController
+  before_action :check_authorization
+  before_action :set_field_definition, only: [:update, :destroy]
+
+  def index
+    render json: fields_payload
+  end
+
+  def create
+    attrs = field_params.merge(
+      account: Current.account,
+      is_system: false,
+      storage_type: 'custom_attribute'
+    )
+    attrs[:options] = [] if attrs[:field_type] != 'select'
+    field = field_scope.new(attrs)
+    field.key = generated_field_key(field.label) if field.key.blank?
+    field.position = next_position if field.position.blank? || field.position.zero?
+    field.save!
+
+    render json: field_payload(field)
+  end
+
+  def update
+    return render_validation_error('system fields cannot be updated') if @field_definition.is_system?
+
+    @field_definition.update!(field_update_params)
+
+    render json: field_payload(@field_definition)
+  end
+
+  def destroy
+    return render_validation_error('system fields cannot be deleted') if @field_definition.is_system?
+
+    ActiveRecord::Base.transaction do
+      stage_required_field_scope.where(field_definition_id: @field_definition.id).delete_all
+      @field_definition.update!(is_active: false)
+    end
+
+    head :ok
+  end
+
+  def stage_requirements
+    stage = stage_scope.find(params.require(:stage_id))
+    fields = required_field_definitions
+    return if performed?
+
+    ActiveRecord::Base.transaction do
+      stage_required_field_scope.where(stage_id: stage.id).delete_all
+      fields.each do |field|
+        CrmPipelineStageRequiredField.create!(
+          account: Current.account,
+          stage: stage,
+          field_definition: field
+        )
+      end
+    end
+
+    render json: fields_payload
+  end
+
+  private
+
+  def field_scope
+    CrmDealFieldDefinition.for_account(Current.account.id)
+  end
+
+  def stage_scope
+    CrmPipelineStage.for_account(Current.account.id)
+  end
+
+  def stage_required_field_scope
+    CrmPipelineStageRequiredField.for_account(Current.account.id)
+  end
+
+  def set_field_definition
+    @field_definition = field_scope.find(params[:id])
+  end
+
+  def field_params
+    params.require(:deal_field).permit(
+      :key,
+      :label,
+      :field_type,
+      :position,
+      :is_active,
+      options: []
+    )
+  end
+
+  def field_update_params
+    field_params.except(:key, :is_active).tap do |attrs|
+      attrs[:options] = [] if attrs.key?(:field_type) && attrs[:field_type] != 'select'
+    end
+  end
+
+  def fields_payload
+    {
+      fields: all_fields.map { |field| field_payload(field) },
+      requirements: requirements_payload
+    }
+  end
+
+  def all_fields
+    field_scope.active
+  end
+
+  def field_payload(field)
+    {
+      id: field.id,
+      key: field.key,
+      label: field.label,
+      field_type: field.field_type,
+      storage_type: field.storage_type,
+      position: field.position,
+      options: field.options || [],
+      source: source_for(field),
+      is_system: field.is_system,
+      is_active: field.is_active,
+      required_by_stage_ids: required_stage_ids_for(field)
+    }
+  end
+
+  def source_for(field)
+    field.storage_type == 'system_column' ? 'system' : 'custom'
+  end
+
+  def requirements_payload
+    stage_required_field_scope.includes(:field_definition).group_by(&:stage_id).transform_values do |requirements|
+      requirements.map { |requirement| requirement.field_definition.key }
+    end
+  end
+
+  def required_stage_ids_for(field)
+    stage_required_field_scope.select do |requirement|
+      requirement.field_definition_id == field.id
+    end.map(&:stage_id)
+  end
+
+  def required_field_definitions
+    requested_keys = Array(params[:required_field_keys]).map(&:to_s).uniq
+    fields_by_key = field_scope.active.where(key: requested_keys).index_by(&:key)
+    invalid_keys = requested_keys - fields_by_key.keys
+    return fields_by_key.values_at(*requested_keys) if invalid_keys.blank?
+
+    render_validation_error("unknown field keys: #{invalid_keys.join(', ')}")
+  end
+
+  def generated_field_key(label)
+    label.to_s.strip.downcase.gsub(/[^a-z0-9]+/, '_').gsub(/\A_+|_+\z/, '')
+  end
+
+  def next_position
+    (field_scope.maximum(:position) || 100) + 10
+  end
+
+  def render_validation_error(message)
+    render json: { error: message }, status: :unprocessable_entity
+  end
+
+  def check_authorization
+    raise Pundit::NotAuthorizedError unless Current.account_user.administrator?
+  end
+end
