+  def merged_deal_attributes(deal, attrs)
+    deal.attributes.merge(attrs.to_h.stringify_keys).tap do |merged_attrs|
+      merged_attrs['custom_attributes'] = normalized_custom_attributes(attrs[:custom_attributes]) if attrs.key?(:custom_attributes)
+    end
+  end
+
+  def missing_required_fields_for(stage, attrs)
+    required_field_definitions_for(stage).filter_map do |field|
+      next if field_present?(attrs, field)
+
+      field_payload_for(field)
+    end
+  end
+
+  def required_field_definitions_for(stage)
+    CrmDealFieldDefinition
+      .for_account(Current.account.id)
+      .active
+      .joins(:crm_pipeline_stage_required_fields)
+      .where(crm_pipeline_stage_required_fields: {
+        account_id: Current.account.id,
+        stage_id: stage.id
+      })
+  end
+
+  def field_present?(attrs, field)
+    value = field_value(attrs, field)
+    return !value.nil? if value == false
+
+    value.present?
+  end
+
+  def field_value(attrs, field)
+    key = field.key.to_s
+    return attribute_value(attrs, key) if field.storage_type == 'system_column'
+
+    normalized_custom_attributes(attribute_value(attrs, 'custom_attributes'))[key]
+  end
+
+  def attribute_value(attrs, key)
+    return attrs[key] if attrs.respond_to?(:key?) && attrs.key?(key)
+    return attrs[key.to_sym] if attrs.respond_to?(:key?) && attrs.key?(key.to_sym)
+
+    nil
+  end
+
+  def field_payload_for(field)
+    {
+      id: field.id,
+      key: field.key,
+      label: field.label,
+      field_type: field.field_type,
+      storage_type: field.storage_type
+    }
+  end
+
+  def normalized_custom_attributes(custom_attributes)
+    return custom_attributes.to_h.stringify_keys if custom_attributes.respond_to?(:to_h)
+    return custom_attributes.stringify_keys if custom_attributes.is_a?(Hash)
+
+    {}
+  end
+
+  def render_missing_required_fields(missing_required_fields)
+    render json: {
+      error: 'Required deal fields are missing for this stage',
+      missing_required_fields: missing_required_fields
+    }, status: :unprocessable_entity
+  end
