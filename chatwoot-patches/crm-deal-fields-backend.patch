diff --git a/app/models/crm_deal_field_definition.rb b/app/models/crm_deal_field_definition.rb
new file mode 100644
index 0000000..e8c3ab8
--- /dev/null
+++ b/app/models/crm_deal_field_definition.rb
@@ -0,0 +1,49 @@
+class CrmDealFieldDefinition < ApplicationRecord
+  FIELD_TYPES = %w[text number date boolean select].freeze
+  STORAGE_TYPES = %w[system_column custom_attribute].freeze
+
+  belongs_to :account
+  has_many :crm_pipeline_stage_required_fields,
+           foreign_key: :field_definition_id,
+           dependent: :destroy
+
+  scope :for_account, ->(account_id) { where(account_id: account_id) }
+  scope :active, -> { where(is_active: true).order(:position, :id) }
+
+  before_validation :normalize_key
+  before_validation :ensure_options
+  before_validation :ensure_storage_type
+
+  validates :key,
+            presence: true,
+            uniqueness: { scope: :account_id },
+            format: { with: /\A[a-z][a-z0-9_]*\z/ },
+            exclusion: { in: CrmDeal::SYSTEM_FIELD_KEYS },
+            unless: :is_system?
+  validates :label, presence: true
+  validates :field_type, inclusion: { in: FIELD_TYPES }
+  validates :storage_type, inclusion: { in: STORAGE_TYPES }
+  validate :storage_type_matches_system_flag
+
+  private
+
+  def normalize_key
+    self.key = key.to_s.strip.downcase.gsub(/[^a-z0-9_]+/, '_').gsub(/\A_+|_+\z/, '') if key.present?
+  end
+
+  def ensure_options
+    self.options = [] unless options.is_a?(Array)
+  end
+
+  def ensure_storage_type
+    self.storage_type ||= is_system? ? 'system_column' : 'custom_attribute'
+  end
+
+  def storage_type_matches_system_flag
+    if is_system? && storage_type != 'system_column'
+      errors.add(:storage_type, 'must be system_column for system fields')
+    elsif !is_system? && storage_type != 'custom_attribute'
+      errors.add(:storage_type, 'must be custom_attribute for custom fields')
+    end
+  end
+end
diff --git a/app/models/crm_pipeline_stage_required_field.rb b/app/models/crm_pipeline_stage_required_field.rb
