+    if (!append) stages.value = stageResponse.data || [];
+
+    const responsePayload = append
+      ? normalizedDealResponse(dealResponse, requestPage)
+      : await loadAllDealPages(dealResponse);
+
+    deals.value = append
+      ? [...deals.value, ...responsePayload.deals]
+      : responsePayload.deals;
+    currentPage.value = responsePayload.meta.page ?? requestPage;
+    pipelineMeta.value = {
+      total_count: responsePayload.meta.total_count || deals.value.length,
+      total_amount: responsePayload.meta.total_amount ?? totalFromDeals(),
+      total_debt_amount: responsePayload.meta.total_debt_amount ?? 0,
+      page: currentPage.value,
+      per_page: responsePayload.meta.per_page ?? DEALS_PER_PAGE,
+      has_more: Boolean(responsePayload.meta.has_more),
+    };
+    pruneSelectedDealIds();
+  } catch (error) {
+    setError(error);
+  } finally {
+    isLoading.value = false;
+    isLoadingMore.value = false;
+  }
+};
