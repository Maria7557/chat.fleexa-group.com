diff --git a/app/javascript/dashboard/routes/dashboard/crm/Pipeline.vue b/app/javascript/dashboard/routes/dashboard/crm/Pipeline.vue
new file mode 100644
index 0000000..22e2836
--- /dev/null
+++ b/app/javascript/dashboard/routes/dashboard/crm/Pipeline.vue
@@ -0,0 +1,1720 @@
+<script setup>
+import { computed, onBeforeUnmount, ref, watch } from 'vue';
+import { useRoute, useRouter } from 'vue-router';
+
+import CrmPipelineAPI from 'dashboard/api/crmPipeline';
+import Button from 'dashboard/components-next/button/Button.vue';
+import Spinner from 'dashboard/components-next/spinner/Spinner.vue';
+import { useAccount } from 'dashboard/composables/useAccount';
+
+const route = useRoute();
+const router = useRouter();
+const { accountId } = useAccount();
+
+const buildDealForm = () => ({
+  title: '',
+  client_phone: '',
+  car_model: '',
+  rental_start: '',
+  rental_end: '',
+  amount: '',
+  booking_id: '',
+});
+
+const optionalDealFields = [
+  'client_phone',
+  'car_model',
+  'rental_start',
+  'rental_end',
+  'amount',
+  'booking_id',
+];
+
+const buildEmptyFilters = () => ({
+  q: '',
+  assignee: '',
+  stageId: '',
+  createdPreset: '',
+  createdFrom: '',
+  createdTo: '',
+  inboxId: '',
+  fieldFilters: {},
+});
+
+const stages = ref([]);
+const deals = ref([]);
+const fieldDefinitions = ref([]);
+const pipelineMeta = ref({
+  total_count: 0,
+  total_amount: 0,
+  total_debt_amount: 0,
+});
+const isLoading = ref(false);
+const isLoadingFields = ref(false);
+const errorMessage = ref('');
+const activeStageId = ref(null);
+const newDealForm = ref(buildDealForm());
+const savingStageId = ref(null);
+const draggingDealId = ref(null);
+const selectedDeal = ref(null);
+const appliedFilters = ref(buildEmptyFilters());
+const draftFilters = ref(buildEmptyFilters());
+const isFilterPanelOpen = ref(false);
+const isExportModalOpen = ref(false);
+const isExporting = ref(false);
+const exportScope = ref('all');
+const exportFormat = ref('csv');
+const viewMode = ref('kanban');
+const filterShellRef = ref(null);
+
+const dateRangeFilters = [
+  { key: '', label: 'Any date' },
+  { key: 'today', label: 'Today' },
+  { key: 'yesterday', label: 'Yesterday' },
+  { key: 'last_7_days', label: 'Last 7 days' },
+  { key: 'this_week', label: 'This week' },
+  { key: 'last_week', label: 'Last week' },
+  { key: 'this_month', label: 'This month' },
+  { key: 'last_month', label: 'Last month' },
+  { key: 'this_quarter', label: 'Quarter' },
+];
+
+const moneyFormatter = new Intl.NumberFormat('en-AE', {
+  style: 'currency',
+  currency: 'AED',
+});
+
+const dateFormatter = new Intl.DateTimeFormat('en-GB', {
+  day: '2-digit',
+  month: 'short',
+  year: 'numeric',
+});
+
+const cloneFilters = filters => ({
+  ...buildEmptyFilters(),
+  ...(filters || {}),
+  fieldFilters: { ...(filters?.fieldFilters || {}) },
+});
+
+const orderedStages = computed(() => {
+  return [...stages.value].sort((a, b) => a.position - b.position);
+});
+
+const dealsByStage = computed(() => {
+  return deals.value.reduce((memo, deal) => {
+    const stageDeals = memo[deal.stage_id] || [];
+    stageDeals.push(deal);
+    memo[deal.stage_id] = stageDeals;
+    return memo;
+  }, {});
+});
+
+const dealsForStage = stageId => dealsByStage.value[stageId] || [];
+
+const amountValue = amount => {
+  if (amount === null || amount === undefined || amount === '') return 0;
+  const value = Number(amount);
+  return Number.isFinite(value) ? value : 0;
+};
+
+const totalFromDeals = () => {
+  return deals.value.reduce((sum, deal) => sum + amountValue(deal.amount), 0);
+};
+
+const pipelineTotalCount = computed(() => {
+  return pipelineMeta.value?.total_count ?? deals.value.length;
+});
+
+const pipelineTotalAmount = computed(() => {
+  return pipelineMeta.value?.total_amount ?? totalFromDeals();
+});
+
+const pipelineSummary = computed(() => {
+  const amount = formatAmount(pipelineTotalAmount.value);
+  return `${pipelineTotalCount.value} deals · ${amount || formatAmount(0)}`;
+});
+
+const dateFilterOptions = computed(() => {
+  return dateRangeFilters;
+});
+
+const assigneeFilterOptions = computed(() => {
+  const users = new Map();
+
+  deals.value.forEach(deal => {
+    const user = deal.assigned_user;
+    if (!user?.id) return;
+    users.set(String(user.id), user.name || user.email || `#${user.id}`);
+  });
+
+  return [
+    { value: '', label: 'All operators' },
+    { value: 'me', label: 'Me' },
+    { value: 'unassigned', label: 'Unassigned' },
+    ...[...users.entries()].map(([value, label]) => ({
+      value,
+      label,
+    })),
+  ];
+});
+
+const stageFilterOptions = computed(() => [
+  { value: '', label: 'All stages' },
+  ...orderedStages.value.map(stage => ({
+    value: String(stage.id),
+    label: stage.name,
+  })),
+]);
+
+const inboxFilterOptions = computed(() => {
+  const inboxes = new Set();
+
+  deals.value.forEach(deal => {
+    const inboxId = deal.conversation?.inbox_id;
+    if (inboxId) inboxes.add(String(inboxId));
+  });
+
+  return [
+    { value: '', label: 'All inboxes' },
+    ...[...inboxes]
+      .sort((left, right) => Number(left) - Number(right))
+      .map(inboxId => ({ value: inboxId, label: `Inbox #${inboxId}` })),
+  ];
+});
+
+const fieldDefinitionFor = key => {
+  return fieldDefinitions.value.find(field => field.key === key);
+};
+
+const isSystemField = field => {
+  return field.storage_type === 'system_column' || field.source === 'system';
+};
+
+const customAttributeValue = (deal, key) => {
+  return deal.custom_attributes?.[key] ?? deal[key] ?? '';
+};
+
+const valueForField = (deal, field) => {
+  return isSystemField(field) ? deal[field.key] : customAttributeValue(deal, field.key);
+};
+
+const hasDisplayValue = value => {
+  return value !== null && value !== undefined && value !== '';
+};
+
+const canonicalFilterFieldKey = field => {
+  const key = field.key.toString();
+  return key === 'source_requect' ? 'source_request' : key;
+};
+
+const fieldActualValueCount = field => {
+  const values = new Set();
+
+  deals.value.forEach(deal => {
+    const value = valueForField(deal, field);
+    if (hasDisplayValue(value)) values.add(String(value));
+  });
+
+  return values.size;
+};
+
+const fieldFilterPriority = field => {
+  const options = Array.isArray(field.options) ? field.options.length : 0;
+  const sourceRequestCompatibilityBonus = field.key === 'source_requect' ? 10000 : 0;
+  return sourceRequestCompatibilityBonus + fieldActualValueCount(field) * 100 + options;
+};
+
+const filterFieldDefinitions = computed(() => {
+  const fieldsByCanonicalKey = new Map();
+
+  [...fieldDefinitions.value]
+    .filter(field => field.is_active !== false)
+    .sort((a, b) => a.position - b.position)
+    .forEach(field => {
+      const canonicalKey = canonicalFilterFieldKey(field);
+      const existingField = fieldsByCanonicalKey.get(canonicalKey);
+
+      if (!existingField || fieldFilterPriority(field) > fieldFilterPriority(existingField)) {
+        fieldsByCanonicalKey.set(canonicalKey, field);
+      }
+    });
+
+  return [...fieldsByCanonicalKey.values()].sort((a, b) => a.position - b.position);
+});
+
+const uniqueDealValuesForField = field => {
+  const values = new Set();
+
+  deals.value.forEach(deal => {
+    const value = valueForField(deal, field);
+    if (hasDisplayValue(value)) values.add(String(value));
+  });
+
+  return [...values].sort();
+};
+
+const optionsForField = field => {
+  const configuredOptions = Array.isArray(field.options) ? field.options : [];
+  const actualValues = uniqueDealValuesForField(field);
+  const values = [...new Set([...actualValues, ...configuredOptions].map(String))];
+
+  return [
+    { value: '', label: `Any ${field.label.toLowerCase()}` },
+    ...values.map(value => ({ value: String(value), label: String(value) })),
+  ];
+};
+
+const datePresetLabel = key => {
+  return dateRangeFilters.find(item => item.key === key)?.label || '';
+};
+
+const assigneeLabel = value => {
+  return assigneeFilterOptions.value.find(item => item.value === value)?.label || value;
+};
+
+const stageLabel = value => {
+  return stageFilterOptions.value.find(item => item.value === String(value))?.label || value;
+};
+
+const inboxLabel = value => {
+  return inboxFilterOptions.value.find(item => item.value === value)?.label || `Inbox #${value}`;
+};
+
+const formatDateRangeLabel = (from, to) => {
+  if (from && to) return `${formatDate(from)} - ${formatDate(to)}`;
+  if (from) return `from ${formatDate(from)}`;
+  if (to) return `to ${formatDate(to)}`;
+  return '';
+};
+
+const fieldFilterState = (filters, field) => {
+  return filters.fieldFilters?.[field.key] || {};
+};
+
+const setDraftFieldFilter = (field, value) => {
+  draftFilters.value.fieldFilters = {
+    ...(draftFilters.value.fieldFilters || {}),
+    [field.key]: {
+      ...fieldFilterState(draftFilters.value, field),
+      ...value,
+    },
+  };
+};
+
+const selectOptionsForField = field => {
+  if (field.field_type === 'boolean') {
+    return [
+      { value: '', label: `Any ${field.label.toLowerCase()}` },
+      { value: 'true', label: 'Yes' },
+      { value: 'false', label: 'No' },
+    ];
+  }
+
+  return optionsForField(field);
+};
+
+const inputTypeForField = field => {
+  if (field.field_type === 'date') return 'date';
+  if (field.field_type === 'number') return 'number';
+  return 'text';
+};
+
+const stepForField = field => {
+  return field.field_type === 'number' ? '0.01' : undefined;
+};
+
+const isTextFilterField = field => {
+  return !['select', 'boolean', 'date', 'number'].includes(field.field_type);
+};
+
+const isRangeFilterField = field => {
+  return ['date', 'number'].includes(field.field_type);
+};
+
+const hasFieldFilterValue = filter => {
+  return hasDisplayValue(filter.value) || hasDisplayValue(filter.from) || hasDisplayValue(filter.to);
+};
+
+const fieldFilterChipLabel = (field, filter) => {
+  if (field.field_type === 'date') {
+    return `${field.label}: ${formatDateRangeLabel(filter.from, filter.to)}`;
+  }
+
+  if (field.field_type === 'number') {
+    return `${field.label}: ${filter.from || '0'}-${filter.to || 'any'}`;
+  }
+
+  if (field.field_type === 'boolean') {
+    return `${field.label}: ${filter.value === 'true' ? 'Yes' : 'No'}`;
+  }
+
+  return `${field.label}: ${filter.value}`;
+};
+
+const activeFilterChips = computed(() => {
+  const filters = appliedFilters.value;
+  const chips = [];
+
+  if (filters.q) chips.push({ key: 'q', label: `Search: ${filters.q}` });
+  if (filters.stageId) {
+    chips.push({ key: 'stageId', label: `Stage: ${stageLabel(filters.stageId)}` });
+  }
+  if (filters.assignee) {
+    chips.push({ key: 'assignee', label: `Operator: ${assigneeLabel(filters.assignee)}` });
+  }
+  if (filters.createdPreset) {
+    chips.push({ key: 'created', label: datePresetLabel(filters.createdPreset) });
+  } else if (filters.createdFrom || filters.createdTo) {
+    chips.push({ key: 'created', label: formatDateRangeLabel(filters.createdFrom, filters.createdTo) });
+  }
+  if (filters.inboxId) chips.push({ key: 'inboxId', label: `Inbox: ${inboxLabel(filters.inboxId)}` });
+
+  Object.entries(filters.fieldFilters || {}).forEach(([key, filter]) => {
+    if (!hasFieldFilterValue(filter)) return;
+
+    const field = fieldDefinitionFor(key);
+    if (!field) return;
+
+    chips.push({ key: `field:${key}`, label: fieldFilterChipLabel(field, filter) });
+  });
+
+  return chips;
+});
+
+const hasActiveFilters = computed(() => activeFilterChips.value.length > 0);
+
+const customFiltersForRequest = filters => {
+  const custom = {};
+
+  Object.entries(filters.fieldFilters || {}).forEach(([key, filter]) => {
+    if (!hasFieldFilterValue(filter)) return;
+
+    const field = fieldDefinitionFor(key);
+    if (!field || isSystemField(field)) return;
+
+    if (isRangeFilterField(field)) {
+      custom[key] = {
+        from: filter.from || '',
+        to: filter.to || '',
+      };
+      return;
+    }
+
+    custom[key] = filter.value;
+  });
+
+  return custom;
+};
+
+const applySystemFieldFilter = (params, field, filter) => {
+  if (!hasFieldFilterValue(filter)) return;
+
+  if (field.field_type === 'date') {
+    if (filter.from) params[`${field.key}_from`] = filter.from;
+    if (filter.to) params[`${field.key}_to`] = filter.to;
+    return;
+  }
+
+  if (field.field_type === 'number') {
+    const rangeKey = field.key === 'debt_amount' ? 'debt' : field.key;
+    if (filter.from) params[`${rangeKey}_min`] = filter.from;
+    if (filter.to) params[`${rangeKey}_max`] = filter.to;
+    return;
+  }
+
+  if (filter.value) params[field.key] = filter.value;
+};
+
+const dealRequestParams = computed(() => {
+  const filters = appliedFilters.value;
+  const params = {
+    include_meta: 1,
+    per_page: 100,
+  };
+
+  if (filters.q) params.q = filters.q;
+  if (filters.stageId) params.stage_id = filters.stageId;
+  if (filters.createdPreset) params.created_at_preset = filters.createdPreset;
+  if (filters.createdFrom) params.created_at_from = filters.createdFrom;
+  if (filters.createdTo) params.created_at_to = filters.createdTo;
+  if (filters.inboxId) params.inbox_id = filters.inboxId;
+
+  if (filters.assignee === 'me') {
+    params.assigned_to = 'me';
+  } else if (filters.assignee === 'unassigned') {
+    params.only_unassigned = 1;
+  } else if (filters.assignee) {
+    params.assigned_to = filters.assignee;
+  }
+
+  Object.entries(filters.fieldFilters || {}).forEach(([key, filter]) => {
+    const field = fieldDefinitionFor(key);
+    if (!field || !isSystemField(field)) return;
+
+    applySystemFieldFilter(params, field, filter);
+  });
+
+  const customFilters = customFiltersForRequest(filters);
+  if (Object.keys(customFilters).length) {
+    params.filters = JSON.stringify({ custom_attributes: customFilters });
+  }
+
+  return params;
+});
+
+const exportRequestParams = () => {
+  if (exportScope.value !== 'filtered') return {};
+
+  const params = { ...dealRequestParams.value };
+  delete params.include_meta;
+  delete params.per_page;
+  return params;
+};
+
+const routeValue = value => {
+  return Array.isArray(value) ? value[0] : value;
+};
+
+const setQueryFieldFilter = (filters, key, value, rangePart = 'value') => {
+  if (!hasDisplayValue(value)) return;
+
+  filters.fieldFilters[key] = {
+    ...(filters.fieldFilters[key] || {}),
+    [rangePart]: value,
+  };
+};
+
+const hydrateLegacyFieldQuery = (filters, query) => {
+  const legacyFieldMap = {
+    source_request: 'source_requect',
+    car_type: 'car_type',
+    client_status: 'client_status',
+    language: 'language',
+    rental_from: 'rental_start',
+    rental_to: 'rental_end',
+    amount_min: 'amount',
+    amount_max: 'amount',
+    debt_min: 'debt_amount',
+    debt_max: 'debt_amount',
+  };
+
+  Object.entries(legacyFieldMap).forEach(([queryKey, fieldKey]) => {
+    const value = routeValue(query[queryKey]);
+    if (!hasDisplayValue(value)) return;
+
+    if (queryKey.endsWith('_from') || queryKey.endsWith('_min')) {
+      setQueryFieldFilter(filters, fieldKey, value, 'from');
+    } else if (queryKey.endsWith('_to') || queryKey.endsWith('_max')) {
+      setQueryFieldFilter(filters, fieldKey, value, 'to');
+    } else {
+      setQueryFieldFilter(filters, fieldKey, value);
+    }
+  });
+};
+
+const filtersFromQuery = query => {
+  const filters = buildEmptyFilters();
+
+  filters.q = routeValue(query.q) || '';
+  filters.assignee =
+    routeValue(query.assignee) ||
+    routeValue(query.assigned_to) ||
+    (routeValue(query.only_unassigned) ? 'unassigned' : '');
+  filters.stageId = routeValue(query.stage_id) || '';
+  filters.createdPreset = routeValue(query.created_preset) || routeValue(query.created_at_preset) || '';
+  filters.createdFrom = routeValue(query.created_from) || routeValue(query.created_at_from) || '';
+  filters.createdTo = routeValue(query.created_to) || routeValue(query.created_at_to) || '';
+  filters.inboxId = routeValue(query.inbox_id) || '';
+
+  Object.entries(query).forEach(([queryKey, rawValue]) => {
+    if (!queryKey.startsWith('field_')) return;
+
+    const value = routeValue(rawValue);
+    const rawFieldKey = queryKey.slice(6);
+    if (rawFieldKey.endsWith('_from')) {
+      setQueryFieldFilter(filters, rawFieldKey.slice(0, -5), value, 'from');
+    } else if (rawFieldKey.endsWith('_to')) {
+      setQueryFieldFilter(filters, rawFieldKey.slice(0, -3), value, 'to');
+    } else {
+      setQueryFieldFilter(filters, rawFieldKey, value);
+    }
+  });
+
+  hydrateLegacyFieldQuery(filters, query);
+
+  return filters;
+};
+
+const filtersToQuery = filters => {
+  const query = {};
+  const entries = {
+    q: filters.q,
+    assignee: filters.assignee,
+    stage_id: filters.stageId,
+    created_preset: filters.createdPreset,
+    created_from: filters.createdFrom,
+    created_to: filters.createdTo,
+    inbox_id: filters.inboxId,
+  };
+
+  Object.entries(entries).forEach(([key, value]) => {
+    if (value !== undefined && value !== null && value !== '') query[key] = value;
+  });
+
+  Object.entries(filters.fieldFilters || {}).forEach(([fieldKey, filter]) => {
+    if (hasDisplayValue(filter.value)) query[`field_${fieldKey}`] = filter.value;
+    if (hasDisplayValue(filter.from)) query[`field_${fieldKey}_from`] = filter.from;
+    if (hasDisplayValue(filter.to)) query[`field_${fieldKey}_to`] = filter.to;
+  });
+
+  return query;
+};
+
+const updateRouteQuery = filters => {
+  return router.replace({
+    name: 'crm_pipeline_index',
+    params: { accountId: accountId.value },
+    query: filtersToQuery(filters),
+  });
+};
+
+const resetFilterKey = (filters, key) => {
+  if (key.startsWith('field:')) {
+    const fieldKey = key.slice(6);
+    filters.fieldFilters = { ...(filters.fieldFilters || {}) };
+    delete filters.fieldFilters[fieldKey];
+    return;
+  }
+
+  if (key === 'created') {
+    filters.createdPreset = '';
+    filters.createdFrom = '';
+    filters.createdTo = '';
+    return;
+  }
+
+  filters[key] = '';
+};
+
+const commitFilters = async (filters, options = {}) => {
+  const nextFilters = cloneFilters(filters);
+  appliedFilters.value = nextFilters;
+  draftFilters.value = cloneFilters(nextFilters);
+  await updateRouteQuery(nextFilters);
+  await fetchPipeline();
+  if (options.closePanel) isFilterPanelOpen.value = false;
+};
+
+const openFilterPanel = () => {
+  if (!isFilterPanelOpen.value) {
+    draftFilters.value = cloneFilters(appliedFilters.value);
+  }
+  isFilterPanelOpen.value = true;
+};
+
+const closeFilterPanel = () => {
+  draftFilters.value = cloneFilters(appliedFilters.value);
+  isFilterPanelOpen.value = false;
+};
+
+const handleOutsideClick = event => {
+  if (!isFilterPanelOpen.value) return;
+  if (filterShellRef.value?.contains(event.target)) return;
+  closeFilterPanel();
+};
+
+document.addEventListener('click', handleOutsideClick);
+
+onBeforeUnmount(() => {
+  document.removeEventListener('click', handleOutsideClick);
+});
+
+const applyDraftFilters = () => {
+  commitFilters(draftFilters.value, { closePanel: true });
+};
+
+const resetFilters = () => {
+  commitFilters(buildEmptyFilters(), { closePanel: true });
+};
+
+const applySearch = () => {
+  commitFilters({
+    ...appliedFilters.value,
+    q: draftFilters.value.q.trim(),
+  });
+};
+
+const clearSearch = () => {
+  commitFilters({
+    ...appliedFilters.value,
+    q: '',
+  });
+};
+
+const openExportModal = () => {
+  exportScope.value = hasActiveFilters.value ? 'filtered' : 'all';
+  exportFormat.value = 'csv';
+  isFilterPanelOpen.value = false;
+  isExportModalOpen.value = true;
+};
+
+const closeExportModal = () => {
+  if (isExporting.value) return;
+
+  isExportModalOpen.value = false;
+};
+
+const exportFilename = response => {
+  const disposition = response.headers?.['content-disposition'] || '';
+  const match = disposition.match(/filename="?([^"]+)"?/i);
+  return match?.[1] || `fleexa_crm_deals_${new Date().toISOString().slice(0, 10)}.csv`;
+};
+
+const downloadExportBlob = response => {
+  const blob = new Blob([response.data], { type: 'text/csv;charset=utf-8' });
+  const url = window.URL.createObjectURL(blob);
+  const link = document.createElement('a');
+  link.href = url;
+  link.download = exportFilename(response);
+  document.body.appendChild(link);
+  link.click();
+  document.body.removeChild(link);
+  window.URL.revokeObjectURL(url);
+};
+
+const exportDeals = async () => {
+  if (exportFormat.value !== 'csv') return;
+
+  isExporting.value = true;
+  errorMessage.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.exportDeals(exportRequestParams());
+    downloadExportBlob(response);
+    isExportModalOpen.value = false;
+  } catch (error) {
+    setError(error);
+  } finally {
+    isExporting.value = false;
+  }
+};
+
+const removeFilterChip = chip => {
+  const filters = cloneFilters(appliedFilters.value);
+  resetFilterKey(filters, chip.key);
+  commitFilters(filters);
+};
+
+const stageTotal = stageId => {
+  return dealsForStage(stageId).reduce((sum, deal) => {
+    return sum + amountValue(deal.amount);
+  }, 0);
+};
+
+const stageName = stageId => {
+  return stages.value.find(stage => stage.id === stageId)?.name || '';
+};
+
+const selectedStageName = computed(() => {
+  return selectedDeal.value ? stageName(selectedDeal.value.stage_id) : '';
+});
+
+const setError = error => {
+  errorMessage.value = error?.response?.data?.error || error?.message || 'Request failed';
+};
+
+const loadDealFields = async () => {
+  if (typeof CrmPipelineAPI.getDealFields !== 'function') return;
+
+  isLoadingFields.value = true;
+  try {
+    const response = await CrmPipelineAPI.getDealFields();
+    fieldDefinitions.value = response.data?.fields || [];
+  } catch {
+    fieldDefinitions.value = [];
+  } finally {
+    isLoadingFields.value = false;
+  }
+};
+
+const fetchPipeline = async () => {
+  isLoading.value = true;
+  errorMessage.value = '';
+
+  try {
+    await loadDealFields();
+    const [stageResponse, dealResponse] = await Promise.all([
+      CrmPipelineAPI.getStages(),
+      CrmPipelineAPI.getDeals(dealRequestParams.value),
+    ]);
+
+    stages.value = stageResponse.data || [];
+    const payload = dealResponse.data || {};
+    if (Array.isArray(payload)) {
+      deals.value = payload;
+      pipelineMeta.value = {
+        total_count: payload.length,
+        total_amount: totalFromDeals(),
+        total_debt_amount: 0,
+      };
+      return;
+    }
+
+    deals.value = payload.data || [];
+    pipelineMeta.value = {
+      total_count: payload?.meta?.total_count ?? deals.value.length,
+      total_amount: payload?.meta?.total_amount ?? totalFromDeals(),
+      total_debt_amount: payload?.meta?.total_debt_amount ?? 0,
+    };
+  } catch (error) {
+    setError(error);
+  } finally {
+    isLoading.value = false;
+  }
+};
+
+const initializePipeline = () => {
+  const initialFilters = filtersFromQuery(route.query);
+  appliedFilters.value = cloneFilters(initialFilters);
+  draftFilters.value = cloneFilters(initialFilters);
+  fetchPipeline();
+};
+
+const openNewDealForm = stageId => {
+  activeStageId.value = stageId;
+  newDealForm.value = buildDealForm();
+};
+
+const closeNewDealForm = () => {
+  activeStageId.value = null;
+  newDealForm.value = buildDealForm();
+};
+
+const dealPayloadFromForm = stage => {
+  const title = newDealForm.value.title.trim();
+  if (!title) return null;
+
+  const deal = {
+    title,
+    stage_id: stage.id,
+  };
+
+  optionalDealFields.forEach(field => {
+    const value = newDealForm.value[field];
+    if (value !== null && value !== undefined && String(value).trim() !== '') {
+      deal[field] = value;
+    }
+  });
+
+  return deal;
+};
+
+const createDeal = async stage => {
+  const deal = dealPayloadFromForm(stage);
+  if (!deal) return;
+
+  savingStageId.value = stage.id;
+  errorMessage.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.createDeal({ deal });
+
+    deals.value = [response.data, ...deals.value];
+    closeNewDealForm();
+  } catch (error) {
+    setError(error);
+  } finally {
+    savingStageId.value = null;
+  }
+};
+
+const onDragStart = deal => {
+  draggingDealId.value = deal.id;
+};
+
+const onDragEnd = () => {
+  draggingDealId.value = null;
+};
+
+const updateLocalDeal = updatedDeal => {
+  deals.value = deals.value.map(item =>
+    item.id === updatedDeal.id ? { ...item, ...updatedDeal } : item
+  );
+
+  if (selectedDeal.value?.id === updatedDeal.id) {
+    selectedDeal.value = { ...selectedDeal.value, ...updatedDeal };
+  }
+};
+
+const onDrop = async stage => {
+  const deal = deals.value.find(item => item.id === draggingDealId.value);
+  if (!deal || deal.stage_id === stage.id) {
+    draggingDealId.value = null;
+    return;
+  }
+
+  errorMessage.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.updateDeal(deal.id, {
+      deal: { stage_id: stage.id },
+    });
+
+    updateLocalDeal(response.data);
+  } catch (error) {
+    setError(error);
+  } finally {
+    draggingDealId.value = null;
+  }
+};
+
+const formatAmount = amount => {
+  if (amount === null || amount === undefined || amount === '') return '';
+  const value = Number(amount);
+  return Number.isFinite(value) ? moneyFormatter.format(value) : '';
+};
+
+const formatDate = value => {
+  if (!value) return '';
+  const date = new Date(value);
+  return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
+};
+
+const formatRentalPeriod = deal => {
+  const start = formatDate(deal.rental_start);
+  const end = formatDate(deal.rental_end);
+
+  if (start && end) return `${start} - ${end}`;
+  return start || end;
+};
+
+const rottingMinutes = rottingSince => {
+  const startedAt = new Date(rottingSince).getTime();
+  if (Number.isNaN(startedAt)) return 0;
+  return Math.max(0, Math.floor((Date.now() - startedAt) / 60000));
+};
+
+const rottingBadgeClass = deal => {
+  return rottingMinutes(deal.rotting_since) >= 60
+    ? 'bg-n-ruby-3 text-n-ruby-11'
+    : 'bg-n-amber-3 text-n-amber-11';
+};
+
+const contactName = deal => deal.contact?.name || deal.title;
+const phoneNumber = deal => deal.contact?.phone_number || deal.client_phone;
+const assignedName = deal => deal.assigned_user?.name || '';
+const conversationDisplayId = deal => {
+  return deal.conversation?.display_id || deal.conversation_id;
+};
+
+const conversationLabel = deal => {
+  const displayId = conversationDisplayId(deal);
+  return displayId ? `#${displayId}` : 'Linked';
+};
+
+const openDeal = deal => {
+  selectedDeal.value = deal;
+};
+
+const closeDealDrawer = () => {
+  selectedDeal.value = null;
+};
+
+const openConversation = deal => {
+  const conversationId = conversationDisplayId(deal);
+  if (!conversationId) return;
+
+  router.push({
+    name: 'inbox_conversation',
+    params: {
+      accountId: accountId.value,
+      conversation_id: conversationId,
+    },
+  });
+};
+
+watch(
+  accountId,
+  () => {
+    if (!accountId.value) return;
+    initializePipeline();
+  },
+  { immediate: true },
+);
+</script>
+
