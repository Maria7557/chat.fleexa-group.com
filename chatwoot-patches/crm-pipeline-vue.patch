+const createDeal = async () => {
+  const deal = dealPayloadFromForm();
+  if (!deal) return;
+
+  savingStageId.value = deal.stage_id;
+  errorMessage.value = '';
+  newDealError.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.createDeal({ deal });
+    const createdDeal = response.data;
+
+    deals.value = [createdDeal, ...deals.value];
+    closeNewDealForm();
+    openDeal(createdDeal);
+    fetchPipeline();
+  } catch (error) {
+    newDealError.value = error?.response?.data?.error || error?.message || 'Deal create failed';
+  } finally {
+    savingStageId.value = null;
+  }
+};
