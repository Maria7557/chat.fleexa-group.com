+    if (phone) payload.phone_number = phone;
+    if (email) payload.email = email;
+
+    const response = await ContactAPI.create(payload);
+    const contact = response.data?.payload?.contact;
+    if (contact) selectClient(contact);
+  } catch (error) {
+    newDealError.value = error?.response?.data?.message ||
+      error?.response?.data?.error ||
+      error?.message ||
+      'Client create failed';
+  } finally {
+    isCreatingContact.value = false;
+  }
+};
+
+const dealPayloadFromForm = () => {
+  if (!selectedClient.value?.id) {
+    newDealError.value = 'Select or create a client';
+    return null;
+  }
+
+  const form = newDealForm.value;
