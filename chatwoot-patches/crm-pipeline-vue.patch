+};
+
+const normalizeHexColor = color => {
+  return /^#[0-9A-F]{6}$/i.test(color || '') ? color : '#6B7280';
+};
+
+const colorWithAlpha = (color, alpha) => {
+  const normalizedColor = normalizeHexColor(color).slice(1);
+  const red = Number.parseInt(normalizedColor.slice(0, 2), 16);
+  const green = Number.parseInt(normalizedColor.slice(2, 4), 16);
+  const blue = Number.parseInt(normalizedColor.slice(4, 6), 16);
+
+  return `rgba(${red}, ${green}, ${blue}, ${alpha})`;
+};
+
+const stageBadgeStyle = stage => {
+  const color = stage?.color || '#6B7280';
+
+  return {
+    backgroundColor: colorWithAlpha(color, 0.14),
+    color: normalizeHexColor(color),
+  };
+};
+
+const stageDotStyle = stage => ({
+  backgroundColor: normalizeHexColor(stage?.color),
+});
+
+const assignedName = deal => {
+  const assignedUser = deal.assigned_user || deal.assignee || deal.assigned_to;
+
+  if (assignedUser && typeof assignedUser === 'object') {
+    return assignedUser.name || assignedUser.email || `#${assignedUser.id}`;
+  }
+
+  return assignedUser ? `#${assignedUser}` : '';
+};
+const conversationDisplayId = deal => {
+  return deal.conversation?.display_id || deal.conversation_id;
+};
+
+const conversationLabel = deal => {
+  const displayId = conversationDisplayId(deal);
+  return displayId ? `#${displayId}` : 'Linked';
+};
+
+const inboxForDeal = deal => {
+  const inboxId = deal.conversation?.inbox_id;
+  if (!inboxId) return null;
+
+  return inboxes.value.find(inbox => String(inbox.id) === String(inboxId)) ||
+    deal.conversation?.inbox ||
+    null;
+};
+
+const inboxName = deal => {
+  const inbox = inboxForDeal(deal);
+  return inbox?.name || deal.conversation?.inbox_name || '';
+};
+
+const inboxFallbackLabel = deal => {
+  return inboxName(deal) || (deal.conversation?.inbox_id ? `Inbox #${deal.conversation.inbox_id}` : '');
+};
+
+const inboxIconClass = deal => {
+  const inbox = inboxForDeal(deal);
+  const channel = String(
+    inbox?.channel_type ||
+      inbox?.channelType ||
+      deal.conversation?.channel_type ||
+      deal.conversation?.channelType ||
+      ''
+  ).toLowerCase();
+
+  if (channel.includes('telegram')) return 'i-lucide-send';
+  if (channel.includes('whatsapp')) return 'i-lucide-braces';
+  return 'i-lucide-inbox';
+};
