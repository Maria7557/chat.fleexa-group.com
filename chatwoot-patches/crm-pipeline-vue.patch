+  if (!deal || deal.stage_id === stage.id) {
+    draggingDealId.value = null;
+    return;
+  }
+
+  errorMessage.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.updateDeal(deal.id, {
+      deal: { stage_id: stage.id },
+    });
+
+    updateLocalDeal(response.data);
+  } catch (error) {
+    setError(error);
+  } finally {
+    draggingDealId.value = null;
+  }
+};
