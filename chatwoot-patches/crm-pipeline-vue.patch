+const createClient = async () => {
+  const phone = contactForm.value.phone_number.trim();
+  const email = contactForm.value.email.trim();
+
+  if (!phone && !email) {
+    newDealError.value = 'Phone or email required';
+    return;
+  }
+
+  isCreatingContact.value = true;
+  newDealError.value = '';
+
+  try {
+    const payload = {
+      name: createClientName(),
+      custom_attributes: {
+        client_type: contactForm.value.client_type,
+        language: contactForm.value.language,
+      },
+    };
