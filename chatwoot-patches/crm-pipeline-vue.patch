+const contactSearchQuery = ref('');
+const contactSearchResults = ref([]);
+const isSearchingContacts = ref(false);
+const isCreatingContact = ref(false);
+const showCreateClientForm = ref(false);
+const contactForm = ref(buildContactForm());
+const newDealError = ref('');
+const appliedFilters = ref(buildEmptyFilters());
+const draftFilters = ref(buildEmptyFilters());
+const isFilterPanelOpen = ref(false);
+const isExportModalOpen = ref(false);
+const isExporting = ref(false);
+const exportScope = ref('all');
+const exportFormat = ref('csv');
+const viewMode = ref('kanban');
+const filterShellRef = ref(null);
+const listSettingsRef = ref(null);
+const isListSettingsOpen = ref(false);
+const visibleListColumnKeys = ref([...DEFAULT_LIST_COLUMN_KEYS]);
+const selectedDealIds = ref(new Set());
+const currentPage = ref(1);
+
+let contactSearchTimeout = null;
+let contactSearchController = null;
+
+const dateRangeFilters = [
+  { key: '', label: 'Any date' },
+  { key: 'today', label: 'Today' },
+  { key: 'yesterday', label: 'Yesterday' },
+  { key: 'last_7_days', label: 'Last 7 days' },
+  { key: 'this_week', label: 'This week' },
+  { key: 'last_week', label: 'Last week' },
+  { key: 'this_month', label: 'This month' },
+  { key: 'last_month', label: 'Last month' },
+  { key: 'this_quarter', label: 'Quarter' },
+];
+
+const moneyFormatter = new Intl.NumberFormat('en-AE', {
+  style: 'currency',
+  currency: 'AED',
+});
+
+const dateFormatter = new Intl.DateTimeFormat('en-GB', {
+  day: '2-digit',
+  month: 'short',
+  year: 'numeric',
+});
+
+const dateTimeFormatter = new Intl.DateTimeFormat('en-GB', {
+  day: '2-digit',
+  month: 'short',
+  year: 'numeric',
+  hour: '2-digit',
+  minute: '2-digit',
+  hour12: false,
+});
+
+const cloneFilters = filters => ({
+  ...buildEmptyFilters(),
+  ...(filters || {}),
+  fieldFilters: { ...(filters?.fieldFilters || {}) },
+});
+
+const normalizeListColumnKeys = keys => {
+  const validKeys = new Set(DEFAULT_LIST_COLUMN_KEYS);
+  const normalizedKeys = Array.isArray(keys)
+    ? keys.filter(key => validKeys.has(key))
+    : [];
+
+  return normalizedKeys.length ? normalizedKeys : [...DEFAULT_LIST_COLUMN_KEYS];
+};
+
+const loadVisibleListColumns = () => {
+  if (!accountId.value || typeof window === 'undefined') return;
+
+  try {
+    const savedKeys = window.localStorage.getItem(listColumnStorageKey.value);
+    visibleListColumnKeys.value = normalizeListColumnKeys(
+      savedKeys ? JSON.parse(savedKeys) : DEFAULT_LIST_COLUMN_KEYS
+    );
+  } catch {
+    visibleListColumnKeys.value = [...DEFAULT_LIST_COLUMN_KEYS];
+  }
+};
+
+const persistVisibleListColumns = () => {
+  if (!accountId.value || typeof window === 'undefined') return;
+
+  window.localStorage.setItem(
+    listColumnStorageKey.value,
+    JSON.stringify(visibleListColumnKeys.value)
+  );
+};
+
+const isListColumnVisible = key => visibleListColumnKeys.value.includes(key);
+
+const setListColumnVisibility = (key, visible) => {
+  if (!DEFAULT_LIST_COLUMN_KEYS.includes(key)) return;
+
+  if (visible) {
+    visibleListColumnKeys.value = normalizeListColumnKeys([
+      ...visibleListColumnKeys.value,
+      key,
+    ]);
+  } else if (visibleListColumnKeys.value.length > 1) {
+    visibleListColumnKeys.value = visibleListColumnKeys.value.filter(
+      columnKey => columnKey !== key
+    );
+  }
+
+  persistVisibleListColumns();
+};
+
+const resetListColumns = () => {
+  visibleListColumnKeys.value = [...DEFAULT_LIST_COLUMN_KEYS];
+  persistVisibleListColumns();
+};
+
+const toggleListSettings = () => {
+  isFilterPanelOpen.value = false;
+  isListSettingsOpen.value = !isListSettingsOpen.value;
+};
+
+const orderedStages = computed(() => {
+  return [...stages.value].sort((a, b) => a.position - b.position);
+});
+
+const currentUserId = computed(() => {
+  return currentUser.value?.id ? String(currentUser.value.id) : '';
+});
+
+const defaultStageId = computed(() => {
+  return activeStageId.value || orderedStages.value[0]?.id || '';
+});
+
+const sourceRequestField = computed(() => {
+  return fieldDefinitions.value.find(field => field.key === 'source_request') ||
+    fieldDefinitions.value.find(field => field.key === 'source_requect');
+});
+
+const sourceRequestOptions = computed(() => {
+  const options = sourceRequestField.value?.options || [];
+  return options.map(option => ({ value: String(option), label: String(option) }));
+});
+
+const sourceRequestColumnLabel = computed(() => {
+  const label = String(sourceRequestField.value?.label || '').trim();
+  const normalized = label.toLowerCase().replace(/[_-]+/g, ' ');
+
+  if (normalized.includes('source') && normalized.includes('request')) {
+    return label;
+  }
+
+  return 'Source Request';
+});
+
+const listColumnDefinitions = computed(() => [
+  {
+    key: 'created_at',
+    label: 'Date created',
+    width: '10.5rem',
+    headerClass: 'w-[10.5rem]',
+    cellClass: 'w-[10.5rem] text-n-slate-11',
+  },
+  {
+    key: 'title',
+    label: 'Client',
+    width: '17rem',
+    headerClass: 'w-[17rem]',
+    cellClass: 'w-[17rem]',
+  },
+  {
+    key: 'stage',
+    label: 'Stage',
+    width: '12rem',
+    headerClass: 'w-[12rem]',
+    cellClass: 'w-[12rem]',
+  },
+  {
+    key: 'source_request',
+    label: sourceRequestColumnLabel.value,
+    width: '13rem',
+    headerClass: 'w-[13rem]',
+    cellClass: 'w-[13rem] text-n-slate-11',
+  },
+  {
+    key: 'selected_car',
+    label: 'Selected Car',
+    width: '14rem',
+    headerClass: 'w-[14rem]',
+    cellClass: 'w-[14rem] text-n-slate-11',
+  },
+  {
+    key: 'budget',
+    label: 'Budget',
+    width: '10rem',
+    headerClass: 'w-[10rem]',
+    cellClass: 'w-[10rem] text-n-slate-12',
+  },
+  {
+    key: 'operator',
+    label: 'Operator',
+    width: '10rem',
+    headerClass: 'w-[10rem]',
+    cellClass: 'w-[10rem] text-n-slate-11',
+  },
+]);
+
+const listColumnStorageKey = computed(() => {
+  return `fleexa.crm.pipeline.list_columns.${accountId.value}`;
+});
+
+const visibleListColumns = computed(() => {
+  const visibleKeys = new Set(visibleListColumnKeys.value);
+  return listColumnDefinitions.value.filter(column => visibleKeys.has(column.key));
+});
+
+const listResultSummary = computed(() => {
+  const loadedCount = deals.value.length;
+  const totalCount = pipelineMeta.value?.total_count ?? loadedCount;
+
+  if (pipelineMeta.value?.has_more) {
+    return `${loadedCount} of ${totalCount} deals`;
+  }
+
+  return `${loadedCount} deals`;
+});
+
+const hasMoreDeals = computed(() => Boolean(pipelineMeta.value?.has_more));
+
+const assignedUserOptions = computed(() => {
+  const users = new Map();
+  const user = currentUser.value;
+
+  if (user?.id) {
+    users.set(String(user.id), user.name || user.email || 'Current user');
+  }
+
+  deals.value.forEach(deal => {
+    const assignedUser = deal.assigned_user;
+    if (!assignedUser?.id) return;
+
+    users.set(
+      String(assignedUser.id),
+      assignedUser.name || assignedUser.email || `#${assignedUser.id}`
+    );
+  });
+
+  return [
+    { value: '', label: 'Unassigned' },
+    ...[...users.entries()].map(([value, label]) => ({ value, label })),
+  ];
+});
+
+const dealsByStage = computed(() => {
+  return deals.value.reduce((memo, deal) => {
+    const stageDeals = memo[deal.stage_id] || [];
+    stageDeals.push(deal);
+    memo[deal.stage_id] = stageDeals;
+    return memo;
+  }, {});
+});
+
+const dealsForStage = stageId => dealsByStage.value[stageId] || [];
+
+const visibleDealIds = computed(() => deals.value.map(deal => deal.id));
+
+const allVisibleDealsSelected = computed(() => {
+  return visibleDealIds.value.length > 0 &&
+    visibleDealIds.value.every(id => selectedDealIds.value.has(id));
+});
+
+const someVisibleDealsSelected = computed(() => {
+  return visibleDealIds.value.some(id => selectedDealIds.value.has(id)) &&
+    !allVisibleDealsSelected.value;
+});
+
+const allVisibleDealsModel = computed({
+  get: () => allVisibleDealsSelected.value,
+  set: value => toggleAllVisibleDeals(value),
+});
+
+const isDealSelected = dealId => selectedDealIds.value.has(dealId);
+
+const toggleDealSelection = (dealId, checked) => {
+  const nextSelectedIds = new Set(selectedDealIds.value);
+
+  if (checked) {
+    nextSelectedIds.add(dealId);
+  } else {
+    nextSelectedIds.delete(dealId);
+  }
+
+  selectedDealIds.value = nextSelectedIds;
+};
+
+const toggleAllVisibleDeals = checked => {
+  const nextSelectedIds = new Set(selectedDealIds.value);
+
+  visibleDealIds.value.forEach(id => {
+    if (checked) {
+      nextSelectedIds.add(id);
+    } else {
+      nextSelectedIds.delete(id);
+    }
+  });
+
+  selectedDealIds.value = nextSelectedIds;
+};
+
+const pruneSelectedDealIds = () => {
+  const loadedDealIds = new Set(visibleDealIds.value);
+  selectedDealIds.value = new Set(
+    [...selectedDealIds.value].filter(id => loadedDealIds.has(id))
+  );
+};
+
+const amountValue = amount => {
+  if (amount === null || amount === undefined || amount === '') return 0;
+  const value = Number(amount);
+  return Number.isFinite(value) ? value : 0;
+};
+
+const totalFromDeals = () => {
+  return deals.value.reduce((sum, deal) => sum + amountValue(deal.amount), 0);
+};
+
+const pipelineTotalCount = computed(() => {
+  return pipelineMeta.value?.total_count ?? deals.value.length;
+});
