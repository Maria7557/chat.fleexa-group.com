+const searchContacts = async query => {
+  const search = query.trim();
+  if (search.length < 2) {
+    contactSearchResults.value = [];
+    return;
+  }
+
+  contactSearchController?.abort();
+  const controller = new AbortController();
+  contactSearchController = controller;
+  isSearchingContacts.value = true;
+
+  try {
+    const response = await ContactAPI.search(search, 1, 'name', '', {
+      signal: controller.signal,
+    });
+    contactSearchResults.value = response.data?.payload || [];
+  } catch (error) {
+    if (error.name === 'CanceledError' || error.code === 'ERR_CANCELED') return;
+
+    newDealError.value = error?.response?.data?.error || error?.message || 'Contact search failed';
+  } finally {
+    if (contactSearchController === controller) {
+      contactSearchController = null;
+      isSearchingContacts.value = false;
+    }
+  }
+};
+
+const createClientName = () => {
+  const firstName = contactForm.value.first_name.trim();
+  const lastName = contactForm.value.last_name.trim();
+  const name = [firstName, lastName].filter(Boolean).join(' ');
+
+  return name ||
+    contactForm.value.phone_number.trim() ||
+    contactForm.value.email.trim() ||
+    'Unknown';
+};
