@@ -0,0 +1,1023 @@
+<script setup>
+import { computed, onMounted, ref } from 'vue';
+
+import CrmPipelineAPI from 'dashboard/api/crmPipeline';
+import Button from 'dashboard/components-next/button/Button.vue';
+import Spinner from 'dashboard/components-next/spinner/Spinner.vue';
+
+const PAGE_SIZE = 200;
+const SUCCESSFUL_STAGE_TYPES = ['reserved', 'rental', 'closed_won'];
+const LOST_STAGE_TYPES = ['closed_lost'];
+const AED_FORMATTER = new Intl.NumberFormat('en-AE', {
+  style: 'currency',
+  currency: 'AED',
+  maximumFractionDigits: 2,
+});
+
+const rangeOptions = [
+  { value: '', label: 'All' },
+  { value: 'today', label: 'Today' },
+  { value: 'yesterday', label: 'Yesterday' },
+  { value: 'last_30_days', label: '30 days' },
+  { value: 'this_month', label: 'This month' },
+  { value: 'last_7_days', label: '7 days' },
+];
+
+const TREND_CHART_WIDTH = 720;
+const TREND_CHART_HEIGHT = 260;
+const TREND_CHART_PADDING = {
+  top: 18,
+  right: 18,
+  bottom: 34,
+  left: 42,
+};
+const TREND_CHART_INNER_WIDTH =
+  TREND_CHART_WIDTH - TREND_CHART_PADDING.left - TREND_CHART_PADDING.right;
+const TREND_CHART_INNER_HEIGHT =
+  TREND_CHART_HEIGHT - TREND_CHART_PADDING.top - TREND_CHART_PADDING.bottom;
+const TREND_SERIES = [
+  { key: 'all', label: 'All Leads', color: '#6B7280', width: 3 },
+  { key: 'google', label: 'Google', color: '#2563EB', width: 2 },
+  { key: 'meta', label: 'Meta', color: '#0EA5E9', width: 2 },
+  { key: 'tiktok', label: 'TikTok', color: '#DB2777', width: 2 },
+];
+const PAID_SOURCE_KEYS = ['google', 'meta', 'tiktok'];
+
+const stages = ref([]);
+const deals = ref([]);
+const meta = ref({});
+const selectedRange = ref('');
+const customDateFrom = ref('');
+const customDateTo = ref('');
+const isLoading = ref(false);
+const errorMessage = ref('');
+const visibleTrendSeries = ref({
+  all: true,
+  google: true,
+  meta: true,
+  tiktok: true,
+});
+const activeTrendIndex = ref(null);
+
+const normalizeText = value => String(value || '').trim().toLowerCase();
+
+const amountValue = value => {
+  const parsed = Number.parseFloat(value || 0);
+  return Number.isFinite(parsed) ? parsed : 0;
+};
+
+const formatAmount = value => AED_FORMATTER.format(amountValue(value));
+
+const formatNumber = value => new Intl.NumberFormat('en-US').format(value || 0);
+
+const formatPercent = value => {
+  const parsed = Number(value || 0);
+  return `${parsed.toFixed(parsed >= 10 ? 0 : 1)}%`;
+};
+
+const orderedStages = computed(() => {
+  return [...stages.value].sort((a, b) => Number(a.position || 0) - Number(b.position || 0));
+});
+
+const totalDeals = computed(() => deals.value.length);
+
+const isCustomRangeActive = computed(() => {
+  return Boolean(customDateFrom.value || customDateTo.value);
+});
+
+const stageCount = stageId => {
+  return deals.value.filter(deal => String(deal.stage_id) === String(stageId)).length;
+};
+
+const stageRevenue = stageId => {
+  return deals.value
+    .filter(deal => String(deal.stage_id) === String(stageId))
+    .reduce((sum, deal) => sum + amountValue(deal.amount), 0);
+};
+
+const stageIsLost = stage => {
+  const slug = normalizeText(stage?.slug);
+  const name = normalizeText(stage?.name);
+  const trigger = normalizeText(stage?.fleet_status_trigger);
+
+  return slug === 'closed_lost' || trigger === 'cancel' || name === 'отмена';
+};
+
+const forwardStages = computed(() => orderedStages.value.filter(stage => !stageIsLost(stage)));
+const lostStages = computed(() => orderedStages.value.filter(stage => stageIsLost(stage)));
+const firstForwardStageId = computed(() => forwardStages.value[0]?.id);
+
+const stageType = stage => {
+  const slug = normalizeText(stage?.slug);
+  const name = normalizeText(stage?.name);
+
+  if (slug === 'reserved' || name === 'бронь') return 'reserved';
+  if (slug === 'rental' || name === 'в аренде') return 'rental';
+  if (slug === 'closed_won' || name === 'завершено') return 'closed_won';
+  if (stageIsLost(stage)) return 'closed_lost';
+  return '';
+};
+
+const stageById = computed(() => {
+  return orderedStages.value.reduce((memo, stage) => {
+    memo[String(stage.id)] = stage;
+    return memo;
+  }, {});
+});
+
+const stageTypeById = computed(() => {
+  return orderedStages.value.reduce((memo, stage) => {
+    const type = stageType(stage);
+    if (type) memo[String(stage.id)] = type;
+    return memo;
+  }, {});
+});
+
+const dealStageType = deal => stageTypeById.value[String(deal.stage_id)] || '';
+
+const dealsByStageTypes = types => {
+  return deals.value.filter(deal => types.includes(dealStageType(deal)));
+};
+
+const revenueForStageTypes = types => {
+  return dealsByStageTypes(types).reduce((sum, deal) => sum + amountValue(deal.amount), 0);
+};
+
+const countForStageTypes = types => dealsByStageTypes(types).length;
+
+const spamDealsCount = computed(() => {
+  return deals.value.filter(deal => normalizeText(deal.conversation?.status) === 'spam').length;
+});
+
+const spamRate = computed(() => {
+  return totalDeals.value ? (spamDealsCount.value / totalDeals.value) * 100 : 0;
+});
+
+const activityStageIds = deal => {
+  const activityLists = [
+    deal.stage_history,
+    deal.stageHistory,
+    deal.crm_deal_activities,
+    deal.activities,
+  ].filter(Array.isArray);
+  const ids = new Set();
+
+  activityLists.flat().forEach(activity => {
+    ['stage_id', 'from_stage_id', 'to_stage_id'].forEach(key => {
+      if (hasValue(activity?.[key])) ids.add(String(activity[key]));
+    });
+  });
+
+  return ids;
+};
+
+const dealReachedStage = (deal, stage) => {
+  const stageId = String(stage.id);
+  if (String(firstForwardStageId.value || '') === stageId) return true;
+  if (String(deal.stage_id) === stageId) return true;
+
+  const historyStageIds = activityStageIds(deal);
+  if (historyStageIds.size) return historyStageIds.has(stageId);
+
+  const currentStage = stageById.value[String(deal.stage_id)];
+  if (!currentStage || stageIsLost(currentStage)) return false;
+
+  return Number(stage.position || 0) <= Number(currentStage.position || 0);
+};
+
+const buildStageRow = (stage, count, label) => {
+  const share = totalDeals.value ? (count / totalDeals.value) * 100 : 0;
+
+  return {
+    ...stage,
+    count,
+    amount: stageRevenue(stage.id),
+    share,
+    barWidth: share,
+    metricLabel: label,
+  };
+};
+
+const stageRows = computed(() => {
+  const forwardRows = forwardStages.value.map(stage => {
+    const reachedCount = deals.value.filter(deal => dealReachedStage(deal, stage)).length;
+    return buildStageRow(stage, reachedCount, 'of new deals');
+  });
+  const lostRows = lostStages.value.map(stage => {
+    return buildStageRow(stage, stageCount(stage.id), 'lost of new deals');
+  });
+
+  return [...forwardRows, ...lostRows];
+});
+
+const hasValue = value => {
+  if (Array.isArray(value)) return value.length > 0;
+  return value !== null && value !== undefined && String(value).trim() !== '';
+};
+
+const trendPadDatePart = value => String(value).padStart(2, '0');
+
+const trendDateKeyFromDate = date => {
+  return [
+    date.getFullYear(),
+    trendPadDatePart(date.getMonth() + 1),
+    trendPadDatePart(date.getDate()),
+  ].join('-');
+};
+
+const trendDateFromKey = key => {
+  const [year, month, day] = String(key || '').split('-').map(Number);
+  if (!year || !month || !day) return null;
+  return new Date(year, month - 1, day);
+};
+
+const trendDateKeyFromValue = value => {
+  if (!hasValue(value)) return '';
+
+  const date = new Date(value);
+  if (Number.isNaN(date.getTime())) return '';
+  return trendDateKeyFromDate(date);
+};
+
+const addDaysToTrendKey = (key, days) => {
+  const date = trendDateFromKey(key);
+  if (!date) return '';
+
+  date.setDate(date.getDate() + days);
+  return trendDateKeyFromDate(date);
+};
+
+const trendDateKeysBetween = (fromKey, toKey) => {
+  const fromDate = trendDateFromKey(fromKey);
+  const toDate = trendDateFromKey(toKey);
+  if (!fromDate || !toDate || fromDate > toDate) return [];
+
+  const keys = [];
+  const cursor = new Date(fromDate);
+  while (cursor <= toDate) {
+    keys.push(trendDateKeyFromDate(cursor));
+    cursor.setDate(cursor.getDate() + 1);
+  }
+
+  return keys;
+};
+
+const displayTrendDateKey = key => {
+  const [year, month, day] = String(key || '').split('-');
+  return year && month && day ? `${day}/${month}/${year}` : '';
+};
+
+const dateBoundsForPreset = preset => {
+  const todayKey = trendDateKeyFromDate(new Date());
+
+  if (preset === 'today') {
+    return { from: todayKey, to: todayKey };
+  }
+
+  if (preset === 'yesterday') {
+    const yesterdayKey = addDaysToTrendKey(todayKey, -1);
+    return { from: yesterdayKey, to: yesterdayKey };
+  }
+
+  if (preset === 'last_7_days') {
+    return { from: addDaysToTrendKey(todayKey, -6), to: todayKey };
+  }
+
+  if (preset === 'last_30_days') {
+    return { from: addDaysToTrendKey(todayKey, -29), to: todayKey };
+  }
+
+  if (preset === 'this_month') {
+    const today = new Date();
+    return {
+      from: trendDateKeyFromDate(new Date(today.getFullYear(), today.getMonth(), 1)),
+      to: todayKey,
+    };
+  }
+
+  return { from: '', to: '' };
+};
+
+const normalizedAttributes = source => {
+  if (!source || Array.isArray(source) || typeof source !== 'object') return {};
+  return source;
+};
+
+const dealAttributeSources = deal => [
+  normalizedAttributes(deal),
+  normalizedAttributes(deal?.custom_attributes),
+  normalizedAttributes(deal?.contact?.custom_attributes),
+  normalizedAttributes(deal?.contact?.additional_attributes),
+  normalizedAttributes(deal?.conversation?.custom_attributes),
+  normalizedAttributes(deal?.conversation?.additional_attributes),
+];
+
+const valueFromDealSources = (deal, keys) => {
+  const sources = dealAttributeSources(deal);
+
+  for (const source of sources) {
+    for (const key of keys) {
+      if (hasValue(source[key])) return source[key];
+    }
+  }
+
+  return '';
+};
+
+const paidSourceKeyFromText = value => {
+  const normalized = normalizeText(value).replace(/[\s_-]+/g, '');
+  if (!normalized) return '';
+  if (normalized.includes('google')) return 'google';
+  if (
+    normalized.includes('meta') ||
+    normalized.includes('facebook') ||
+    normalized === 'fb' ||
+    normalized.includes('instagram') ||
+    normalized === 'ig'
+  ) {
+    return 'meta';
+  }
+  if (normalized.includes('tiktok')) return 'tiktok';
+  if (normalized.includes('unknown')) return 'unknown';
+  return 'other';
+};
+
+const classifyTrafficSource = deal => {
+  const firstTouchSource = valueFromDealSources(deal, [
+    'first_touch_source_label',
+    'first_touch_source_key',
+  ]);
+  const firstTouchSourceKey = paidSourceKeyFromText(firstTouchSource);
+  if (firstTouchSourceKey) return firstTouchSourceKey;
+
+  if (hasValue(valueFromDealSources(deal, ['gclid', 'gclientid']))) {
+    return 'google';
+  }
+
+  if (hasValue(valueFromDealSources(deal, ['fbclid']))) {
+    return 'meta';
+  }
+
+  if (paidSourceKeyFromText(valueFromDealSources(deal, ['utm_source'])) === 'tiktok') {
+    return 'tiktok';
+  }
+
+  return 'unknown';
+};
+
+const kpiCards = computed(() => [
+  {
+    label: 'Spend',
+    value: formatAmount(0),
+    detail: 'Ad spend in selected period',
+    icon: 'i-lucide-wallet',
+  },
+  {
+    label: 'New Leads',
+    value: formatNumber(totalDeals.value),
+    detail: 'All new deals in selected period',
+    icon: 'i-lucide-inbox',
+  },
+  {
+    label: 'Successful Deals',
+    value: formatNumber(countForStageTypes(SUCCESSFUL_STAGE_TYPES)),
+    detail: 'Reserved + Rental + Done',
+    icon: 'i-lucide-check-check',
+  },
+  {
+    label: 'Successful Deals Amount',
+    value: formatAmount(revenueForStageTypes(SUCCESSFUL_STAGE_TYPES)),
+    detail: 'Reserved + Rental + Done value',
+    icon: 'i-lucide-ticket',
+  },
+  {
+    label: 'Lost',
+    value: formatNumber(countForStageTypes(LOST_STAGE_TYPES)),
+    detail: 'Closed lost / cancelled',
+    icon: 'i-lucide-circle-x',
+  },
+  {
+    label: 'Spam %',
+    value: formatPercent(spamRate.value),
+    detail: `${formatNumber(spamDealsCount.value)} spam conversations`,
+    icon: 'i-lucide-percent',
+  },
+]);
+
+const dealDateKeys = computed(() => {
+  return deals.value.map(deal => trendDateKeyFromValue(deal.created_at)).filter(Boolean).sort();
+});
+
+const trendDateKeys = computed(() => {
+  if (!dealDateKeys.value.length) return [];
+
+  const presetBounds = dateBoundsForPreset(selectedRange.value);
+  const fromKey = customDateFrom.value || presetBounds.from || dealDateKeys.value[0];
+  const toKey =
+    customDateTo.value ||
+    presetBounds.to ||
+    dealDateKeys.value[dealDateKeys.value.length - 1];
+
+  return trendDateKeysBetween(fromKey, toKey);
+});
+
+const leadTrendRows = computed(() => {
+  const rowsByDate = trendDateKeys.value.reduce((memo, dateKey) => {
+    memo[dateKey] = {
+      key: dateKey,
+      label: displayTrendDateKey(dateKey),
+      all: 0,
+      google: 0,
+      meta: 0,
+      tiktok: 0,
+    };
+    return memo;
+  }, {});
+
+  deals.value.forEach(deal => {
+    const dateKey = trendDateKeyFromValue(deal.created_at);
+    const row = rowsByDate[dateKey];
+    if (!row) return;
+
+    row.all += 1;
+    const sourceKey = classifyTrafficSource(deal);
+    if (PAID_SOURCE_KEYS.includes(sourceKey)) row[sourceKey] += 1;
+  });
+
+  return trendDateKeys.value.map(dateKey => rowsByDate[dateKey]).filter(Boolean);
+});
+
+const maxTrendValue = computed(() => {
+  const visibleKeys = TREND_SERIES
+    .filter(series => visibleTrendSeries.value[series.key] !== false)
+    .map(series => series.key);
+  const maxValue = leadTrendRows.value.reduce((max, row) => {
+    return Math.max(max, ...visibleKeys.map(key => row[key] || 0));
+  }, 0);
+
+  return Math.max(maxValue, 1);
+});
+
+const trendPointX = (index, total) => {
+  if (total <= 1) {
+    return TREND_CHART_PADDING.left + TREND_CHART_INNER_WIDTH / 2;
+  }
+
+  return TREND_CHART_PADDING.left + (TREND_CHART_INNER_WIDTH * index) / (total - 1);
+};
+
+const trendPointY = value => {
+  return TREND_CHART_PADDING.top +
+    TREND_CHART_INNER_HEIGHT -
+    (TREND_CHART_INNER_HEIGHT * Number(value || 0)) / maxTrendValue.value;
+};
+
+const linePathFromPoints = points => {
+  return points
+    .map((point, index) => `${index === 0 ? 'M' : 'L'} ${point.x.toFixed(2)} ${point.y.toFixed(2)}`)
+    .join(' ');
+};
+
+const leadTrendSeries = computed(() => {
+  const total = leadTrendRows.value.length;
+
+  return TREND_SERIES.map(series => {
+    const points = leadTrendRows.value.map((row, index) => ({
+      x: trendPointX(index, total),
+      y: trendPointY(row[series.key]),
+      value: row[series.key] || 0,
+      date: row.label,
+    }));
+
+    return {
+      ...series,
+      points,
+      path: points.length ? linePathFromPoints(points) : '',
+    };
+  });
+});
+
+const trendGridLines = computed(() => {
+  return [1, 0.5, 0].map(ratio => {
+    const value = Math.round(maxTrendValue.value * ratio);
+    return {
+      key: ratio,
+      y: trendPointY(value),
+      label: formatNumber(value),
+    };
+  });
+});
+
+const trendXAxisLabels = computed(() => {
+  const rows = leadTrendRows.value;
+  if (!rows.length) return [];
+
+  const lastIndex = rows.length - 1;
+  const indexes = [...new Set([0, Math.floor(lastIndex / 2), lastIndex])];
+
+  return indexes.map(index => ({
+    key: `${rows[index].key}-${index}`,
+    label: rows[index].label,
+    x: trendPointX(index, rows.length),
+  }));
+});
+
+const activeTrendRow = computed(() => {
+  if (activeTrendIndex.value === null) return null;
+  return leadTrendRows.value[activeTrendIndex.value] || null;
+});
+
+const activeTrendSeriesPoints = computed(() => {
+  if (activeTrendIndex.value === null) return [];
+
+  return leadTrendSeries.value
+    .filter(series => visibleTrendSeries.value[series.key] !== false)
+    .map(series => ({
+      ...series,
+      point: series.points[activeTrendIndex.value],
+    }))
+    .filter(series => series.point);
+});
+
+const activeTrendGuideX = computed(() => {
+  return activeTrendSeriesPoints.value[0]?.point?.x || 0;
+});
+
+const trendTooltipStyle = computed(() => {
+  const x = activeTrendGuideX.value || TREND_CHART_WIDTH / 2;
+  const anchor = x > TREND_CHART_WIDTH * 0.72 ? '-100%' : '-50%';
+
+  return {
+    left: `${(x / TREND_CHART_WIDTH) * 100}%`,
+    transform: `translateX(${anchor})`,
+  };
+});
+
+const isTrendSeriesVisible = key => visibleTrendSeries.value[key] !== false;
+
+const toggleTrendSeries = key => {
+  visibleTrendSeries.value = {
+    ...visibleTrendSeries.value,
+    [key]: !isTrendSeriesVisible(key),
+  };
+};
+
+const requestParams = page => {
+  const params = {
+    include_meta: true,
+    page,
+    per_page: PAGE_SIZE,
+  };
+
+  if (selectedRange.value) {
+    params.created_at_preset = selectedRange.value;
+  }
+
+  if (customDateFrom.value) {
+    params.created_at_from = customDateFrom.value;
+  }
+
+  if (customDateTo.value) {
+    params.created_at_to = customDateTo.value;
+  }
+
+  return params;
+};
+
+const normalizeDealsResponse = response => {
+  const payload = response.data || {};
+  if (Array.isArray(payload)) {
+    return {
+      data: payload,
+      meta: {
+        total_count: payload.length,
+        has_more: false,
+      },
+    };
+  }
+
+  return {
+    data: payload.data || [],
+    meta: payload.meta || {},
+  };
+};
+
+const fetchAnalytics = async () => {
+  isLoading.value = true;
+  errorMessage.value = '';
+
+  try {
+    const [stageResponse, firstDealResponse] = await Promise.all([
+      CrmPipelineAPI.getStages(),
+      CrmPipelineAPI.getDeals(requestParams(1)),
+    ]);
+    const firstPage = normalizeDealsResponse(firstDealResponse);
+    const nextDeals = [...firstPage.data];
+    let nextMeta = firstPage.meta;
+
+    while (nextMeta.has_more) {
+      const response = await CrmPipelineAPI.getDeals(requestParams(Number(nextMeta.page || 1) + 1));
+      const page = normalizeDealsResponse(response);
+      nextDeals.push(...page.data);
+      nextMeta = page.meta;
+    }
+
+    stages.value = stageResponse.data || [];
+    deals.value = nextDeals;
+    meta.value = {
+      ...nextMeta,
+      total_count: nextMeta.total_count ?? nextDeals.length,
+    };
+  } catch (error) {
+    errorMessage.value = error?.response?.data?.error || error?.message || 'Failed to load analytics';
+  } finally {
+    isLoading.value = false;
+  }
+};
+
+const selectRange = value => {
+  selectedRange.value = value;
+  customDateFrom.value = '';
+  customDateTo.value = '';
+  fetchAnalytics();
+};
+
+const updateCustomDates = ({ from = customDateFrom.value, to = customDateTo.value } = {}) => {
+  customDateFrom.value = from;
+  customDateTo.value = to;
+  selectedRange.value = '';
+  fetchAnalytics();
+};
+
+const setActiveTrendPoint = event => {
+  if (!leadTrendRows.value.length) return;
+
+  const bounds = event.currentTarget.getBoundingClientRect();
+  const relativeX = ((event.clientX - bounds.left) / bounds.width) * TREND_CHART_WIDTH;
+  const clampedX = Math.min(
+    Math.max(relativeX, TREND_CHART_PADDING.left),
+    TREND_CHART_WIDTH - TREND_CHART_PADDING.right
+  );
+  const ratio = (clampedX - TREND_CHART_PADDING.left) / TREND_CHART_INNER_WIDTH;
+  const index = Math.round(ratio * (leadTrendRows.value.length - 1));
+
+  activeTrendIndex.value = Math.min(Math.max(index, 0), leadTrendRows.value.length - 1);
+};
+
+const clearActiveTrendPoint = () => {
+  activeTrendIndex.value = null;
+};
+
+onMounted(fetchAnalytics);
+</script>
+
+<template>
+  <section class="flex h-full min-h-0 flex-col bg-n-background">
+    <header class="border-b border-n-weak px-8 py-6">
+      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
+        <div>
+          <div class="flex items-center gap-3">
+            <h1 class="text-2xl font-semibold tracking-normal text-n-slate-12">
