+            >
+              {{ contactInitial }}
+            </div>
+            <div class="min-w-0">
+              <div class="truncate text-sm font-medium text-n-slate-12">
+                {{ contactName }}
+              </div>
+              <div class="mt-0.5 flex flex-wrap items-center gap-2 text-xs text-n-slate-11">
+                <span v-if="contactPhone">{{ contactPhone }}</span>
+                <span v-if="contactPhone && contactEmail" class="h-1 w-1 rounded-full bg-n-slate-7" />
+                <span v-if="contactEmail">{{ contactEmail }}</span>
+              </div>
+            </div>
+          </div>
+          <span
+            v-if="conversation?.status"
+            class="shrink-0 rounded-md bg-n-alpha-2 px-2 py-1 text-xs font-medium capitalize text-n-slate-11"
+          >
