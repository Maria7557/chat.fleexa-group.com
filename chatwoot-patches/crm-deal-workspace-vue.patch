+<script setup>
+import { computed, nextTick, ref, watch } from 'vue';
+import { useRoute, useRouter } from 'vue-router';
+
+import CrmPipelineAPI from 'dashboard/api/crmPipeline';
+import Button from 'dashboard/components-next/button/Button.vue';
+import Spinner from 'dashboard/components-next/spinner/Spinner.vue';
+import TextArea from 'dashboard/components-next/textarea/TextArea.vue';
+import { useAccount } from 'dashboard/composables/useAccount';
+
+const route = useRoute();
+const router = useRouter();
+const { accountId } = useAccount();
+
+const deal = ref(null);
+const stages = ref([]);
+const conversation = ref(null);
+const messages = ref([]);
+const dealForm = ref({});
+const replyText = ref('');
+const errorMessage = ref('');
+const messageError = ref('');
+const saveMessage = ref('');
+const isLoading = ref(false);
+const isSaving = ref(false);
+const isLoadingMessages = ref(false);
+const isLoadingEarlier = ref(false);
+const isSendingReply = ref(false);
+const messagesPaneRef = ref(null);
+
+const moneyFormatter = new Intl.NumberFormat('en-AE', {
+  style: 'currency',
+  currency: 'AED',
+});
+
+const dateFormatter = new Intl.DateTimeFormat('en-GB', {
+  day: '2-digit',
+  month: 'short',
+  year: 'numeric',
+});
+
+const timeFormatter = new Intl.DateTimeFormat('en-GB', {
+  day: '2-digit',
+  month: 'short',
+  hour: '2-digit',
+  minute: '2-digit',
+});
+
+const orderedStages = computed(() => {
+  return [...stages.value].sort((a, b) => a.position - b.position);
+});
+
+const activeStage = computed(() => {
+  return stages.value.find(stage => stage.id === deal.value?.stage_id);
+});
+
+const contact = computed(() => deal.value?.contact || {});
+const contactName = computed(() => contact.value?.name || deal.value?.title || 'Client');
+const contactPhone = computed(() => contact.value?.phone_number || deal.value?.client_phone || '');
+const contactEmail = computed(() => contact.value?.email || '');
+const contactInitial = computed(() => contactName.value.slice(0, 1).toUpperCase());
+const conversationDisplayId = computed(() => deal.value?.conversation?.display_id);
+const hasConversation = computed(() => !!conversationDisplayId.value);
+const canReply = computed(() => {
+  return hasConversation.value && conversation.value?.can_reply !== false;
+});
+
+const replyDisabled = computed(() => {
+  return (
+    !hasConversation.value ||
+    !canReply.value ||
+    isSendingReply.value ||
+    !replyText.value.trim()
+  );
+});
+
+const fieldClass =
+  'h-9 w-full rounded-md border border-n-weak bg-n-background px-3 text-sm text-n-slate-12 outline-none focus:border-n-brand';
+
+const buildDealForm = source => ({
+  title: source?.title || '',
+  stage_id: source?.stage_id || '',
+  client_phone: source?.client_phone || '',
+  car_model: source?.car_model || '',
+  booking_id: source?.booking_id || '',
+  rental_start: source?.rental_start || '',
+  rental_end: source?.rental_end || '',
+  amount: source?.amount ?? '',
+  debt_amount: source?.debt_amount ?? '',
+});
+
+const setError = error => {
+  errorMessage.value = error?.response?.data?.error || error?.message || 'Request failed';
+};
+
+const setMessageError = error => {
+  messageError.value = error?.response?.data?.error || error?.message || 'Message request failed';
+};
+
+const formatAmount = amount => {
+  if (amount === null || amount === undefined || amount === '') return '';
+  const value = Number(amount);
+  return Number.isFinite(value) ? moneyFormatter.format(value) : '';
+};
+
+const formatDate = value => {
+  if (!value) return '';
+  const date = new Date(value);
+  return Number.isNaN(date.getTime()) ? '' : dateFormatter.format(date);
+};
+
+const formatMessageTime = value => {
+  if (!value) return '';
+  const date = new Date(value * 1000);
+  return Number.isNaN(date.getTime()) ? '' : timeFormatter.format(date);
+};
+
+const formatRentalPeriod = computed(() => {
+  const start = formatDate(deal.value?.rental_start);
+  const end = formatDate(deal.value?.rental_end);
+
+  if (start && end) return `${start} - ${end}`;
+  return start || end;
+});
+
+const scrollMessagesToBottom = async () => {
+  await nextTick();
+  const pane = messagesPaneRef.value;
+  if (!pane) return;
+  pane.scrollTop = pane.scrollHeight;
+};
+
+const loadConversation = async () => {
+  conversation.value = null;
+  messages.value = [];
+  messageError.value = '';
+
+  if (!conversationDisplayId.value) return;
+
+  isLoadingMessages.value = true;
+
+  try {
+    const [conversationResponse, messagesResponse] = await Promise.all([
+      CrmPipelineAPI.getConversation(conversationDisplayId.value),
+      CrmPipelineAPI.getConversationMessages(conversationDisplayId.value, {
+        filter_internal_messages: true,
+      }),
+    ]);
+
+    conversation.value = conversationResponse.data;
+    messages.value = messagesResponse.data?.payload || [];
+    await scrollMessagesToBottom();
+  } catch (error) {
+    setMessageError(error);
+  } finally {
+    isLoadingMessages.value = false;
+  }
+};
+
+const loadWorkspace = async () => {
+  if (!route.params.dealId) return;
+
+  isLoading.value = true;
+  errorMessage.value = '';
+  saveMessage.value = '';
+
+  try {
+    const [stageResponse, dealResponse] = await Promise.all([
+      CrmPipelineAPI.getStages(),
+      CrmPipelineAPI.getDeal(route.params.dealId),
+    ]);
+
+    stages.value = stageResponse.data || [];
+    deal.value = dealResponse.data;
+    dealForm.value = buildDealForm(deal.value);
+    await loadConversation();
+  } catch (error) {
+    setError(error);
+  } finally {
+    isLoading.value = false;
+  }
+};
+
+const openPipeline = () => {
+  router.push({
+    name: 'crm_pipeline_index',
+    params: { accountId: accountId.value },
+  });
+};
+
+const openInboxConversation = () => {
+  if (!conversationDisplayId.value) return;
+
+  router.push({
+    name: 'inbox_conversation',
+    params: {
+      accountId: accountId.value,
+      conversation_id: conversationDisplayId.value,
+    },
+  });
+};
+
+const dealPayload = () => ({
+  title: dealForm.value.title,
+  stage_id: dealForm.value.stage_id,
+  client_phone: dealForm.value.client_phone,
+  car_model: dealForm.value.car_model,
+  booking_id: dealForm.value.booking_id,
+  rental_start: dealForm.value.rental_start,
+  rental_end: dealForm.value.rental_end,
+  amount: dealForm.value.amount,
+  debt_amount: dealForm.value.debt_amount,
+});
+
+const saveDeal = async () => {
+  if (!deal.value?.id || !dealForm.value.title.trim()) return;
+
+  isSaving.value = true;
+  errorMessage.value = '';
+  saveMessage.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.updateDeal(deal.value.id, {
+      deal: dealPayload(),
+    });
+
+    deal.value = response.data;
+    dealForm.value = buildDealForm(deal.value);
+    saveMessage.value = 'Saved';
+  } catch (error) {
+    setError(error);
+  } finally {
+    isSaving.value = false;
+  }
+};
+
+const loadEarlierMessages = async () => {
+  if (!conversationDisplayId.value || !messages.value.length) return;
+
+  isLoadingEarlier.value = true;
+  messageError.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.getConversationMessages(
+      conversationDisplayId.value,
+      {
+        before: messages.value[0].id,
+        filter_internal_messages: true,
+      }
+    );
+    const olderMessages = response.data?.payload || [];
+    const existingIds = new Set(messages.value.map(message => message.id));
+    const uniqueOlderMessages = olderMessages.filter(message => !existingIds.has(message.id));
+    messages.value = [...uniqueOlderMessages, ...messages.value];
+  } catch (error) {
+    setMessageError(error);
+  } finally {
+    isLoadingEarlier.value = false;
+  }
+};
+
+const sendReply = async () => {
+  const content = replyText.value.trim();
+  if (replyDisabled.value || !content) return;
+
+  isSendingReply.value = true;
+  messageError.value = '';
+
+  try {
+    const response = await CrmPipelineAPI.sendConversationMessage(
+      conversationDisplayId.value,
+      {
+        content,
+        private: false,
+      }
+    );
+
+    messages.value = [...messages.value, response.data];
+    replyText.value = '';
+    await scrollMessagesToBottom();
+  } catch (error) {
+    setMessageError(error);
+  } finally {
+    isSendingReply.value = false;
+  }
+};
+
+const messageSenderName = message => {
+  if (message.private) return 'Private note';
+  if (message.message_type === 0) return message.sender?.name || contactName.value;
+  if (message.message_type === 1) return message.sender?.name || 'Manager';
+  return 'Activity';
+};
+
+const messageAlignClass = message => {
+  if (message.message_type === 1) return 'items-end';
+  if (message.message_type === 2) return 'items-center';
+  return 'items-start';
+};
+
+const messageBubbleClass = message => {
+  if (message.private) return 'bg-n-amber-3 text-n-slate-12';
+  if (message.message_type === 1) return 'bg-n-brand/10 text-n-slate-12';
+  if (message.message_type === 2) return 'bg-transparent text-n-slate-10';
+  return 'bg-n-surface-2 text-n-slate-12';
+};
+
+const attachmentLabel = message => {
+  const count = message.attachments?.length || 0;
+  if (!count) return '';
+  return count === 1 ? '1 attachment' : `${count} attachments`;
+};
+
+watch(() => route.params.dealId, loadWorkspace, { immediate: true });
+</script>
+
