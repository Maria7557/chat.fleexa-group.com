+              <span v-if="conversationDisplayId" class="inline-flex items-center gap-1 text-n-teal-11">
+                <i class="i-lucide-message-circle h-3.5 w-3.5" />
+                #{{ conversationDisplayId }}
+              </span>
+            </div>
+          </div>
+        </div>
+
+        <div class="flex shrink-0 items-center gap-2">
+          <Button
+            v-if="conversationDisplayId"
+            label="Open in Inbox"
