new file mode 100644
index 0000000..207dc4f
--- /dev/null
+++ b/app/models/airbyte_meta_ads_daily_spend_mock.rb
@@ -0,0 +1,20 @@
+class AirbyteMetaAdsDailySpendMock < ApplicationRecord
+  self.table_name = 'airbyte_meta_ads_daily_spend_mock'
+
+  belongs_to :account
+
+  scope :for_account, ->(account_id) { where(account_id: account_id) }
+
+  before_validation :normalize_currency
+
+  validates :external_row_id, :spend_date, :ad_account_id, :campaign_id, presence: true
+  validates :currency, presence: true, length: { is: 3 }
+  validates :spend, numericality: { greater_than_or_equal_to: 0 }
+
+  private
+
+  def normalize_currency
+    self.currency = currency.to_s.strip.upcase.presence || 'AED'
+    self.synced_at ||= Time.current
+  end
+end
