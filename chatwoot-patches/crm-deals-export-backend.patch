+  def export_deal_title(deal)
+    parts = [deal.contact&.name, deal.car_model].filter_map(&:presence)
+    return parts.join(' - ') if parts.any?
+
+    deal.title
+  end
+
+  def export_closed_at(deal)
+    export_custom_value([export_deal_attributes(deal)], 'closed_at', 'closed_date').presence || 'не закрыта'
+  end
+
+  def export_company_name(contact)
+    export_custom_value(
+      [
+        export_record_attributes(contact, :additional_attributes),
+        export_record_attributes(contact, :custom_attributes)
+      ],
+      'company_name',
+      'company',
+      'organization'
+    )
+  end
+
+  def export_contact_value(deal, *keys)
+    export_custom_value(
+      [
+        export_record_attributes(deal.contact, :custom_attributes),
+        export_record_attributes(deal.contact, :additional_attributes),
+        export_record_attributes(deal.conversation, :custom_attributes),
+        export_deal_attributes(deal)
+      ],
+      *keys
+    )
+  end
+
+  def export_deal_value(deal, *keys)
+    export_custom_value([export_deal_attributes(deal)], *keys)
+  end
+
+  def export_custom_value(attribute_sets, *keys)
+    lookup_keys = keys.flat_map { |key| [key.to_s, key.to_s.downcase] }.uniq
+
+    attribute_sets.each do |attributes|
+      lookup_keys.each do |key|
+        value = attributes[key]
+        return value if value.present? || value == false
+      end
+    end
+
+    ''
+  end
+
+  def export_deal_attributes(deal)
+    export_record_attributes(deal, :custom_attributes)
+  end
+
+  def export_record_attributes(record, attribute_name)
+    return {} unless record&.respond_to?(attribute_name)
+
+    value = record.public_send(attribute_name)
+    return value.to_h.stringify_keys if value.respond_to?(:to_h)
+    return JSON.parse(value).deep_stringify_keys if value.is_a?(String) && value.present?
+
+    {}
+  rescue JSON::ParserError
+    {}
+  end
+
+  def export_datetime(value)
+    return '' if value.blank?
+
+    value.in_time_zone.strftime('%d.%m.%Y %H:%M:%S')
+  end
+
+  def export_period(deal)
+    return '' if deal.rental_start.blank? || deal.rental_end.blank?
+
+    "#{export_day_month(deal.rental_start)}-#{export_day_month(deal.rental_end)}"
+  end
+
+  def export_day_month(value)
+    value.in_time_zone.strftime('%d.%m')
+  end
+
   def range_values_for(*keys)
