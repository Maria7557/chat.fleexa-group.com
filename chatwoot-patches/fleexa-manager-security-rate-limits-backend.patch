+  def enforce_manager_rate_limit!(bucket:, identity:, limit:, window:, message:)
+    result = FleexaManager::V1::RateLimiter.check!(
+      bucket: bucket,
+      identity: identity,
+      limit: limit,
+      window: window
+    )
+    return false unless result.limited?
+
+    response.headers['Retry-After'] = result.retry_after.to_s
+    render_manager_error(
+      'rate_limited',
+      message,
+      status: :too_many_requests,
+      details: {
+        retryAfterSeconds: result.retry_after,
+        limit: result.limit,
+        windowSeconds: result.window
+      }
+    )
+    true
+  end
+
+  def rate_limit_remote_ip
+    request.remote_ip.presence || request.ip.presence || 'unknown'
+  end
