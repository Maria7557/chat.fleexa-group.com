diff --git a/app/services/fleexa_manager/v1/rate_limiter.rb b/app/services/fleexa_manager/v1/rate_limiter.rb
new file mode 100644
index 00000000..985e3326
--- /dev/null
+++ b/app/services/fleexa_manager/v1/rate_limiter.rb
@@ -0,0 +1,72 @@
+require 'digest'
+
+module FleexaManager
+  module V1
+    class RateLimiter
+      MAX_LIMIT = 100_000
+      MAX_WINDOW = 86_400
+
+      Result = Struct.new(:limited, :retry_after, :limit, :window, keyword_init: true) do
+        def limited?
+          limited
+        end
+      end
+
+      class << self
+        def check!(bucket:, identity:, limit:, window:)
+          limit = bounded_integer(limit, MAX_LIMIT)
+          window = bounded_integer(window, MAX_WINDOW)
+          return Result.new(limited: false, retry_after: 0, limit: limit, window: window) if limit.zero? || window.zero?
+
+          now = Time.current.to_i
+          period = now / window
+          key = cache_key(bucket, identity, period)
+          count = increment_counter(key, window * 2)
+          retry_after = [((period + 1) * window) - now, 1].max
+
+          Result.new(
+            limited: count.to_i > limit,
+            retry_after: retry_after,
+            limit: limit,
+            window: window
+          )
+        end
+
+        def reset_local!
+          @local_counts = {}
+        end
+
+        private
+
+        def bounded_integer(value, max)
+          Integer(value).clamp(0, max)
+        rescue ArgumentError, TypeError
+          0
+        end
+
+        def cache_key(bucket, identity, period)
+          normalized_bucket = bucket.to_s.gsub(/[^a-z0-9_:-]/i, '_')
+          digest = Digest::SHA256.hexdigest(identity.to_s)
+
+          "fleexa_manager:rate_limit:#{normalized_bucket}:#{period}:#{digest}"
+        end
+
+        def increment_counter(key, ttl_seconds)
+          Rails.cache.write(key, 0, expires_in: ttl_seconds.seconds) unless Rails.cache.exist?(key)
+          Rails.cache.increment(key, 1) || increment_local_counter(key, ttl_seconds)
+        end
+
+        def increment_local_counter(key, ttl_seconds)
+          now = Time.current.to_i
+          @local_counts ||= {}
+          current = @local_counts[key]
+          current = nil if current.present? && current[:expires_at] <= now
+          current ||= { count: 0, expires_at: now + ttl_seconds }
+          current[:count] += 1
+          @local_counts[key] = current
+          current[:count]
+        end
+      end
+    end
+  end
+end
