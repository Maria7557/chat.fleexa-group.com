--- /dev/null
+++ b/lib/tasks/crm_marketing_spend.rake
@@ -0,0 +1,52 @@
+namespace :crm do
+  namespace :marketing_spend do
+    desc 'Create the Stage 1A sample manual spend entry and normalized daily rows'
+    task :demo_manual_entry, [:account_id] => :environment do |_task, args|
+      account_id = args[:account_id].presence || ENV.fetch('ACCOUNT_ID', nil)
+      abort 'Usage: ACCOUNT_ID=1 rake crm:marketing_spend:demo_manual_entry' if account_id.blank?
+
+      entry = ManualSpendEntry.where(
+        account_id: account_id,
+        source_key: 'dubizzle_ads',
+        campaign_name: 'Homepage banner July'
+      ).first_or_initialize
+
+      entry.assign_attributes(
+        source_label: 'Dubizzle Ads',
+        platform: 'partner_site',
+        vendor_name: 'Dubizzle',
+        notes: 'Stage 1A demo manual spend entry',
+        start_date: Date.new(2026, 7, 1),
+        end_date: Date.new(2026, 7, 14),
+        total_budget: 5000,
+        currency: 'AED',
+        allocation_mode: ManualSpendEntry::ALLOCATION_EVEN_BY_DAY,
+        is_active: true
+      )
+      entry.save!
+
+      daily_rows = MarketingSpendDaily.manual.where(manual_spend_entry_id: entry.id)
+      puts "manual_spend_entry_id=#{entry.id}"
+      puts "daily_rows=#{daily_rows.count}"
+      puts "total_spend_aed=#{daily_rows.sum(:spend_aed).to_d.to_s('F')}"
+    end
+
+    desc 'Rebuild normalized marketing_spend_daily rows from manual spend entries'
+    task :rebuild, [:account_id, :entry_id] => :environment do |_task, args|
+      account_id = args[:account_id].presence || ENV['ACCOUNT_ID']
+      entry_id = args[:entry_id].presence || ENV['ENTRY_ID']
+
+      Crm::MarketingSpend::ManualEntryNormalizer.rebuild_all!(
+        account_id: account_id,
+        entry_id: entry_id
+      )
+
+      scope = MarketingSpendDaily.manual
+      scope = scope.where(account_id: account_id) if account_id.present?
+      scope = scope.where(manual_spend_entry_id: entry_id) if entry_id.present?
+
+      puts "daily_rows=#{scope.count}"
+      puts "total_spend_aed=#{scope.sum(:spend_aed).to_d.to_s('F')}"
+    end
+  end
+end
