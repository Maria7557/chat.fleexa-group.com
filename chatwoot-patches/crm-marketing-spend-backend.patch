+  def marketing_spend_scope
+    return MarketingSpendDaily.none unless MarketingSpendDaily.table_exists?
+
+    scope = MarketingSpendDaily.for_account(Current.account.id)
+    from_date, to_date = spend_date_range
+    scope = scope.where('spend_date >= ?', from_date) if from_date.present?
+    scope = scope.where('spend_date <= ?', to_date) if to_date.present?
+    scope
+  end
+
+  def spend_date_range
+    from_date = parsed_date(params[:spend_date_from] || params[:created_at_from])
+    to_date = parsed_date(params[:spend_date_to] || params[:created_at_to])
+    return [from_date, to_date] if from_date.present? || to_date.present?
+
+    preset_date_range(params[:spend_date_preset] || params[:created_at_preset])
+  end
+
+  def preset_date_range(preset)
+    today = Time.zone.today
+
+    case preset
+    when 'today'
+      [today, today]
+    when 'yesterday'
+      [today - 1.day, today - 1.day]
+    when 'last_7_days'
+      [today - 6.days, today]
+    when 'last_30_days'
+      [today - 29.days, today]
+    when 'this_month'
+      [today.beginning_of_month, today]
+    else
+      [nil, nil]
+    end
+  end
+
+  def parsed_date(value)
+    return if value.blank?
+
+    Date.iso8601(value.to_s)
+  rescue ArgumentError
+    nil
+  end
+
+  def manual_spend_entry_scope
+    ManualSpendEntry.for_account(Current.account.id).order(updated_at: :desc)
+  end
+
+  def set_manual_spend_entry
+    @manual_spend_entry = manual_spend_entry_scope.find(params[:id])
+  end
+
+  def manual_spend_entry_payload
+    params.require(:manual_spend_entry)
+  end
+
+  def manual_spend_entry_params
+    payload = manual_spend_entry_payload.permit(
+      :source,
+      :source_key,
+      :source_label,
+      :vendor_name,
+      :campaign_name,
+      :notes,
+      :start_date,
+      :end_date,
+      :total_budget,
+      :currency,
+      :is_active
+    ).to_h
+    source = payload.delete('source')
+    payload['source_label'] = source if payload['source_label'].blank? && source.present?
+    payload['currency'] = 'AED'
+    payload['platform'] = 'manual'
+    payload['allocation_mode'] = ManualSpendEntry::ALLOCATION_EVEN_BY_DAY
+    payload
+  end
+
+  def manual_spend_entry_json(entry)
+    daily_scope = MarketingSpendDaily.manual.where(manual_spend_entry_id: entry.id)
