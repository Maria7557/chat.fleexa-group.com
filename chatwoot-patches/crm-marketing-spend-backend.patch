diff --git a/app/models/manual_spend_entry.rb b/app/models/manual_spend_entry.rb
new file mode 100644
index 0000000..dca5ac6
--- /dev/null
+++ b/app/models/manual_spend_entry.rb
@@ -0,0 +1,59 @@
+class ManualSpendEntry < ApplicationRecord
+  ALLOCATION_EVEN_BY_DAY = 'even_by_day'.freeze
+
+  belongs_to :account
+  belongs_to :creator, class_name: 'User', foreign_key: :created_by, optional: true
+
+  has_many :marketing_spend_daily,
+           foreign_key: :manual_spend_entry_id,
+           dependent: :delete_all
+
+  scope :active, -> { where(is_active: true) }
+  scope :for_account, ->(account_id) { where(account_id: account_id) }
+
+  before_validation :normalize_source_fields
+  before_validation :normalize_budget_fields
+  after_commit :rebuild_daily_spend_rows, on: [:create, :update]
+
+  validates :source_key, :source_label, :platform, :start_date, :end_date, presence: true
+  validates :allocation_mode, inclusion: { in: [ALLOCATION_EVEN_BY_DAY] }
+  validates :currency, presence: true, length: { is: 3 }
+  validates :total_budget, numericality: { greater_than: 0 }
+  validates :fx_rate_to_aed, numericality: { greater_than: 0 }
+  validates :total_budget_aed, numericality: { greater_than: 0 }
+  validate :end_date_is_not_before_start_date
+
+  private
+
+  def normalize_source_fields
+    self.source_label = source_label.to_s.strip
+    self.source_key = source_key.presence || source_key_from_label(source_label)
+    self.source_key = source_key.to_s.strip.parameterize(separator: '_') if source_key.present?
+    self.platform = platform.presence || 'manual'
+  end
+
+  def normalize_budget_fields
+    self.currency = currency.presence&.upcase || 'AED'
+    self.allocation_mode = allocation_mode.presence || ALLOCATION_EVEN_BY_DAY
+    self.fx_rate_to_aed = 1 if currency == 'AED'
+
+    return if total_budget.blank? || fx_rate_to_aed.blank?
+
+    self.total_budget_aed = BigDecimal(total_budget.to_s) * BigDecimal(fx_rate_to_aed.to_s)
+  end
+
+  def end_date_is_not_before_start_date
+    return if start_date.blank? || end_date.blank?
+    return if end_date >= start_date
+
+    errors.add(:end_date, 'must be on or after start date')
+  end
+
+  def source_key_from_label(value)
+    value.to_s.strip.parameterize(separator: '_').presence || 'manual_spend'
+  end
+
+  def rebuild_daily_spend_rows
+    Crm::MarketingSpend::ManualEntryNormalizer.new(self).rebuild!
+  end
+end
