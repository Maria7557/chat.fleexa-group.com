+class MarketingSpendDaily < ApplicationRecord
+  self.table_name = 'marketing_spend_daily'
+
+  IMPORT_TYPE_MANUAL = 'manual'.freeze
+  SOURCE_SYSTEM_MANUAL = 'manual'.freeze
+
+  belongs_to :account
+  belongs_to :manual_spend_entry, optional: true
+
+  scope :for_account, ->(account_id) { where(account_id: account_id) }
+  scope :manual, -> { where(import_type: IMPORT_TYPE_MANUAL) }
+
+  validates :spend_date, :import_type, :source_system, :source_key, :source_label, presence: true
+  validates :source_currency, presence: true, length: { is: 3 }
+  validates :source_spend, :spend_aed, numericality: { greater_than_or_equal_to: 0 }
+  validates :fx_rate_to_aed, numericality: { greater_than: 0 }
+  validates :manual_spend_entry_id,
+            presence: true,
+            if: -> { import_type == IMPORT_TYPE_MANUAL }
+end
diff --git a/app/services/crm/marketing_spend/manual_entry_normalizer.rb b/app/services/crm/marketing_spend/manual_entry_normalizer.rb
new file mode 100644
index 0000000..f57ec23
--- /dev/null
+++ b/app/services/crm/marketing_spend/manual_entry_normalizer.rb
@@ -0,0 +1,83 @@
+module Crm
+  module MarketingSpend
+    class ManualEntryNormalizer
+      def self.rebuild_all!(account_id: nil, entry_id: nil)
+        scope = ManualSpendEntry.all
+        scope = scope.where(account_id: account_id) if account_id.present?
+        scope = scope.where(id: entry_id) if entry_id.present?
+
+        scope.find_each do |entry|
+          new(entry).rebuild!
+        end
+      end
+
+      def initialize(entry)
+        @entry = entry
+      end
+
+      def rebuild!
+        MarketingSpendDaily.transaction do
+          daily_scope.delete_all
+
+          if entry.is_active?
+            rows.each { |row| MarketingSpendDaily.create!(row) }
+            rows.length
+          else
+            0
+          end
+        end
+      end
+
+      private
+
+      attr_reader :entry
+
+      def daily_scope
+        MarketingSpendDaily.manual.where(manual_spend_entry_id: entry.id)
+      end
+
+      def rows
+        spend_dates.map.with_index do |date, index|
+          {
+            account_id: entry.account_id,
+            spend_date: date,
+            import_type: MarketingSpendDaily::IMPORT_TYPE_MANUAL,
+            source_system: MarketingSpendDaily::SOURCE_SYSTEM_MANUAL,
+            source_key: entry.source_key,
+            source_label: entry.source_label,
+            platform: entry.platform,
+            vendor_name: entry.vendor_name,
+            campaign_name: entry.campaign_name,
+            source_currency: entry.currency,
+            source_spend: allocated_source_amount(index),
+            fx_rate_to_aed: entry.fx_rate_to_aed,
+            spend_aed: allocated_aed_amount(index),
+            manual_spend_entry_id: entry.id
+          }
+        end
+      end
+
+      def spend_dates
+        (entry.start_date..entry.end_date).to_a
+      end
+
+      def allocated_source_amount(index)
+        allocated_amount(entry.total_budget, index)
+      end
+
+      def allocated_aed_amount(index)
+        allocated_amount(entry.total_budget_aed, index)
+      end
+
+      def allocated_amount(total, index)
+        total_amount = BigDecimal(total.to_s).round(2)
+        return total_amount if spend_dates.one?
+
+        daily_amount = (total_amount / spend_dates.length).round(2)
+        return daily_amount unless index == spend_dates.length - 1
+
+        total_amount - (daily_amount * (spend_dates.length - 1))
+      end
+    end
+  end
+end
