+  def default_widgets
+    DEFAULT_WIDGETS.map.with_index do |widget, index|
+      {
+        key: widget[:key],
+        visible: widget[:visible],
+        position: index + 1
+      }
+    end
+  end
+
+  def default_attribution_items(defaults)
+    defaults.map.with_index do |item, index|
+      item.merge(sort_order: index + 1)
+    end
+  end
+
+  def normalized_attribution_items(raw_items, defaults)
+    raw_items = Array(raw_items)
+    return default_attribution_items(defaults) if raw_items.blank?
+
+    fallback_by_key = default_attribution_items(defaults).index_by { |item| item[:key] }
+    items = raw_items.each_with_index.filter_map do |item, index|
+      label = value_for(item, :label).to_s.strip
+      key = attribution_key(value_for(item, :key).presence || label)
+      next if key.blank? || label.blank?
+
+      fallback = fallback_by_key[key] || {}
+      sort_order = value_for(item, :sort_order).to_i
+      {
+        key: key,
+        label: label,
+        color: normalized_color(value_for(item, :color), fallback[:color]),
+        is_active: value_for(item, :is_active).nil? ? true : boolean_value(value_for(item, :is_active)),
+        sort_order: sort_order.positive? ? sort_order : index + 1
+      }
+    end
+
+    return default_attribution_items(defaults) if items.blank?
+
+    items.uniq { |item| item[:key] }
+         .sort_by { |item| item[:sort_order] }
+         .map.with_index { |item, index| item.merge(sort_order: index + 1) }
+  end
+
+  def attribution_key(value)
+    value.to_s
+         .strip
+         .downcase
+         .gsub(/[^a-z0-9]+/, '_')
+         .gsub(/\A_+|_+\z/, '')
+  end
+
+  def normalized_color(value, fallback)
+    color = value.to_s.strip
+    return color if color.match?(/\A#[0-9a-fA-F]{6}\z/)
+
+    fallback.presence || '#94A3B8'
+  end
+
   def default_position(key)
     ALLOWED_WIDGET_KEYS.index(key) || ALLOWED_WIDGET_KEYS.length
   end
