diff --git a/app/services/crm/marketing_spend/google_ads_airbyte_normalizer.rb b/app/services/crm/marketing_spend/google_ads_airbyte_normalizer.rb
new file mode 100644
index 0000000..9a952a4
--- /dev/null
+++ b/app/services/crm/marketing_spend/google_ads_airbyte_normalizer.rb
@@ -0,0 +1,121 @@
+module Crm
+  module MarketingSpend
+    class GoogleAdsAirbyteNormalizer
+      SOURCE_KEY = MarketingSpendDaily::SOURCE_SYSTEM_GOOGLE_ADS
+      SOURCE_LABEL = 'Google Ads'.freeze
+
+      Result = Struct.new(
+        :account_id,
+        :date_from,
+        :date_to,
+        :mock_rows,
+        :deleted_rows,
+        :normalized_rows,
+        :ready_rows,
+        :needs_fx_rows,
+        :spend_aed,
+        keyword_init: true
+      )
+
+      def self.rebuild!(account_id:)
+        new(account_id).rebuild!
+      end
+
+      def initialize(account_id)
+        @account_id = account_id
+      end
+
+      def rebuild!
+        affected_from, affected_to = affected_date_range
+        mock_rows = rows_for_range(affected_from, affected_to).to_a
+        deleted_count = 0
+
+        MarketingSpendDaily.transaction do
+          deleted_count = normalized_scope_for_range(affected_from, affected_to).delete_all
+          mock_rows.each { |row| MarketingSpendDaily.create!(normalized_attributes(row)) }
+        end
+
+        Result.new(
+          account_id: account_id,
+          date_from: affected_from,
+          date_to: affected_to,
+          mock_rows: mock_rows.length,
+          deleted_rows: deleted_count,
+          normalized_rows: mock_rows.length,
+          ready_rows: mock_rows.count { |row| aed?(row.currency) },
+          needs_fx_rows: mock_rows.count { |row| !aed?(row.currency) },
+          spend_aed: mock_rows.sum { |row| aed?(row.currency) ? BigDecimal(row.spend.to_s) : 0.to_d }
+        )
+      end
+
+      private
+
+      attr_reader :account_id
+
+      def affected_date_range
+        mock_range = date_range(mock_scope)
+        normalized_range = date_range(normalized_scope)
+        dates = [mock_range, normalized_range].flatten.compact
+        return [nil, nil] if dates.blank?
+
+        [dates.min, dates.max]
+      end
+
+      def date_range(scope)
+        [scope.minimum(:spend_date), scope.maximum(:spend_date)]
+      end
+
+      def rows_for_range(date_from, date_to)
+        scope = mock_scope.order(:spend_date, :ad_account_id, :campaign_id, :id)
+        scope = scope.where('spend_date >= ?', date_from) if date_from.present?
+        scope = scope.where('spend_date <= ?', date_to) if date_to.present?
+        scope
+      end
+
+      def normalized_scope_for_range(date_from, date_to)
+        scope = normalized_scope
+        scope = scope.where('spend_date >= ?', date_from) if date_from.present?
+        scope = scope.where('spend_date <= ?', date_to) if date_to.present?
+        scope
+      end
+
+      def mock_scope
+        AirbyteGoogleAdsDailySpendMock.for_account(account_id)
+      end
+
+      def normalized_scope
+        MarketingSpendDaily.for_account(account_id).google_ads
+      end
+
+      def normalized_attributes(row)
+        row_is_aed = aed?(row.currency)
+
+        {
+          account_id: account_id,
+          spend_date: row.spend_date,
+          import_type: MarketingSpendDaily::IMPORT_TYPE_AIRBYTE,
+          source_system: MarketingSpendDaily::SOURCE_SYSTEM_GOOGLE_ADS,
+          source_key: SOURCE_KEY,
+          source_label: SOURCE_LABEL,
+          platform: MarketingSpendDaily::SOURCE_SYSTEM_GOOGLE_ADS,
+          vendor_name: SOURCE_LABEL,
+          ad_account_id: row.ad_account_id,
+          ad_account_name: row.ad_account_name,
+          campaign_id: row.campaign_id,
+          campaign_name: row.campaign_name,
+          source_currency: row.currency,
+          source_spend: row.spend,
+          fx_rate_to_aed: row_is_aed ? 1 : nil,
+          spend_aed: row_is_aed ? row.spend : nil,
+          sync_status: row_is_aed ? MarketingSpendDaily::SYNC_STATUS_READY : MarketingSpendDaily::SYNC_STATUS_NEEDS_FX,
+          last_synced_at: row.synced_at,
+          raw_row_id: row.external_row_id
+        }
+      end
+
+      def aed?(currency)
+        currency.to_s.casecmp('AED').zero?
+      end
+    end
+  end
+end
