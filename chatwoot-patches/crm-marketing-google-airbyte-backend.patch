+          spend_date: Date.new(2026, 7, 2),
+          ad_account_id: 'ga-act-1',
+          ad_account_name: 'Fleexa Google Ads',
+          campaign_id: 'ga-campaign-search',
+          campaign_name: 'Search leads July',
+          spend: 1200,
+          currency: 'AED',
+          synced_at: Time.zone.parse('2026-07-03 01:00:00')
+        },
+        {
+          external_row_id: 'google-ads-2026-07-02-fleexa-display-aed',
+          spend_date: Date.new(2026, 7, 2),
+          ad_account_id: 'ga-act-1',
+          ad_account_name: 'Fleexa Google Ads',
+          campaign_id: 'ga-campaign-display',
+          campaign_name: 'Display retargeting July',
+          spend: 450,
+          currency: 'AED',
+          synced_at: Time.zone.parse('2026-07-03 01:15:00')
+        },
+        {
+          external_row_id: 'google-ads-2026-07-03-fleexa-video-usd',
+          spend_date: Date.new(2026, 7, 3),
+          ad_account_id: 'ga-act-2',
+          ad_account_name: 'Fleexa Google Ads USD',
+          campaign_id: 'ga-campaign-video',
+          campaign_name: 'Video awareness July',
+          spend: 300,
+          currency: 'USD',
+          synced_at: Time.zone.parse('2026-07-04 01:00:00')
+        }
+      ]
+
+      rows.each do |attributes|
+        row = AirbyteGoogleAdsDailySpendMock.where(
+          account_id: account_id,
+          external_row_id: attributes[:external_row_id]
+        ).first_or_initialize
+        row.assign_attributes(attributes.merge(account_id: account_id))
+        row.save!
+      end
+
+      scope = AirbyteGoogleAdsDailySpendMock.for_account(account_id)
+      puts "mock_rows=#{scope.count}"
+      puts "mock_source_spend=#{scope.sum(:spend).to_d.to_s('F')}"
+    end
+
+    desc 'Normalize mock Airbyte Google Ads rows into marketing_spend_daily'
+    task :normalize_google_ads, [:account_id] => :environment do |_task, args|
+      account_id = args[:account_id].presence || ENV.fetch('ACCOUNT_ID', nil)
+      abort 'Usage: ACCOUNT_ID=1 rake crm:marketing_spend:normalize_google_ads' if account_id.blank?
+
+      result = Crm::MarketingSpend::GoogleAdsAirbyteNormalizer.rebuild!(account_id: account_id)
+      scope = MarketingSpendDaily.for_account(account_id).google_ads
+
+      puts "account_id=#{result.account_id}"
+      puts "date_from=#{result.date_from}"
+      puts "date_to=#{result.date_to}"
+      puts "mock_rows=#{result.mock_rows}"
+      puts "deleted_rows=#{result.deleted_rows}"
+      puts "normalized_rows=#{result.normalized_rows}"
+      puts "ready_rows=#{result.ready_rows}"
+      puts "needs_fx_rows=#{result.needs_fx_rows}"
+      puts "total_spend_aed=#{scope.ready.sum(:spend_aed).to_d.to_s('F')}"
+      puts "duplicate_grains=#{duplicate_google_ads_grains(scope)}"
+    end
+
+    desc 'Clear local mock Airbyte Google Ads rows and rebuild normalized rows'
+    task :clear_google_ads_mock, [:account_id] => :environment do |_task, args|
+      account_id = args[:account_id].presence || ENV.fetch('ACCOUNT_ID', nil)
+      abort 'Usage: ACCOUNT_ID=1 rake crm:marketing_spend:clear_google_ads_mock' if account_id.blank?
+
+      deleted = AirbyteGoogleAdsDailySpendMock.for_account(account_id).delete_all
+      result = Crm::MarketingSpend::GoogleAdsAirbyteNormalizer.rebuild!(account_id: account_id)
+
+      puts "deleted_mock_rows=#{deleted}"
+      puts "deleted_normalized_rows=#{result.deleted_rows}"
+      puts "normalized_rows=#{result.normalized_rows}"
+    end
+
+    def duplicate_google_ads_grains(scope)
+      scope
+        .select('spend_date, ad_account_id, campaign_id, source_currency, COUNT(*) AS rows_count')
+        .group('spend_date, ad_account_id, campaign_id, source_currency')
+        .having('COUNT(*) > 1')
+        .length
+    end
   end
 end
