+  def apply_unread_filter(scope)
+    scope.where(
+      <<~SQL.squish,
+        EXISTS (
+          SELECT 1
+          FROM messages unread_messages
+          WHERE unread_messages.conversation_id = conversations.id
+            AND unread_messages.account_id = conversations.account_id
+            AND unread_messages.message_type = :incoming_type
+            AND (
+              conversations.agent_last_seen_at IS NULL
+              OR unread_messages.created_at > conversations.agent_last_seen_at
+            )
+        )
+      SQL
+      incoming_type: Message.message_types[:incoming]
+    )
+  end
+
+  def apply_waiting_for_reply_filter(scope)
+    scope.where(
+      "#{last_customer_message_at_sql} IS NOT NULL AND " \
+      "(#{last_agent_reply_at_sql} IS NULL OR #{last_customer_message_at_sql} > #{last_agent_reply_at_sql})"
+    )
+  end
+
+  def last_customer_message_at_sql
+    <<~SQL.squish
+      (
+        SELECT MAX(customer_messages.created_at)
+        FROM messages customer_messages
+        WHERE customer_messages.conversation_id = conversations.id
+          AND customer_messages.account_id = conversations.account_id
+          AND customer_messages.message_type = #{Message.message_types[:incoming]}
+          AND customer_messages.private = FALSE
+      )
+    SQL
+  end
+
+  def last_agent_reply_at_sql
+    <<~SQL.squish
+      (
+        SELECT MAX(agent_messages.created_at)
+        FROM messages agent_messages
+        WHERE agent_messages.conversation_id = conversations.id
+          AND agent_messages.account_id = conversations.account_id
+          AND agent_messages.message_type = #{Message.message_types[:outgoing]}
+          AND agent_messages.private = FALSE
+      )
+    SQL
   end
 
