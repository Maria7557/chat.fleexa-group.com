# Local Chatwoot development only. Do not use these values in production.

SECRET_KEY_BASE=c4dfecadc6f38a2503063ba01ee6951fb965190e239899bf2375b03a6dc9bc0d

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=chatwoot_dev_password
POSTGRES_DB=chatwoot_development

REDIS_URL=redis://redis:6379/0

FRONTEND_URL=http://localhost:3000
RAILS_ENV=development
NODE_ENV=development
INSTALLATION_ENV=docker

ACTIVE_STORAGE_SERVICE=local
ENABLE_INSTAGRAM_CHANNEL_HUMAN_AGENT=true

RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
LOG_LEVEL=debug
FORCE_SSL=false
DEFAULT_LOCALE=en
INSTALLATION_NAME=Fleexa Chatwoot Local

# Optional backend Sentry for patched Chatwoot. Do not commit production DSNs or auth tokens.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=false

# Local default keeps Manager cookies usable over http://localhost.
# Production must rely on HTTPS and secure cookies.
FLEEXA_MANAGER_SESSION_COOKIE_SECURE=false
