# Public URL that Chatwoot and browser users can reach.
WAHA_PUBLIC_URL=https://waha.fleexa-group.com

# WAHA Apps are required for the built-in Chatwoot integration.
WAHA_APPS_ENABLED=True
WAHA_APPS_ON=chatwoot

# Required by the WAHA Chatwoot app for background jobs.
WAHA_REDIS_PASSWORD=<generate-random-redis-password>
REDIS_URL=redis://:<same-random-redis-password>@redis:6379

# Recommended by WAHA Chatwoot docs for reliable WhatsApp automation.
WHATSAPP_DEFAULT_ENGINE=GOWS

# Generate real values before deploy. Do not commit the real .env.
WAHA_API_KEY=<generate-random-secret>
WAHA_API_KEY_PLAIN=<same-plain-secret-for-apps>

# Recommended for dashboard access during POC.
WAHA_DASHBOARD_ENABLED=true
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=<generate-random-dashboard-password>
