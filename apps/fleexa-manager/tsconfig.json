{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@fleexa/api-client": [
        "../../packages/fleexa-api-client/src/index.ts"
      ],
      "@fleexa/config": [
        "../../packages/fleexa-config/src/index.ts"
      ],
      "@fleexa/domain": [
        "../../packages/fleexa-domain/src/index.ts"
      ],
      "@fleexa/ui": [
        "../../packages/fleexa-ui/src/index.tsx"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "app.config.ts"
  ]
}
