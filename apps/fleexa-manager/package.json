{
  "name": "@fleexa/manager",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "web": "expo start --web --port 8082",
    "smoke:web": "expo export --platform web --output-dir dist-web-smoke",
    "validate:env": "tsx ./src/config/validate-env.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "57.0.6",
    "@fleexa/api-client": "*",
    "@fleexa/config": "*",
    "@fleexa/domain": "*",
    "@fleexa/ui": "*",
    "@sentry/react-native": "7.11.0",
    "@tanstack/react-query": "5.101.2",
    "expo": "57.0.7",
    "expo-constants": "57.0.6",
    "expo-linking": "57.0.3",
    "expo-router": "57.0.7",
    "expo-secure-store": "57.0.1",
    "expo-status-bar": "57.0.1",
    "lucide-react-native": "1.25.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "0.21.2",
    "zustand": "5.0.14"
  }
}
