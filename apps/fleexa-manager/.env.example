EXPO_PUBLIC_FLEEXA_APP_ENV=development
EXPO_PUBLIC_FLEEXA_API_MODE=live
EXPO_PUBLIC_FLEEXA_API_BASE_URL=http://localhost:3000/api/fleexa-manager/v1

# Optional. Sentry DSN is not a secret, but leave it empty for local work.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Optional build-time source map upload settings. Do not commit auth tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=https://sentry.io/
