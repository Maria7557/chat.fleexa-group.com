COPY chatwoot-patches/crm-marketing-demo-readiness-vue.patch /tmp/crm-marketing-demo-readiness-vue.patch
COPY chatwoot-patches/crm-marketing-economics-meeting-polish-vue.patch /tmp/crm-marketing-economics-meeting-polish-vue.patch
