RUN cd /app && \
    git apply /tmp/crm-pipeline-vue.patch && \
    git apply /tmp/crm-deal-workspace-vue.patch && \
    git apply /tmp/crm-deal-fields-vue.patch && \
    git apply /tmp/crm-deal-workspace-inbox-chat-vue.patch && \
    git apply /tmp/crm-deal-workspace-sidebar-style-vue.patch && \
    git apply /tmp/crm-deal-workspace-emoji-picker-vue.patch && \
    git apply /tmp/crm-deal-workspace-tabs-vue.patch && \
    git apply /tmp/crm-deal-workspace-conversation-load-fix-vue.patch && \
    git apply /tmp/crm-deal-workspace-assignee-vue.patch && \
    git apply /tmp/crm-marketing-analytics-vue.patch && \
    git apply /tmp/crm-date-input-format-vue.patch && \
    git apply /tmp/crm-marketing-dashboard-config-vue.patch && \
    git apply /tmp/crm-marketing-spend-vue.patch && \
    git apply /tmp/fleexa-global-branding-visible-ui.patch && \
    git apply /tmp/crm-marketing-lead-trend-polish-vue.patch && \
    git apply /tmp/crm-marketing-monthly-spend-revenue-vue.patch && \
    git apply /tmp/crm-marketing-source-settings-vue.patch && \
    git apply /tmp/crm-marketing-source-detection-rules-vue.patch && \
    git apply /tmp/crm-marketing-source-visibility-analytics-vue.patch && \
    git apply /tmp/crm-marketing-attribution-settings-native-vue.patch && \
    git apply /tmp/crm-marketing-page-level-controls-vue.patch && \
    git apply /tmp/crm-marketing-reuse-chatwoot-date-filter-vue.patch && \
    git apply /tmp/crm-marketing-remove-legacy-attribution-vue.patch && \
    git apply /tmp/crm-manual-spend-attribution-sources-vue.patch && \
    git apply /tmp/crm-marketing-attribution-settings-board-vue.patch && \
    git apply /tmp/crm-marketing-economics-foundation-vue.patch && \
    git apply /tmp/crm-marketing-economics-kpi-layer-vue.patch && \
    git apply /tmp/crm-marketing-loss-analysis-vue.patch && \
    git apply /tmp/crm-marketing-demo-readiness-vue.patch && \
    git apply /tmp/crm-marketing-economics-meeting-polish-vue.patch && \
    git apply /tmp/crm-marketing-two-funnels-vue.patch && \
    git apply /tmp/crm-marketing-leads-as-clients-vue.patch && \
    git apply /tmp/crm-marketing-loss-summary-panel-vue.patch && \
    git apply /tmp/crm-marketing-pipeline-funnel-reach-vue.patch && \
    git apply /tmp/crm-marketing-lead-trend-after-economics-vue.patch && \
    git apply /tmp/crm-marketing-monthly-chart-all-periods-vue.patch && \
    HUSKY=0 pnpm install --frozen-lockfile && \
    (node node_modules/esbuild/install.js 2>/dev/null || true)

RUN cd /app && \
    NODE_OPTIONS=--max-old-space-size=2560 \
    SECRET_KEY_BASE=build_dummy_key_not_used_in_production \
    bundle exec rake vite:build_all

