FROM chatwoot/chatwoot:v4.14.2 AS frontend-builder

RUN apk add --no-cache npm && npm install -g pnpm@10.2.0

COPY chatwoot-patches/crm-pipeline-vue.patch /tmp/crm-pipeline-vue.patch
COPY chatwoot-patches/crm-deal-workspace-vue.patch /tmp/crm-deal-workspace-vue.patch
COPY chatwoot-patches/crm-deal-fields-vue.patch /tmp/crm-deal-fields-vue.patch
COPY chatwoot-patches/crm-deal-workspace-inbox-chat-vue.patch /tmp/crm-deal-workspace-inbox-chat-vue.patch
COPY chatwoot-patches/crm-deal-workspace-sidebar-style-vue.patch /tmp/crm-deal-workspace-sidebar-style-vue.patch
COPY chatwoot-patches/crm-deal-workspace-emoji-picker-vue.patch /tmp/crm-deal-workspace-emoji-picker-vue.patch
COPY chatwoot-patches/crm-deal-workspace-tabs-vue.patch /tmp/crm-deal-workspace-tabs-vue.patch
COPY chatwoot-patches/crm-deal-workspace-conversation-load-fix-vue.patch /tmp/crm-deal-workspace-conversation-load-fix-vue.patch
COPY chatwoot-patches/crm-deal-workspace-assignee-vue.patch /tmp/crm-deal-workspace-assignee-vue.patch
COPY chatwoot-patches/crm-marketing-analytics-vue.patch /tmp/crm-marketing-analytics-vue.patch
COPY chatwoot-patches/crm-date-input-format-vue.patch /tmp/crm-date-input-format-vue.patch
COPY chatwoot-patches/crm-marketing-dashboard-config-vue.patch /tmp/crm-marketing-dashboard-config-vue.patch
COPY chatwoot-patches/crm-marketing-spend-vue.patch /tmp/crm-marketing-spend-vue.patch
COPY chatwoot-patches/fleexa-global-branding-visible-ui.patch /tmp/fleexa-global-branding-visible-ui.patch

RUN cd /app && \
    git apply /tmp/crm-pipeline-vue.patch && \
    git apply /tmp/crm-deal-workspace-vue.patch && \
    git apply /tmp/crm-deal-fields-vue.patch && \
    git apply /tmp/crm-deal-workspace-inbox-chat-vue.patch && \
    git apply /tmp/crm-deal-workspace-sidebar-style-vue.patch && \
    git apply /tmp/crm-deal-workspace-emoji-picker-vue.patch && \
    git apply /tmp/crm-deal-workspace-tabs-vue.patch && \
    git apply /tmp/crm-deal-workspace-conversation-load-fix-vue.patch && \
    git apply /tmp/crm-deal-workspace-assignee-vue.patch && \
    git apply /tmp/crm-marketing-analytics-vue.patch && \
    git apply /tmp/crm-date-input-format-vue.patch && \
    git apply /tmp/crm-marketing-dashboard-config-vue.patch && \
    git apply /tmp/crm-marketing-spend-vue.patch && \
    git apply /tmp/fleexa-global-branding-visible-ui.patch && \
    HUSKY=0 pnpm install --frozen-lockfile && \
    (node node_modules/esbuild/install.js 2>/dev/null || true)

RUN cd /app && \
    NODE_OPTIONS=--max-old-space-size=2560 \
    SECRET_KEY_BASE=build_dummy_key_not_used_in_production \
    bundle exec rake vite:build_all

FROM chatwoot/chatwoot:v4.14.2

COPY --from=frontend-builder /app/public/vite /app/public/vite

COPY chatwoot-patches/instagram-human-agent-activity-window.patch /tmp/patch.patch
COPY chatwoot-patches/crm-models.rb.patch /tmp/crm-models.rb.patch
COPY chatwoot-patches/crm-controllers.rb.patch /tmp/crm-controllers.rb.patch
COPY chatwoot-patches/crm-routes.rb.patch /tmp/crm-routes.rb.patch
COPY chatwoot-patches/crm-ensure-from-conversation.patch /tmp/crm-ensure-from-conversation.patch
COPY chatwoot-patches/crm-webhook-listener.patch /tmp/crm-webhook-listener.patch
COPY chatwoot-patches/crm-deal-fields-backend.patch /tmp/crm-deal-fields-backend.patch
COPY chatwoot-patches/crm-deal-query-backend.patch /tmp/crm-deal-query-backend.patch
COPY chatwoot-patches/crm-deals-export-backend.patch /tmp/crm-deals-export-backend.patch
COPY chatwoot-patches/crm-deal-backfill.patch /tmp/crm-deal-backfill.patch
COPY chatwoot-patches/crm-marketing-dashboard-config-backend.patch /tmp/crm-marketing-dashboard-config-backend.patch
COPY chatwoot-patches/crm-marketing-spend-backend.patch /tmp/crm-marketing-spend-backend.patch
COPY chatwoot-patches/crm-marketing-google-airbyte-backend.patch /tmp/crm-marketing-google-airbyte-backend.patch
COPY chatwoot-patches/crm-marketing-meta-airbyte-backend.patch /tmp/crm-marketing-meta-airbyte-backend.patch
COPY chatwoot-patches/crm-marketing-source-mapping-backend.patch /tmp/crm-marketing-source-mapping-backend.patch
COPY chatwoot-patches/crm-pipeline-vue.patch /tmp/crm-pipeline-vue.patch
COPY chatwoot-patches/crm-deal-workspace-vue.patch /tmp/crm-deal-workspace-vue.patch
COPY chatwoot-patches/crm-deal-fields-vue.patch /tmp/crm-deal-fields-vue.patch
COPY chatwoot-patches/crm-deal-workspace-inbox-chat-vue.patch /tmp/crm-deal-workspace-inbox-chat-vue.patch
COPY chatwoot-patches/crm-deal-workspace-sidebar-style-vue.patch /tmp/crm-deal-workspace-sidebar-style-vue.patch
COPY chatwoot-patches/crm-deal-workspace-emoji-picker-vue.patch /tmp/crm-deal-workspace-emoji-picker-vue.patch
COPY chatwoot-patches/crm-deal-workspace-tabs-vue.patch /tmp/crm-deal-workspace-tabs-vue.patch
COPY chatwoot-patches/crm-deal-workspace-conversation-load-fix-vue.patch /tmp/crm-deal-workspace-conversation-load-fix-vue.patch
COPY chatwoot-patches/crm-deal-workspace-assignee-vue.patch /tmp/crm-deal-workspace-assignee-vue.patch
COPY chatwoot-patches/crm-marketing-analytics-vue.patch /tmp/crm-marketing-analytics-vue.patch
COPY chatwoot-patches/crm-date-input-format-vue.patch /tmp/crm-date-input-format-vue.patch
COPY chatwoot-patches/crm-marketing-dashboard-config-vue.patch /tmp/crm-marketing-dashboard-config-vue.patch
COPY chatwoot-patches/crm-marketing-spend-vue.patch /tmp/crm-marketing-spend-vue.patch
COPY chatwoot-patches/fleexa-global-branding-visible-ui.patch /tmp/fleexa-global-branding-visible-ui.patch

RUN cd /app && \
    git apply /tmp/patch.patch && \
    git apply /tmp/crm-models.rb.patch && \
    git apply /tmp/crm-controllers.rb.patch && \
    git apply /tmp/crm-routes.rb.patch && \
    git apply /tmp/crm-ensure-from-conversation.patch && \
    git apply /tmp/crm-webhook-listener.patch && \
    git apply /tmp/crm-deal-fields-backend.patch && \
    git apply /tmp/crm-deal-query-backend.patch && \
    git apply /tmp/crm-deals-export-backend.patch && \
    git apply /tmp/crm-deal-backfill.patch && \
    git apply /tmp/crm-marketing-dashboard-config-backend.patch && \
    git apply /tmp/crm-marketing-spend-backend.patch && \
    git apply /tmp/crm-marketing-google-airbyte-backend.patch && \
    git apply /tmp/crm-marketing-meta-airbyte-backend.patch && \
    git apply /tmp/crm-marketing-source-mapping-backend.patch && \
    git apply /tmp/crm-pipeline-vue.patch && \
    git apply /tmp/crm-deal-workspace-vue.patch && \
    git apply /tmp/crm-deal-fields-vue.patch && \
    git apply /tmp/crm-deal-workspace-inbox-chat-vue.patch && \
    git apply /tmp/crm-deal-workspace-sidebar-style-vue.patch && \
    git apply /tmp/crm-deal-workspace-emoji-picker-vue.patch && \
    git apply /tmp/crm-deal-workspace-tabs-vue.patch && \
    git apply /tmp/crm-deal-workspace-conversation-load-fix-vue.patch && \
    git apply /tmp/crm-deal-workspace-assignee-vue.patch && \
    git apply /tmp/crm-marketing-analytics-vue.patch && \
    git apply /tmp/crm-date-input-format-vue.patch && \
    git apply /tmp/crm-marketing-dashboard-config-vue.patch && \
    git apply /tmp/crm-marketing-spend-vue.patch && \
    git apply /tmp/fleexa-global-branding-visible-ui.patch
